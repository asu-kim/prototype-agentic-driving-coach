target Python{keepalive: true, files:"environment.csv", coordination: decentralized}
preamble{=
    import csv
=}


reactor A {
    timer t(0,100msec)
    output messageB
    reaction(startup){=
        
        try:
            with open("/home/asurite.ad.asu.edu/dprahlad/deterministic-prototyping-agenticCPS/src/HardwareIntegration/environment.csv", "r", newline="") as f:
                reader = csv.DictReader(f)

                headings = reader.fieldnames
                self.lines = list(reader)
                
            self.loaded = True
            print("Environment Loaded", flush=True)
        except Exception as e:
            print(f"Environment is not loaded: {e}", flush=True)
            self.loaded = False
    =}

    reaction(t)-> messageB{=
        messageB.set("This is reactor B")
        row = self.lines[0]
        road_phase = row["road_phase"]
        car_present = int(row["other_car_present"])
        distance = float(row["other_distance_m"])
        velocity = float(row["other_velocity_kmh"])
      
        print(road_phase)
        print(car_present)
        print(distance)
        print(velocity)
        # print(f"LOGICAL TIME AT B: {lf.time.logical_elapsed()/1e6}")
    =}
}

main reactor{
    a = new A()




}