target Python {files: "environment.csv"}
preamble{=
    import csv
=}

reactor Environment{
    input v

    state loaded = False


    state passed = False
    output displacement
    output environment_states
    
    state v_val = 0.0
    reaction(startup){=
        
        try:
            with open("/home/asurite.ad.asu.edu/dprahlad/deterministic-prototyping-agenticCPS/src/HardwareIntegration/environment.csv", "r", newline="") as f:
                reader = csv.DictReader(f)
                headings = reader.fieldnames
                self.lines = list(reader)
            self.loaded = True
            print("Environment Loaded", flush=True)
        except Exception as e:
            print(f"Environment is not loaded: {e}", flush=True)
            self.loaded = False
    =}

    reaction(v) -> displacement, environment_states{=
        row = self.lines[0]
        road_phase = row["road_phase"]
        other_car_present = int(row["other_car_present"])
        other_distance_m = float(row["other_distance_m"])
        other_velocity_kmh = float(row["other_velocity_kmh"])
        right_car_present = int(row["right_car_present"])
        right_car_position = row["right_car_position"]
        right_car_distance_m = float(row["right_car_distance_m"])
        right_car_velocity_kmh = float(row["right_car_velocity_kmh"])
        cross_left_car_present = int(row["cross_left_car_present"])
        cross_right_car_present = int(row["cross_right_car_present"])
        cross_right_car_distance_m = float(row["cross_right_car_distance_m"])
        cross_right_car_velocity_kmh = float(row["cross_right_car_velocity_kmh"])

        en_states = []
        en_states.append(road_phase, other_car_present, other_distance_m, other_velocity_kmh, right_car_present, right_car_position, right_car_distance_m, right_car_velocity_kmh, cross_left_car_present, cross_right_car_present,  cross_right_car_distance_m, cross_right_car_velocity_kmh)
    
        environment_states.set(en_states)

        if v.is_present:
            self.v_val = float(v.value)
        step = self.v_val * 0.1
        if not self.passed:
            self.pos_speed_change -= step

            if self.pos_speed_change <= 0.0:
                self.pos_speed_change = 0.0
                self.passed = True

            displacement.set(self.pos_speed_change)
        else:
            displacement.set(0.0)
        current_dri = lf.time.logical_elapsed()/1e6
        physical_dri = lf.time.physical_elapsed()/1e6
        lag = physical_dri - current_dri

        print(f"[ENV CLOCK] displacement={self.pos_speed_change}", flush=True)
        print("----------------------------------------------------------")
        print(f"[ENVIRONMENT] Logical time: {current_dri:.2f} ", flush=True)
        print(f"[ENVIRONMENT] Physical time: {physical_dri:.2f} ", flush=True)
        print(f"[ENVIRONMENT] LAG: {lag:.2f} ", flush=True)
        print("----------------------------------------------------------")
    =}
 
    
    
}