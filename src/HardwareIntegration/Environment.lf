target Python {files: "environment.csv"}
preamble{=
    import csv
    import json
    import os
    import rerun as rr

    _RUN_MODE = os.getenv("RUN_MODE", "Testing")
    _RERUN_ENABLED = _RUN_MODE == "DataCollect"
=}

reactor Environment{
    input v

    state loaded = False
    state distance_to_exit_m = 1600
    state distance_to_stop_sign_m = 1000
    state distance_after_stop_m = 100
    state row_idx = 0
    state previous_logical_ns = 0
    state has_previous_logical_time = False

    state passed = False
    output displacement
    output environment_states

    state v_val = 0.0
    reaction(startup){=
        if _RERUN_ENABLED:
            rr.init("TCRS_Federated", spawn=False)
            rr.connect()
            print("[RERUN] Environment connected to Rerun viewer.", flush=True)
        print(f"[ENVIRONMENT MODE] {_RUN_MODE}", flush=True)

        try:
            with open("/home/asurite.ad.asu.edu/dprahlad/deterministic-prototyping-agenticCPS/src/HardwareIntegration/environment.csv", "r", newline="") as f:
                reader = csv.DictReader(f)
                headings = reader.fieldnames
                self.lines = list(reader)
            if len(self.lines) == 0:
                raise RuntimeError("environment.csv contains no data rows")
            self.loaded = True
            print("Environment Loaded", flush=True)
        except Exception as e:
            self.loaded = False
            raise RuntimeError(f"Environment is not loaded: {e}") from e
    =}

    reaction(v) -> displacement, environment_states{=
        #reading the csv for the environment variables
        if not self.loaded or len(self.lines) == 0:
            raise RuntimeError("Environment reaction cannot run because environment.csv is not loaded")

        row = self.lines[self.row_idx]
        if self.row_idx < len(self.lines) - 1:
            self.row_idx += 1
        road_phase = row["road_phase"]
        front_car_present = int(row["front_car_present"])
        right_car_present = int(row["right_car_present"])
        right_car_position = row["right_car_position"]
        cross_left_car_present = int(row["cross_left_car_present"])
        cross_right_car_present = int(row["cross_right_car_present"])

        #converting the velocity back to m/s for ease of calculation

        car_velocity = float(v.value if v.value is not None else 0.0) / 3.6
        current_logical_ns = lf.time.logical_elapsed()
        if not self.has_previous_logical_time:
            dt_seconds = 0.0
        else:
            dt_seconds = max(0.0, (current_logical_ns - self.previous_logical_ns) / 1e9)
        self.has_previous_logical_time = True
        self.previous_logical_ns = current_logical_ns
        vdt = car_velocity * dt_seconds
        current_displacement = 0.0
        if road_phase in ("HIGHWAY", "LANE_CHANGE"):
            self.distance_to_exit_m = max(0.0, self.distance_to_exit_m - vdt)
            current_displacement = self.distance_to_exit_m
            displacement.set(current_displacement)

        elif road_phase in ("EXIT", "STOP_SIGN", "YIELD"):
            self.distance_to_stop_sign_m = max(0.0, self.distance_to_stop_sign_m - vdt)
            current_displacement = self.distance_to_stop_sign_m
            displacement.set(current_displacement)

        elif road_phase == "MOVE":
            self.distance_after_stop_m = max(0.0, self.distance_after_stop_m - vdt)
            current_displacement = self.distance_after_stop_m
            displacement.set(current_displacement)

        else:
            displacement.set(0.0)

        en_states = [
            road_phase,
            front_car_present,
            right_car_present,
            right_car_position,
            cross_left_car_present,
            cross_right_car_present
        ]
        environment_states.set(en_states)



        if _RERUN_ENABLED:
            rr.set_time("logical_time_ms", sequence=lf.time.logical_elapsed() // 1_000_000)
            rr.log("environment/displacement_m", rr.Scalars(float(current_displacement)))
            rr.log("environment/road_phase", rr.TextLog(road_phase))
            rr.log("environment/states", rr.TextLog(json.dumps(en_states)))
        current_dri = lf.time.logical_elapsed()/1e6
        physical_dri = lf.time.physical_elapsed()/1e6
        lag = physical_dri - current_dri
        current_tag = lf.tag()

        print(f"[ENV CLOCK] displacement={current_displacement}", flush=True)
        print("----------------------------------------------------------")
        print(f"[ENVIRONMENT] Logical time: {current_dri:.2f} ms", flush=True)
        print(f"[ENVIRONMENT] Physical time: {physical_dri:.2f} ms", flush=True)
        print(f"[ENVIRONMENT] LAG: {lag:.2f} ms", flush=True)
        print(f"[ENVIRONMENT] Tag time: {current_tag.time} ns", flush=True)
        print(f"[ENVIRONMENT] Microstep: {current_tag.microstep}", flush=True)
        print("----------------------------------------------------------")
    =}



}