target Python

preamble{=
    import os
    import rerun as rr
    import time
    import ollama

    _OLLAMA_MODEL = os.getenv("OLLAMA_MODEL", "llama3:8b")
    _CONTROL_IDS = {"NONE": 0.0, "WARNING": 1.0, "ACTUATE": 2.0}
=}

reactor AgenticCoach {
    input s
    input v
    input st 
    input h
    input e
    input en_states

    // output ready
    output control
    output instruction

    reaction(startup) {=
        rr.init(
            "hardware_integrated_adc",
            recording_id=os.getenv("RERUN_RECORDING_ID", "hardware_integrated_adc_run")
        )
        rr.connect_grpc(os.getenv("RERUN_GRPC_URL", "rerun+http://127.0.0.1:9876/proxy"))
        print("[RERUN] LLM viewer initialized.", flush=True)
    =}

    preamble {=
        def run_llm_message(self, llm_inputs):
            import ollama
            import time
            import json

            t0 = time.perf_counter()

            try:
                r = ollama.chat(
                    model=_OLLAMA_MODEL,
                    messages=[
                            {

                            "role": "system",
                            "content": """
                            
                            You are a real-time driving coach. 
                            
                            The environment has tasks in this order:

                            1. The driver must do a lane change from a left lane to right lane before the exiting the highway. The the exit is in 1.6 kilometer.
                            The driver is maintaining a speed between 85 kilometer per hour to 90 kilometer per hour. 
                            The driver must look to the right before changing the lane to avoid any cars on the right lane.

                            2. After lane change, the driver must exiting the highway, and reduce the speed to 45 kilometer per hour.
                            There maybe cars ahead of the driver and the driver must maintain a safe distance.

                            3. There is a stop sign at 1 kilometer after exiting and the driver must come to a stop sign and look right and left before moving ahead.

                            Treat the provided INPUT values as authoritative current measurements. Do not assume the driver is following the task. Compare the current measurements against the task requirements and warn or actuate when they are unsafe or substantially outside the required range.

                            Please guide the driver based on the Inputs from the driver and the environment.

                            You will generate the output in this format:

                            "TOKEN|INSTRUCTION"

                            where TOKEN is:
                                NONE = if the driver is following the instruction
                                WARNING = If the driver is in the recoverable speed region
                                ACTUATE = if there needs to be control taken over.

                            Return exactly one line in TOKEN|INSTRUCTION format with no explanation before it.

                            Instruction is the guiding message for warning or actuation.
                            """
                        },
                        {
                            "role": "user",
                            "content": f"""INPUT:
                                            {json.dumps(llm_inputs, indent=2)}

                                            Return output:"""
                        }
                    ],
                    options={
                        "temperature": 0.1,
                        "num_predict": 30
                    },
                )
            except Exception as e:
                print(">>> LLM ERROR:", e, flush=True)
                return "NONE", "", 0.0

            ms = (time.perf_counter() - t0) * 1000.0
            raw = (r.get("message", {}).get("content", "") or "").strip()
            print(f"[LLM RAW] {raw}", flush=True)

            # Parse token + message properly
            parts = raw.split("|", 1)
            token = parts[0].strip() if len(parts) > 0 else "NONE"
            msg = parts[1].strip() if len(parts) > 1 else ""

            return token, msg, ms
    =}


    reaction(s, v, st, h, e, en_states) -> control, instruction {=
        distance_val = s.value if s.is_present else 0.0
        velocity_val = v.value if v.is_present else 0.0
        steer_input = st.value if st.is_present else None
        head_input = h.value if h.is_present and h.value else ["CENTER"]
        eye_input = e.value if e.is_present and e.value else ["CENTER"]
        environment_values = en_states.value if en_states.is_present else []

        if distance_val <= 0.0:
            distance_val = 0.0

       
        print(
            f"[LLM INPUT] DISTANCE: {distance_val:.2f} m  "
            f"VELOCITY: {velocity_val} km/h  STEER: {steer_input}",
            flush=True
        )
        print(f"Head history: {head_input}", flush=True)
        print(f"Eye history: {eye_input}", flush=True)
        environment_keys = [
            "road_phase",
            "front_car_present",
            "front_car_distance_m",
            "front_car_velocity_kmh",
            "right_car_present",
            "right_car_position",
            "right_car_distance_m",
            "right_car_velocity_kmh",
            "cross_left_car_present",
            "cross_right_car_present"
        ]
        environment_input = dict(zip(environment_keys, environment_values))
        llm_inputs = {
            "distance_to_target_m": distance_val,
            "velocity_kmh": velocity_val,
            "steering": steer_input,
            "head_history": head_input,
            "eye_history": eye_input,
            "environment": environment_input
        }
        print(f"LLM inputs: {llm_inputs}", flush=True)


        tok_raw, msg_raw, ms = self.run_llm_message(llm_inputs)

        current_dri = lf.time.logical_elapsed()/1e6
        physical_dri = lf.time.physical_elapsed()/1e6
        lag = physical_dri - current_dri
        print("----------------------------------------------------------")
        print(f"[LLM INFERENCE] Logical time: {current_dri:.2f} ms", flush=True)
        print(f"[LLM INFERENCE] Physical time: {physical_dri:.2f} ms", flush=True)
        print(f"[LLM INFERENCE] LAG: {lag:.2f} ms", flush=True)
        print("----------------------------------------------------------")

        tok = (tok_raw or "NONE").strip().upper()
        if tok not in {"NONE", "WARNING", "ACTUATE"}:
            tok = "NONE"
        msg = (msg_raw or "").strip()

        print(f"[LLM RESULT] {tok} | {msg} | {ms:.2f} ms", flush=True)

        rr.set_time("logical_time_ms", sequence=lf.time.logical_elapsed() // 1_000_000)
        rr.log("llm/control_id", rr.Scalars(_CONTROL_IDS[tok]))
        rr.log("llm/control", rr.TextLog(tok))
        rr.log("llm/instruction", rr.TextLog(msg))
        rr.log("llm/model", rr.TextLog(_OLLAMA_MODEL))
        rr.log("llm/inference_ms", rr.Scalars(float(ms)))

        control.set(tok)
        instruction.set(msg)

    =} tardy
}