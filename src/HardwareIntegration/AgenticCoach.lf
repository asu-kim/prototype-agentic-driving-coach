target Python

preamble{=
    import csv
    import json
    import os
    import sys
    import time
    import ollama

    _LLM_BEHAVIOR_LOG_PATH = os.getenv(
        "LLM_BEHAVIOR_LOG_PATH",
        "logs-trace/llm_behavior.csv",
    )
    _FEDERATE_EXECUTION_LOG_PATH = os.getenv(
        "FEDERATE_EXECUTION_LOG_PATH",
        "logs-trace/federate_execution_times.csv",
    )

    def _open_execution_log():
        log_dir = os.path.dirname(_FEDERATE_EXECUTION_LOG_PATH)
        if log_dir:
            os.makedirs(log_dir, exist_ok=True)
        needs_header = (
            not os.path.exists(_FEDERATE_EXECUTION_LOG_PATH)
            or os.path.getsize(_FEDERATE_EXECUTION_LOG_PATH) == 0
        )
        log_file = open(_FEDERATE_EXECUTION_LOG_PATH, "a", newline="", encoding="utf-8")
        log_writer = csv.writer(log_file)
        if needs_header:
            log_writer.writerow([
                "federate",
                "reactor",
                "reaction",
                "logical_time_ns",
                "logical_time_ms",
                "tag_time_ns",
                "microstep",
                "lag_ms",
                "start_physical_time_ms",
                "stop_physical_time_ms",
                "execution_time_ms",
            ])
            log_file.flush()
        return log_file, log_writer

    def _log_execution_time(self, federate, reactor, reaction, start_physical_time_ms, stop_physical_time_ms):
        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        self.execution_log_writer.writerow([
            federate,
            reactor,
            reaction,
            logical_time_ns,
            logical_time_ns / 1e6,
            (lf.tag().time - lf.time.start()),
            current_tag.microstep,
            start_physical_time_ms - (logical_time_ns / 1e6),
            start_physical_time_ms,
            stop_physical_time_ms,
            stop_physical_time_ms - start_physical_time_ms,
        ])
        self.execution_log_file.flush()

=}

reactor AgenticCoach {
    input s
    input v
    input st
    input h
    input e
    input en_states


    // output ready
    output control
    output instruction


    preamble {=
        def run_llm_message(self, llm_inputs):
            import ollama
            import time
            import json

            t0 = time.perf_counter()

            try:
                r = ollama.chat(
                    model="llama3.1:8b",
                    messages=[
                            {

                            "role": "system",
                            "content": """

                            You are a real-time driving coach.

                            Treat every INPUT value like authoritative current measurement. Never invent vehicles, hazards, driver actions, or road phases.

                            Apply only the requirements for the current road_phase:

                            - HIGHWAY: Maintain 85-90 km/h. When distance_to_target_m is at most 1000, instruct the driver to prepare to change right for the exit. Do not request a right-lane check before that 1 km point.
                            - LANE_CHANGE: Look right before changing lanes. A right look is satisfied when RIGHT appears in either head_history or eye_history. The right lane is unsafe when right_car_present is 1.
                            - EXIT: Reduce speed toward 45 km/h. distance_to_target_m is distance to the stop sign at the crossroad.
                            - STOP_SIGN: Stop before the sign and look LEFT and RIGHT before moving ahead.
                            - YIELD: Yield until cross traffic has cleared, especially right-side cross traffic.
                            - MOVE: Move ahead for the final 100 m.

                            Choose exactly one control token using this priority:

                            1. ACTUATE for an immediate hazard requiring vehicle control:
                               - front_car_present is 1, or
                               - road_phase is LANE_CHANGE and right_car_present is 1, or
                               - road_phase is STOP_SIGN, distance_to_target_m is at most 5 m, and velocity_kmh is above 5.

                            2. WARNING for a recoverable unmet requirement:
                               - HIGHWAY distance_to_target_m is at most 1000 and the driver has not been told to prepare for the exit,
                               - HIGHWAY velocity is below 85 or above 90 km/h,
                               - LANE_CHANGE has no recent RIGHT look,
                               - EXIT velocity is outside 40-50 km/h, or
                               - STOP_SIGN requires a missing LEFT or RIGHT look.

                            3. NONE when no ACTUATE or WARNING condition applies.

                            Instruction rules:
                            - For low speed, say increase speed. Never say slow down.
                            - For high speed, say reduce speed.
                            - At the HIGHWAY 1 km point, say prepare to change right for the exit.
                            - Do not mention a right-lane vehicle when right_car_present is 0.
                            - For NONE, leave the instruction empty.

                            Output contract:
                            - Decide the control token first, then write the driver-facing instruction yourself.
                            - Return exactly one line and no explanation.
                            - Format: CONTROL|INSTRUCTION
                            - CONTROL must be exactly ACTUATE, WARNING, or NONE.
                            - INSTRUCTION must be a short natural-language command for the driver.
                            - Use exactly one | separator.
                            - Do not output placeholder words such as TOKEN, CONTROL, or INSTRUCTION.
                            - Do not put ACTUATE, WARNING, or NONE in the instruction field.
                            - For NONE, return exactly NONE| with nothing after the separator.

                            Valid examples:
                            WARNING|Reduce speed.
                            WARNING|Increase speed.
                            WARNING|Look right before changing lanes.
                            ACTUATE|Brake for the vehicle ahead.
                            NONE|
                            """
                        },
                        {
                            "role": "user",
                            "content": f"""INPUT:
                                            {json.dumps(llm_inputs, indent=2)}

                                            Return output:"""
                        }
                    ],
                    options={
                        "temperature": 0.1,
                        "num_predict": 30
                    },
                    keep_alive="10m",
                )
            except Exception as e:
                print(">>> LLM ERROR:", e, flush=True)
                return "NONE", "", 0.0

            ms = (time.perf_counter() - t0) * 1000.0
            raw = (r.get("message", {}).get("content", "") or "").strip()
            print(f"[LLM RAW] {raw}", flush=True)

            parts = raw.split("|", 1)
            token = parts[0].strip().upper() if len(parts) > 0 else "NONE"
            msg = parts[1].strip() if len(parts) > 1 else ""

            if token not in {"NONE", "WARNING", "ACTUATE"}:
                print(f"[LLM PARSE WARNING] Invalid token: {token}; raw={raw}", flush=True)
                token = "NONE"
                msg = ""
            elif token == "NONE":
                msg = ""

            return token, msg, ms

    =}


    reaction(startup) {=
        start_physical_time = lf.time.physical_elapsed()/1e6
        self.execution_log_file, self.execution_log_writer = _open_execution_log()
        os.makedirs(os.path.dirname(_LLM_BEHAVIOR_LOG_PATH), exist_ok=True)
        self.llm_behavior_log_file = open(_LLM_BEHAVIOR_LOG_PATH, "w", newline="", encoding="utf-8")
        self.llm_behavior_log_writer = csv.writer(self.llm_behavior_log_file)
        self.llm_behavior_log_writer.writerow([
            "event",
            "logical_time_ns",
            "logical_time_ms",
            "physical_time_ms",
            "tag_time_ns",
            "microstep",
            "lag_ms",
            "displacement_present",
            "velocity_present",
            "steer_present",
            "head_present",
            "eye_present",
            "environment_states_present",
            "distance_to_target_m",
            "velocity_kmh",
            "steering",
            "head_history_json",
            "eye_history_json",
            "environment_json",
            "control",
            "instruction",
            "inference_ms",
            "control_present",
            "instruction_present",
        ])
        self.llm_behavior_log_file.flush()
        print(f"[LLM BEHAVIOR LOG] Writing behavior to {_LLM_BEHAVIOR_LOG_PATH}", flush=True)
        print(f"[EXECUTION LOG] Appending timings to {_FEDERATE_EXECUTION_LOG_PATH}", flush=True)
        warmup_inputs = {
            "distance_to_target_m": 1500.0,
            "velocity_kmh": 88.0,
            "steering": 2,
            "head_history": ["CENTER"],
            "eye_history": ["CENTER"],
            "environment": {
                "road_phase": "HIGHWAY",
                "front_car_present": 0,
                "right_car_present": 0,
                "right_car_position": "",
                "cross_left_car_present": 0,
                "cross_right_car_present": 0,
            },
        }
        print("[LLM WARMUP] Starting startup inference", flush=True)
        self.run_llm_message(warmup_inputs)
        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        
    =}

    reaction(s, v, st, h, e, en_states) -> control, instruction {=

        start_physical_time = lf.time.physical_elapsed()/1e6
        distance_val = s.value if s.is_present else 0.0
        velocity_val = v.value if v.is_present else 0.0
        steer_input = st.value if st.is_present else None
        head_input = h.value if h.is_present and h.value else ["CENTER"]
        eye_input = e.value if e.is_present and e.value else ["CENTER"]
        environment_values = en_states.value if en_states.is_present else []

        environment_input = {
            "road_phase": environment_values[0] if len(environment_values) > 0 else "",
            "front_car_present": environment_values[1] if len(environment_values) > 1 else 0,
            "right_car_present": environment_values[2] if len(environment_values) > 2 else 0,
            "right_car_position": environment_values[3] if len(environment_values) > 3 else "",
            "cross_left_car_present": environment_values[4] if len(environment_values) > 4 else 0,
            "cross_right_car_present": environment_values[5] if len(environment_values) > 5 else 0,
            }

        road_phase = environment_input["road_phase"]

        llm_inputs = {
            "distance_to_target_m": distance_val,
            "velocity_kmh": velocity_val,
            "steering": steer_input,
            "head_history": head_input,
            "eye_history": eye_input,
            "environment": environment_input
        }

        tok_raw, msg_raw, ms = self.run_llm_message(llm_inputs)

        logical_time_ns = lf.time.logical_elapsed()
        current_dri = logical_time_ns / 1e6
        physical_dri = lf.time.physical_elapsed()/1e6
        lag = physical_dri - current_dri
        current_tag = lf.tag()


        tok = (tok_raw or "NONE").strip().upper()
        if tok not in {"NONE", "WARNING", "ACTUATE"}:
            tok = "NONE"
        msg = (msg_raw or "").strip()
        print("----------------------------------------------------------")
        print(f"LLM inputs: {llm_inputs}", flush=True)
        print(f"[LLM INFERENCE] Logical time: {current_dri:.2f} ms", flush=True)
        print(f"[LLM INFERENCE] Physical time: {physical_dri:.2f} ms", flush=True)
        print(f"[LLM INFERENCE] LAG: {lag:.2f} ms", flush=True)
        print(f"[LLM INFERENCE] Tag time: {(lf.tag().time - lf.time.start())} ns", flush=True)
        print(f"[LLM INFERENCE] Microstep: {current_tag.microstep}", flush=True)
        print(f"[LLM RESULT] {tok} | {msg} | {ms:.2f} ms", flush=True)
        print("----------------------------------------------------------")



        
        self.llm_behavior_log_writer.writerow([
            "llm_inference",
            logical_time_ns,
            logical_time_ns / 1e6,
            physical_dri,
            (lf.tag().time - lf.time.start()),
            current_tag.microstep,
            lag,
            int(s.is_present),
            int(v.is_present),
            int(st.is_present),
            int(h.is_present),
            int(e.is_present),
            int(en_states.is_present),
            distance_val,
            velocity_val,
            steer_input,
            json.dumps(head_input),
            json.dumps(eye_input),
            json.dumps(environment_input),
            tok,
            msg,
            ms,
            1,
            1,
        ])
        self.llm_behavior_log_file.flush()

        control.set(tok)
        instruction.set(msg)
        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "llm", "AgenticCoach", "llm_inference", start_physical_time, stop_physical_time)

    =} tardy{=
        start_physical_time = lf.time.physical_elapsed()/1e6
        logical_ms = lf.time.logical_elapsed() / 1e6
        physical_ms = lf.time.physical_elapsed() / 1e6
        print(
            f"[LLM TARDY] reaction started {logical_ms:.2f} ms late\n"
            f"distance={s.value if s.is_present else 'NOT PRESENT'}\n"
            f"velocity={v.value if v.is_present else 'NOT PRESENT'}\n"
            f"steering={st.value if st.is_present else 'NOT PRESENT'}\n"
            f"head={h.value if h.is_present else 'NOT PRESENT'}\n"
            f"eye={e.value if e.is_present else 'NOT PRESENT'}\n"
            f"environment={en_states.value if en_states.is_present else 'NOT PRESENT'}",
            flush=True
        )
        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "llm", "AgenticCoach", "tardy", start_physical_time, stop_physical_time)
    =}

    reaction(shutdown) {=
        if hasattr(self, "llm_behavior_log_file") and not self.llm_behavior_log_file.closed:
            self.llm_behavior_log_file.flush()
            self.llm_behavior_log_file.close()
        if hasattr(self, "execution_log_file") and not self.execution_log_file.closed:
            self.execution_log_file.flush()
            self.execution_log_file.close()
    =}
}
