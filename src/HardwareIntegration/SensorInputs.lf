reactor SensorInputs{
    output steer_msg
    output accel_msg
    output brake_msg
    output head_msg
    output eye_msg
    // output speed
    // output acceleration_mps2
    // output pedal_position

    dev = new DeviceReader()
    wheel = new steering_wheel()
    acc = new accelerator()
    brk = new brake()
    video = new webcam()
    face_detect = new FaceLandmark()
    // speedcalci = new SpeedCalculator()

    dev.steer -> wheel.steer
    wheel.steer_msg -> steer_msg

    dev.brake -> brk.brake
    brk.brake_msg -> brake_msg

    dev.throttle -> acc.accelerate
    acc.accel_msg -> accel_msg

    dev.frame -> video.vid
    video.frame_fps -> face_detect.frame
    
    face_detect.head_msg -> head_msg
    face_detect.eye_msg  -> eye_msg

    // dev.throttle -> speedcalci.throttle
    // dev.brake -> speedcalci.brake

    // speedcalci.speed_kmph -> speed
    // speedcalci.accel_mps2 -> acceleration_mps2
    // speedcalci.pedal_state -> pedal_position

}