/*
* sudo usermod -aG input raspdeeksha
* sudo usermod -aG video raspdeeksha
* to test the device $ python -m evdev.evtest
* * https://python-evdev.readthedocs.io/en/latest/apidoc.html#evdev.events.InputEvent to understand the evdev python library for linux
*/

target Python {keepalive: true}

import DeviceReader from "SensorReader.lf"
import FaceLandmark from "HeadPoseEstimation.lf"
preamble{=
  import cv2
=}


reactor steering_wheel{
   input steer
   output steer_msg
   state deadzone = 0.04

   reaction(steer) -> steer_msg {=
        s = steer.value
        dz = self.deadzone

        if s < -dz:
            # steer_msg.set("LEFT")
            steer_msg.set(0)
        elif s > dz:
            # steer_msg.set("RIGHT")
            steer_msg.set(2)
        else:
            # steer_msg.set("STRAIGHT")
            steer_msg.set(1)
   =}
}

reactor accelerator{
    input accelerate
    output accel_msg

    reaction(accelerate) -> accel_msg {=
        a = accelerate.value
        accel_msg.set(a)
  =}
}

reactor brake{
    input brake
    output brake_msg

    reaction(brake) -> brake_msg {=
        b = brake.value
        brake_msg.set(b)
  =}
}

reactor webcam(period=5){
    input vid
    output frame_fps
    state k = 0

    reaction(vid) -> frame_fps {=
      self.k += 1
      if self.k >= self.period:
        self.k = 0
        frame_fps.set(vid.value)
    =}
}

