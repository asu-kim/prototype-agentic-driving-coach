target Python {
    timeout: 104 sec,
    files: ["face_detection.py"]
}

preamble {=
    import threading
    import time
    import cv2
    import numpy as np
    from evdev import InputDevice, ecodes, list_devices
    from face_detection import FaceDetector
=}

reactor BenchmarkSensorInputs {
    output steer_msg
    output accel_msg
    output brake_msg
    output head_msg
    output eye_msg

    physical action sensor
    timer cam_timer(4 sec, 100 msec)

    state cap
    state cam_ready = False
    state detector

    state control_count = 0
    state control_total_ns = 0
    state control_max_ns = 0
    state camera_count = 0
    state camera_total_ns = 0
    state camera_max_ns = 0
    state face_count = 0
    state face_total_ns = 0
    state face_max_ns = 0
    state monitor_path_count = 0
    state monitor_path_total_ns = 0
    state monitor_path_max_ns = 0

    reaction(startup) -> sensor {=
        self.detector = FaceDetector()

        def find_path():
            for path in list_devices():
                try:
                    device = InputDevice(path)
                    if "shanwan" in device.name.lower() and "gamepad" in device.name.lower():
                        return path
                except Exception:
                    pass
            return None

        def clamp(value, low, high):
            return max(low, min(high, value))

        def norm(device, code, value):
            info = device.absinfo(code)
            if info.max == info.min:
                return 0.0
            return (value - info.min) / (info.max - info.min)

        def reader(action, path):
            device = InputDevice(path)
            xinfo = device.absinfo(ecodes.ABS_X)
            for event in device.read_loop():
                if event.type != ecodes.EV_ABS:
                    continue
                event_start_ns = time.monotonic_ns()
                if event.code == ecodes.ABS_X:
                    value = (2 * (event.value - xinfo.min) / (xinfo.max - xinfo.min)) - 1.0
                    action.schedule(0, ("steer", float(clamp(value, -1.0, 1.0)), event_start_ns))
                elif event.code == ecodes.ABS_BRAKE:
                    value = float(clamp(norm(device, ecodes.ABS_BRAKE, event.value), 0.0, 1.0))
                    action.schedule(0, ("brake", value, event_start_ns))
                elif event.code == ecodes.ABS_GAS:
                    value = float(clamp(norm(device, ecodes.ABS_GAS, event.value), 0.0, 1.0))
                    action.schedule(0, ("accel", value, event_start_ns))

        path = find_path()
        if path is None:
            print("[BENCHMARK] Wheel device not found.", flush=True)
        else:
            threading.Thread(target=reader, args=(sensor, path), daemon=True).start()

        self.cap = cv2.VideoCapture(0, cv2.CAP_V4L2)
        if self.cap.isOpened():
            cv2.setNumThreads(1)
            self.cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
            self.cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)
            self.cap.set(cv2.CAP_PROP_FPS, 10)
            self.cam_ready = True
            self.cap.read()
        else:
            print("[BENCHMARK] Camera cannot be opened.", flush=True)
    =}

    reaction(sensor) -> steer_msg, accel_msg, brake_msg {=
        tag, value, event_start_ns = sensor.value
        if tag == "steer":
            dz = 0.04
            steer_msg.set(0 if value < -dz else 2 if value > dz else 1)
        elif tag == "brake":
            brake_msg.set(value)
        elif tag == "accel":
            accel_msg.set(value)

        elapsed_ns = time.monotonic_ns() - event_start_ns
        self.control_count += 1
        self.control_total_ns += elapsed_ns
        self.control_max_ns = max(self.control_max_ns, elapsed_ns)
    =}

    reaction(cam_timer) -> head_msg, eye_msg {=
        if not self.cam_ready:
            return

        capture_start_ns = time.monotonic_ns()
        ok, image = self.cap.read()
        capture_ns = time.monotonic_ns() - capture_start_ns
        self.camera_count += 1
        self.camera_total_ns += capture_ns
        self.camera_max_ns = max(self.camera_max_ns, capture_ns)

        if not ok or image is None:
            return

        image = np.ascontiguousarray(image.copy())
        face_start_ns = time.monotonic_ns()
        try:
            result = self.detector.process(image)
        except Exception as error:
            print("[BENCHMARK] Detection error:", error, flush=True)
            return
        face_ns = time.monotonic_ns() - face_start_ns
        self.face_count += 1
        self.face_total_ns += face_ns
        self.face_max_ns = max(self.face_max_ns, face_ns)

        if result is None:
            head_msg.set(1)
            eye_msg.set(1)
        else:
            head_msg.set(result["head"])
            eye_msg.set(result["eye"])

        path_ns = time.monotonic_ns() - capture_start_ns
        self.monitor_path_count += 1
        self.monitor_path_total_ns += path_ns
        self.monitor_path_max_ns = max(self.monitor_path_max_ns, path_ns)
    =}

    reaction(shutdown) {=
        def report(name, count, total_ns, max_ns):
            average_ns = total_ns / count if count else 0
            print(f"[{name}]", flush=True)
            print(f"Samples: {count}", flush=True)
            print(f"Average: {average_ns / 1e6:.6f} ms", flush=True)
            print(f"Observed WCET: {max_ns / 1e6:.6f} ms", flush=True)

        print("[REAL SENSOR PIPELINE]", flush=True)
        report("GAMEPAD EVENT TO CONTROL OUTPUT", self.control_count, self.control_total_ns, self.control_max_ns)
        report("CAMERA CAPTURE", self.camera_count, self.camera_total_ns, self.camera_max_ns)
        report("FACE DETECTION", self.face_count, self.face_total_ns, self.face_max_ns)
        report("CAMERA CAPTURE + FACE DETECTION", self.monitor_path_count, self.monitor_path_total_ns, self.monitor_path_max_ns)
        try:
            if self.cap is not None:
                self.cap.release()
        except Exception:
            pass
    =}
}

reactor BenchmarkDriverControl {
    input steer_msg
    input accel_msg
    input brake_msg
    output steer
    output accelerator
    output brake

    state steer_val = 1
    state accel_val = 0.0
    state brake_val = 0.0
    state input_count = 0
    state input_total_ns = 0
    state input_max_ns = 0
    state output_count = 0
    state output_total_ns = 0
    state output_max_ns = 0

    timer sensorclock(4 sec, 100 msec)

    reaction(steer_msg, accel_msg, brake_msg) {=
        start_ns = lf.time.physical_elapsed()
        if steer_msg.is_present:
            self.steer_val = steer_msg.value
        if accel_msg.is_present:
            self.accel_val = accel_msg.value
        if brake_msg.is_present:
            self.brake_val = brake_msg.value
        elapsed_ns = lf.time.physical_elapsed() - start_ns
        self.input_count += 1
        self.input_total_ns += elapsed_ns
        self.input_max_ns = max(self.input_max_ns, elapsed_ns)
    =}

    reaction(sensorclock) -> steer, accelerator, brake {=
        start_ns = lf.time.physical_elapsed()
        steer.set(self.steer_val)
        accelerator.set(self.accel_val)
        brake.set(self.brake_val)
        elapsed_ns = lf.time.physical_elapsed() - start_ns
        self.output_count += 1
        self.output_total_ns += elapsed_ns
        self.output_max_ns = max(self.output_max_ns, elapsed_ns)
    =}

    reaction(shutdown) {=
        def report(name, count, total_ns, max_ns):
            average_ns = total_ns / count if count else 0
            print(f"[{name}] Samples: {count}", flush=True)
            print(f"Average: {average_ns / 1e6:.6f} ms", flush=True)
            print(f"Observed WCET: {max_ns / 1e6:.6f} ms", flush=True)
        print("[DRIVER CONTROL]", flush=True)
        report("INPUT REACTION", self.input_count, self.input_total_ns, self.input_max_ns)
        report("OUTPUT REACTION", self.output_count, self.output_total_ns, self.output_max_ns)
    =}
}

reactor BenchmarkDriverMonitor {
    input head_msg
    input eye_msg
    output head
    output eye

    state head_val = 1
    state eye_val = 1
    state input_count = 0
    state input_total_ns = 0
    state input_max_ns = 0
    state output_count = 0
    state output_total_ns = 0
    state output_max_ns = 0

    timer sensorclock(4 sec, 100 msec)

    reaction(head_msg, eye_msg) {=
        start_ns = lf.time.physical_elapsed()
        if head_msg.is_present:
            self.head_val = head_msg.value
        if eye_msg.is_present:
            self.eye_val = eye_msg.value
        elapsed_ns = lf.time.physical_elapsed() - start_ns
        self.input_count += 1
        self.input_total_ns += elapsed_ns
        self.input_max_ns = max(self.input_max_ns, elapsed_ns)
    =}

    reaction(sensorclock) -> head, eye {=
        start_ns = lf.time.physical_elapsed()
        head.set(self.head_val)
        eye.set(self.eye_val)
        elapsed_ns = lf.time.physical_elapsed() - start_ns
        self.output_count += 1
        self.output_total_ns += elapsed_ns
        self.output_max_ns = max(self.output_max_ns, elapsed_ns)
    =}

    reaction(shutdown) {=
        def report(name, count, total_ns, max_ns):
            average_ns = total_ns / count if count else 0
            print(f"[{name}] Samples: {count}", flush=True)
            print(f"Average: {average_ns / 1e6:.6f} ms", flush=True)
            print(f"Observed WCET: {max_ns / 1e6:.6f} ms", flush=True)
        print("[DRIVER MONITOR]", flush=True)
        report("INPUT REACTION", self.input_count, self.input_total_ns, self.input_max_ns)
        report("OUTPUT REACTION", self.output_count, self.output_total_ns, self.output_max_ns)
    =}
}

main reactor DriverBenchmark {
    inputs = new BenchmarkSensorInputs()
    control = new BenchmarkDriverControl()
    monitor = new BenchmarkDriverMonitor()

    inputs.steer_msg -> control.steer_msg
    inputs.accel_msg -> control.accel_msg
    inputs.brake_msg -> control.brake_msg
    inputs.head_msg -> monitor.head_msg
    inputs.eye_msg -> monitor.eye_msg

    reaction(startup) {=
        print("[DRIVER BENCHMARK] Measuring real sensor pipeline and driver reaction execution times.", flush=True)
    =}

    reaction(shutdown) {=
        print("[DRIVER BENCHMARK] Finished after 104 seconds.", flush=True)
    =}
}
