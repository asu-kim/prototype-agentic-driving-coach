target Python

import SensorInputs from "SensorInputs.lf"

preamble {=
    import csv
    import os

    _DRIVER_MONITOR_LOG_PATH = os.getenv(
        "DRIVER_MONITOR_LOG_PATH",
        "logs-trace/driver_monitor_inputs.csv",
    )
    _FEDERATE_EXECUTION_LOG_DIR = os.getenv(
        "FEDERATE_EXECUTION_LOG_DIR",
        "logs-trace",
    )
    _FEDERATE_EXECUTION_LOG_PATH = os.getenv(
        "D_MONITOR_EXECUTION_LOG_PATH",
        os.path.join(_FEDERATE_EXECUTION_LOG_DIR, "federate_execution_times_d_monitor.csv"),
    )

    def _open_execution_log():
        log_dir = os.path.dirname(_FEDERATE_EXECUTION_LOG_PATH)
        if log_dir:
            os.makedirs(log_dir, exist_ok=True)
        needs_header = (
            not os.path.exists(_FEDERATE_EXECUTION_LOG_PATH)
            or os.path.getsize(_FEDERATE_EXECUTION_LOG_PATH) == 0
        )
        log_file = open(_FEDERATE_EXECUTION_LOG_PATH, "a", newline="", encoding="utf-8")
        log_writer = csv.writer(log_file)
        if needs_header:
            log_writer.writerow([
                "federate",
                "reactor",
                "reaction",
                "logical_time_ns",
                "logical_time_ms",
                "tag_time_ns",
                "microstep",
                "lag_ms",
                "tardy_invocation_count",
                "start_physical_time_ms",
                "stop_physical_time_ms",
                "execution_time_ms",
            ])
            log_file.flush()
        return log_file, log_writer

    def _log_execution_time(self, federate, reactor, reaction, start_physical_time_ms, stop_physical_time_ms):
        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        if not hasattr(self, "tardy_invocation_count"):
            self.tardy_invocation_count = 0
        if "tardy" in reaction:
            self.tardy_invocation_count += 1
        self.execution_log_writer.writerow([
            federate,
            reactor,
            reaction,
            logical_time_ns,
            logical_time_ns / 1e6,
            (lf.tag().time - lf.time.start()),
            current_tag.microstep,
            start_physical_time_ms - (logical_time_ns / 1e6),
            self.tardy_invocation_count,
            start_physical_time_ms,
            stop_physical_time_ms,
            stop_physical_time_ms - start_physical_time_ms,
        ])
        self.execution_log_file.flush()
=}

reactor DriverMonitor {
    state head_val = 1
    state eye_val = 1

    output head
    output eye

    timer sensorclock(7 sec, 100 msec)

    sensors = new SensorInputs()


    reaction(startup) {=
        self.tardy_invocation_count = 0
        os.makedirs(os.path.dirname(_DRIVER_MONITOR_LOG_PATH), exist_ok=True)
        self.driver_monitor_log_file = open(_DRIVER_MONITOR_LOG_PATH, "w", newline="", encoding="utf-8")
        self.driver_monitor_log_writer = csv.writer(self.driver_monitor_log_file)
        self.driver_monitor_log_writer.writerow([
            "event",
            "logical_time_ns",
            "logical_time_ms",
            "physical_time_ms",
            "tag_time_ns",
            "microstep",
            "lag_ms",
            "tardy_invocation_count",
            "head_present",
            "eye_present",
            "head",
            "eye",
        ])
        self.driver_monitor_log_file.flush()
        self.execution_log_file, self.execution_log_writer = _open_execution_log()
        print(f"[DRIVER MONITOR LOG] Writing inputs to {_DRIVER_MONITOR_LOG_PATH}", flush=True)
        print(f"[EXECUTION LOG] Appending timings to {_FEDERATE_EXECUTION_LOG_PATH}", flush=True)
    =}

    reaction(sensors.head_msg, sensors.eye_msg) {=
        start_physical_time = lf.time.physical_elapsed()/1e6
        if sensors.head_msg.is_present:
            self.head_val = sensors.head_msg.value
        if sensors.eye_msg.is_present:
            self.eye_val = sensors.eye_msg.value

        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        self.driver_monitor_log_writer.writerow([
            "sensor_arrival",
            logical_time_ns,
            logical_time_ns / 1e6,
            lf.time.physical_elapsed() / 1e6,
            (lf.tag().time - lf.time.start()),
            current_tag.microstep,
            (lf.time.physical_elapsed() / 1e6) - (logical_time_ns / 1e6),
            self.tardy_invocation_count,
            int(sensors.head_msg.is_present),
            int(sensors.eye_msg.is_present),
            self.head_val,
            self.eye_val,
        ])
        self.driver_monitor_log_file.flush()
        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "d_monitor", "DriverMonitor", "sensor_arrival", start_physical_time, stop_physical_time)
    =}

    reaction(sensorclock) -> head, eye {=
        start_physical_time = lf.time.physical_elapsed()/1e6
        head.set(self.head_val)
        eye.set(self.eye_val)

        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        self.driver_monitor_log_writer.writerow([
            "output_tick",
            logical_time_ns,
            logical_time_ns / 1e6,
            lf.time.physical_elapsed() / 1e6,
            (lf.tag().time - lf.time.start()),
            current_tag.microstep,
            (lf.time.physical_elapsed() / 1e6) - (logical_time_ns / 1e6),
            self.tardy_invocation_count,
            1,
            1,
            self.head_val,
            self.eye_val,
        ])
        self.driver_monitor_log_file.flush()
        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "d_monitor", "DriverMonitor", "output_tick", start_physical_time, stop_physical_time)
      
    =}

    reaction(shutdown) {=
        if hasattr(self, "driver_monitor_log_file") and not self.driver_monitor_log_file.closed:
            self.driver_monitor_log_file.flush()
            self.driver_monitor_log_file.close()
        if hasattr(self, "execution_log_file") and not self.execution_log_file.closed:
            self.execution_log_file.flush()
            self.execution_log_file.close()
    =}

}
