target Python

import SensorInputs from "SensorInputs.lf"


reactor Driver{

    state steer_val = 1
    state accel_val = 0.0
    state brake_val = 0.0
    state head_val = 1
    state eye_val = 1
    state sensor_ready = False

    output steer
    output accelerator
    output brake
    output head
    output eye

   
    timer sensorclock(4 sec, 100 msec)

    sen = new SensorInputs()
    
    reaction(sen.eye_msg, sen.head_msg, sen.accel_msg, sen.brake_msg, sen.steer_msg) {=

        if sen.head_msg.is_present:
            self.head_val = sen.head_msg.value
        if sen.eye_msg.is_present:
            self.eye_val = sen.eye_msg.value

        if sen.steer_msg.is_present:
            self.steer_val = sen.steer_msg.value

        if sen.accel_msg.is_present:
            self.accel_val = sen.accel_msg.value

        if sen.brake_msg.is_present:
            self.brake_val = sen.brake_msg.value
        
        print(f"[DRIVER STATE] accel={self.accel_val} brake={self.brake_val}", flush=True)
        current_dri = lf.time.logical_elapsed()/1e6
        physical_dri = lf.time.physical_elapsed()/1e6
        lag = physical_dri - current_dri

        print("----------------------------------------------------------")
        print(f"[DRIVER REACTION 1] Logical time: {current_dri:.2f} ", flush=True)
        print(f"[DRIVER REACTION 1] Physical time: {physical_dri:.2f} ", flush=True)
        print(f"[DRIVER REACTION 1] LAG: {lag:.2f} ", flush=True)
        print("----------------------------------------------------------")
    =}
    reaction(sensorclock) -> head, eye, accelerator, brake, steer {=

        steer.set(self.steer_val)
        accelerator.set(self.accel_val)
        brake.set(self.brake_val)
        head.set(self.head_val)
        eye.set(self.eye_val)

        current_dri = lf.time.logical_elapsed()/1e6
        physical_dri = lf.time.physical_elapsed()/1e6
        lag = physical_dri - current_dri

        print("----------------------------------------------------------")
        print(f"[DRIVER] Logical time: {current_dri:.2f} ", flush=True)
        print(f"[DRIVER] Physical time: {physical_dri:.2f} ", flush=True)
        print(f"[DRIVER] LAG: {lag:.2f} ", flush=True)
        print("----------------------------------------------------------")

    =}
}