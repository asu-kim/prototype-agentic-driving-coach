target Python

preamble{=
    import csv
    import json
    import os

    _SIM_ENV_LOG_PATH = os.getenv(
        "SIM_ENVIRONMENT_LOG_PATH",
        "logs-trace/sim_environment_inputs.csv",
    )
    _SIM_ENV_DEBUG = os.getenv("SIM_ENV_DEBUG", "0").lower() in {"1", "true", "yes", "on"}
    _SIM_ENV_FLUSH_EVERY_N = max(1, int(os.getenv("SIM_ENV_FLUSH_EVERY_N", "10")))
    _FEDERATE_EXECUTION_LOG_PATH = os.getenv(
        "FEDERATE_EXECUTION_LOG_PATH",
        "logs-trace/federate_execution_times.csv",
    )

    def _open_execution_log():
        log_dir = os.path.dirname(_FEDERATE_EXECUTION_LOG_PATH)
        if log_dir:
            os.makedirs(log_dir, exist_ok=True)
        needs_header = (
            not os.path.exists(_FEDERATE_EXECUTION_LOG_PATH)
            or os.path.getsize(_FEDERATE_EXECUTION_LOG_PATH) == 0
        )
        log_file = open(_FEDERATE_EXECUTION_LOG_PATH, "a", newline="", encoding="utf-8")
        log_writer = csv.writer(log_file)
        if needs_header:
            log_writer.writerow([
                "federate",
                "reactor",
                "reaction",
                "logical_time_ns",
                "logical_time_ms",
                "tag_time_ns",
                "microstep",
                "start_physical_time_ms",
                "stop_physical_time_ms",
                "execution_time_ms",
            ])
            log_file.flush()
        return log_file, log_writer

    def _log_execution_time(self, federate, reactor, reaction, start_physical_time_ms, stop_physical_time_ms):
        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        self.execution_log_writer.writerow([
            federate,
            reactor,
            reaction,
            logical_time_ns,
            logical_time_ns / 1e6,
            current_tag.time,
            current_tag.microstep,
            start_physical_time_ms,
            stop_physical_time_ms,
            stop_physical_time_ms - start_physical_time_ms,
        ])
        self.execution_log_file.flush()
=}

reactor EnvironmentStates(output_period = 100 msec) {
    input distance_from_start
    input v
    input front_car_visible
    input right_car_visible
    input cross_left_car_visible
    input cross_right_car_visible

    output displacement
    output environment_states
    output phase_preview_info
    timer environment_tick(7 sec, output_period)

    state distance_from_start_m = 0.0
    state velocity_kmh = 0.0
    state front_car_visible_val = 0
    state right_car_visible_val = 0
    state cross_left_car_visible_val = 0
    state cross_right_car_visible_val = 0
    state log_count = 0

    reaction(startup) {=
        os.makedirs(os.path.dirname(_SIM_ENV_LOG_PATH), exist_ok=True)
        self.environment_log_file = open(_SIM_ENV_LOG_PATH, "w", newline="", encoding="utf-8")
        self.environment_log_writer = csv.writer(self.environment_log_file)
        self.environment_log_writer.writerow([
            "logical_time_ns",
            "logical_time_ms",
            "physical_time_ms",
            "tag_time_ns",
            "microstep",
            "distance_from_start_m",
            "velocity_kmh",
            "road_phase",
            "environment_distance",
            "front_car_present",
            "right_car_present",
            "right_car_position",
            "cross_left_car_present",
            "cross_right_car_present",
            "other_car_present",
            "environment_states_json",
            "phase_preview_json",
        ])
        self.environment_log_file.flush()
        self.execution_log_file, self.execution_log_writer = _open_execution_log()
        print(f"[SIM ENVIRONMENT LOG] Writing inputs to {_SIM_ENV_LOG_PATH}", flush=True)
        print(f"[EXECUTION LOG] Appending timings to {_FEDERATE_EXECUTION_LOG_PATH}", flush=True)
    =}

    preamble {=
        def phase_and_distance(self, distance_m):
            if distance_m < 3000.0:
                return "HIGHWAY", max(0.0, 4000.0 - distance_m)
            if distance_m < 4000.0:
                return "LANE_CHANGE", max(0.0, 4000.0 - distance_m)
            if distance_m < 5210.0:
                return "EXIT", max(0.0, 5210.0 - distance_m)
            if distance_m < 5235.0:
                return "STOP_SIGN", max(0.0, 5235.0 - distance_m)
            if distance_m < 5260.0:
                return "YIELD", max(0.0, 5260.0 - distance_m)
            return "MOVE", max(0.0, 5360.0 - distance_m)

        def environment_details(self, road_phase, distance_m):
            front_car_present = int(self.front_car_visible_val)
            right_car_present = int(self.right_car_visible_val)
            right_car_position = "RIGHT_REAR" if right_car_present else "NONE"
            cross_left_car_present = int(self.cross_left_car_visible_val)
            cross_right_car_present = int(self.cross_right_car_visible_val)

            return [
                road_phase,
                front_car_present,
                right_car_present,
                right_car_position,
                cross_left_car_present,
                cross_right_car_present,
            ]

        def phase_preview_details(self, road_phase, distance_to_target_m):
            preview = {
                "current_phase": road_phase,
                "upcoming_phase": "",
                "warning_window": "",
                "distance_to_upcoming_phase_m": None,
            }
            distance_m = float(distance_to_target_m)
            if road_phase == "HIGHWAY" and distance_m <= 1500.0:
                preview["upcoming_phase"] = "LANE_CHANGE"
                preview["warning_window"] = "PREPARE_FOR_EXIT_LANE_CHANGE"
                preview["distance_to_upcoming_phase_m"] = max(0.0, distance_m - 1000.0)
            elif road_phase == "LANE_CHANGE" and distance_m <= 300.0:
                preview["upcoming_phase"] = "EXIT"
                preview["warning_window"] = "PREPARE_FOR_EXIT_RAMP"
                preview["distance_to_upcoming_phase_m"] = max(0.0, distance_m)
            elif road_phase == "EXIT" and distance_m <= 200.0:
                preview["upcoming_phase"] = "STOP_SIGN"
                preview["warning_window"] = "PREPARE_FOR_STOP_SIGN"
                preview["distance_to_upcoming_phase_m"] = max(0.0, distance_m)
            elif road_phase == "STOP_SIGN" and distance_m <= 10.0:
                preview["upcoming_phase"] = "YIELD"
                preview["warning_window"] = "PREPARE_FOR_CROSS_TRAFFIC"
                preview["distance_to_upcoming_phase_m"] = max(0.0, distance_m)
            return preview
    =}

    reaction(distance_from_start, v, front_car_visible, right_car_visible, cross_left_car_visible, cross_right_car_visible) {=
        start_physical_time = lf.time.physical_elapsed()/1e6
        if distance_from_start.is_present:
            self.distance_from_start_m = float(distance_from_start.value)
        if v.is_present:
            self.velocity_kmh = float(v.value)
        if front_car_visible.is_present:
            self.front_car_visible_val = int(front_car_visible.value)
        if right_car_visible.is_present:
            self.right_car_visible_val = int(right_car_visible.value)
        if cross_left_car_visible.is_present:
            self.cross_left_car_visible_val = int(cross_left_car_visible.value)
        if cross_right_car_visible.is_present:
            self.cross_right_car_visible_val = int(cross_right_car_visible.value)
        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "sim", "EnvironmentStates", "input_arrival", start_physical_time, stop_physical_time)
    =}

    reaction(environment_tick) -> displacement, environment_states, phase_preview_info {=
        start_physical_time = lf.time.physical_elapsed()/1e6
        road_phase, environment_distance = self.phase_and_distance(self.distance_from_start_m)
        en_states = self.environment_details(road_phase, self.distance_from_start_m)
        preview = self.phase_preview_details(road_phase, environment_distance)

        other_present = int(bool(en_states[1] or en_states[2] or en_states[4] or en_states[5]))

        displacement.set(environment_distance)
        environment_states.set(en_states)
        phase_preview_info.set(preview)
        print(f"[Environment]: {en_states} preview={preview}")

        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        self.environment_log_writer.writerow([
            logical_time_ns,
            logical_time_ns / 1e6,
            lf.time.physical_elapsed() / 1e6,
            current_tag.time,
            current_tag.microstep,
            self.distance_from_start_m,
            self.velocity_kmh,
            road_phase,
            environment_distance,
            en_states[1],
            en_states[2],
            en_states[3],
            en_states[4],
            en_states[5],
            other_present,
            json.dumps(en_states),
            json.dumps(preview),
        ])
        self.log_count += 1
        if self.log_count % _SIM_ENV_FLUSH_EVERY_N == 0:
            self.environment_log_file.flush()
        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "sim", "EnvironmentStates", "environment_tick", start_physical_time, stop_physical_time)

    =}

    reaction(shutdown) {=
        if hasattr(self, "environment_log_file") and not self.environment_log_file.closed:
            self.environment_log_file.flush()
            self.environment_log_file.close()
        if hasattr(self, "execution_log_file") and not self.execution_log_file.closed:
            self.execution_log_file.flush()
            self.execution_log_file.close()
    =}
}
