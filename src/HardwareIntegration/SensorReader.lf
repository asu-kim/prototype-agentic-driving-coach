/*
* https://python-evdev.readthedocs.io/en/latest/apidoc.html#evdev.events.InputEvent to understand the evdev python library for linux
* e.type   # what kind of event
* e.code   # which control generated it
* e.value  # the current value
*/


target Python 

preamble {=
import threading
import time
from evdev import InputDevice, ecodes, list_devices
import cv2
import sys
_PRINT_CONTROLS = "d_control" in sys.argv[0]
_PRINT_CAMERA = "d_monitor" in sys.argv[0]
import numpy as np
=}

reactor DeviceReader {
  output steer
  output throttle
  output brake
  output frame
  physical action sensor
  timer cam_timer(15 sec, 100 msec)
  state cap
  state cam_ready = False





  reaction(startup) -> sensor{=
      def find_path():
          for p in list_devices():
              try:
                  d = InputDevice(p)
                  if "shanwan" in d.name.lower() and "gamepad" in d.name.lower():
                      return p
              except Exception:
                  pass
          return None
      start_time = time.time()
      path = find_path() if _PRINT_CONTROLS else None
      if _PRINT_CONTROLS and path is None:
          print("wheel device not found", flush=True)
          return

      def clamp(x, lo, hi):
          if x < lo:
              return lo
          elif x > hi:
              return hi
          else:
              return x

      # Normalize to [0, 1]
      def norm(dev, code, val):
          info = dev.absinfo(code)
          mini, maxi = info.min, info.max
          if maxi == mini:
              return 0.0
          return (val - mini) / (maxi - mini)

      def reader(action, path):
          dev = InputDevice(path)
          if _PRINT_CONTROLS: print(f"The {dev.path} is the path and {dev.name} is the name of the device.\n", flush=True)

          xinfo = dev.absinfo(ecodes.ABS_X)
          xmin, xmax = xinfo.min, xinfo.max

          axis_state = {
              "steer": {"last": None, "last_sent": 0.0, "eps": 0.01, "min_dt": 0.01},
              "brake": {"last": None, "last_sent": 0.0, "eps": 0.02, "min_dt": 0.02},
              "throttle": {"last": None, "last_sent": 0.0, "eps": 0.02, "min_dt": 0.02},
          }

          def maybe_send(name, value):

            # now = time.monotonic()

            # st = axis_state[name]

            # if now - st["last_sent"] >= st["min_dt"]:

            # st["last"] = value

            # st["last_sent"] = now

            action.schedule(0, (name, value))

          for e in dev.read_loop():
              if e.type != ecodes.EV_ABS:
                  continue

              if e.code == ecodes.ABS_X:
                  s = (2 * (e.value - xmin) / (xmax - xmin)) - 1.0
                  s = float(clamp(s, -1.0, 1.0))
                  maybe_send("steer", s)

              elif e.code == ecodes.ABS_BRAKE:
                  b = float(clamp(norm(dev, ecodes.ABS_BRAKE, e.value), 0.0, 1.0))
                  if _PRINT_CONTROLS: print(f"The event throttle: {b}")
                  maybe_send("brake", b)

              elif e.code == ecodes.ABS_GAS:
                  tval = float(clamp(norm(dev, ecodes.ABS_GAS, e.value), 0.0, 1.0))
                  if _PRINT_CONTROLS: print(f"The event throttle: {tval}")
                  maybe_send("throttle", tval)

      if _PRINT_CONTROLS:
          t = threading.Thread(
              target=reader,
              args=(sensor, path),
              daemon=True
          )
          t.start()
      end_time = time.time()
      time_diff = end_time - start_time
      if _PRINT_CONTROLS: print(f"Time taken for wheel: {time_diff:.2f}")

      start_time2 = time.time()
      if not _PRINT_CAMERA:
          self.cap = None
          self.cam_ready = False
      else:
          self.cap = cv2.VideoCapture(0, cv2.CAP_V4L2)
          if not self.cap.isOpened():
              print("Camera cannot be opened", flush=True)
              self.cam_ready = False
          else:
              cv2.setNumThreads(1)
              self.cap.set(cv2.CAP_PROP_FRAME_WIDTH, 640)
              self.cap.set(cv2.CAP_PROP_FRAME_HEIGHT, 480)
              self.cap.set(cv2.CAP_PROP_FPS, 10)
              self.cam_ready = True
              print("Webcam opened", flush=True)
              #for startup lag warmup
              self.cap.read()
      
      end_time2 = time.time()
      time_diff2 = end_time2 - start_time2
      
      if _PRINT_CAMERA: print(f"Time taken for cam: {time_diff2:.2f}")

      print("The devices are connected\n")
    =}
