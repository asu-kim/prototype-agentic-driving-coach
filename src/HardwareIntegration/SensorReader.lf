  reaction(cam_timer) -> frame {=
    current_dri = lf.time.logical_elapsed()/1e6
    
    if not getattr(self, "cam_ready", False) or getattr(self, "cap", None) is None:
      return
    try:
      ok, img = self.cap.read()
      physical_dri = lf.time.physical_elapsed()/1e6
      lag = physical_dri - current_dri
      if _PRINT_CAMERA: print(f"[DEVICE READER CAM read] Physical time: {physical_dri:.2f} ", flush=True)
      if _PRINT_CAMERA: print(f"[DEVICE READER CAM read] LAG: {lag:.2f} ", flush=True)
      if ok and img is not None:
        img = np.ascontiguousarray(img)


        frame.set(img)

    except Exception as e:
        
      print("camera error reading the frames", e, flush=True)
    
    physical_dri = lf.time.physical_elapsed()/1e6
    lag = physical_dri - current_dri
    if _PRINT_CAMERA: print("----------------------------------------------------------")
    if _PRINT_CAMERA: print(f"[DEVICE READER CAM TIMER] Logical time: {current_dri:.2f} ", flush=True)
    if _PRINT_CAMERA: print(f"[DEVICE READER CAM TIMER] Physical time: {physical_dri:.2f} ", flush=True)
    if _PRINT_CAMERA: print(f"[DEVICE READER CAM TIMER] LAG: {lag:.2f} ", flush=True)
    if _PRINT_CAMERA: print("----------------------------------------------------------")
  =}

  reaction(sensor) -> steer, brake, throttle{=
  tag, val = sensor.value
  
  if tag == "steer":
    steer.set(val)
  elif tag == "brake":
    brake.set(val)
  elif tag == "throttle":
    throttle.set(val)
  current_dri = lf.time.logical_elapsed()/1e6
  physical_dri = lf.time.physical_elapsed()/1e6
  lag = physical_dri - current_dri
  if _PRINT_CONTROLS: print("----------------------------------------------------------")
  if _PRINT_CONTROLS: print(f"[sterr,brake,accel] Logical time: {current_dri:.2f} ", flush=True)
  if _PRINT_CONTROLS: print(f"[sterr,brake,accel] Physical time: {physical_dri:.2f} ", flush=True)
  if _PRINT_CONTROLS: print(f"[sterr,brake,accel] LAG: {lag:.2f} ", flush=True)
  if _PRINT_CONTROLS: print("----------------------------------------------------------")

=}

  reaction(shutdown) {=
      try:
        if getattr(self, "cap", None) is not None:
          self.cap.release()
      except Exception:
        pass
    =}
}