target Python

import MuJoCoCarAuto from "../../mujoco-py/src/lib/MuJoCoCarAutoHardware.lf"

reactor Simulation {
    preamble {=
        from mujoco.glfw import glfw
    =}
    input steer_in
    input velocity_in
    input rem_dist

    m = new MuJoCoCarAuto()

    reaction(steer_in, velocity_in, rem_dist) -> m.forward, m.turn, m.rd {=
        vel = velocity_in.value if velocity_in.is_present else 0.0
        st  = steer_in.value if steer_in.is_present else 1
        print(f"The value of rd into simulation : {rem_dist.value}")
        rem_dis = rem_dist.value if rem_dist.is_present else 0.0

        forward_cmd = vel    
 
        if st == 2:
            turn_cmd = -0.05
        elif st == 0:
            turn_cmd = 0.05
        else:
            turn_cmd = 0.0

        m.forward.set(forward_cmd)
        m.turn.set(turn_cmd)
        m.rd.set(rem_dis)
    =}

    reaction(m.key) -> m.cam_toggle {=
        if m.key.value.act == glfw.PRESS:
            if m.key.value.key == glfw.KEY_F:
                m.cam_toggle.set(True)
    =}
}