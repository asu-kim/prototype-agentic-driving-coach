target Python {
    files: ["models/car.xml", "models/stopsign.png", "models/exitsign.png", "models/lanechange.png", "models/speed_limit.png"],
    cmake-args: {
        Python_EXECUTABLE: "python3"
    }
}

import MuJoCoCarAuto from "../../mujoco-py/src/lib/MuJoCoCarAutoHardware.lf"
import EnvironmentStates from "EnvironmentFromSimulation.lf"
// import EnvironmentSimulation from "EnvironmentSimulation"

reactor Environment {
    preamble {=
        from mujoco.glfw import glfw
    =}
    input steer_in
    input velocity_in

    output displacement
    output environment_states

    state velocity_kmh = 0.0
    state steer_value = 1
    state distance_from_start_m = 0.0
    state previous_logical_ns = 0
    state has_previous_logical_time = False

    m = new MuJoCoCarAuto()
    env = new EnvironmentStates()

    env.displacement -> displacement
    env.environment_states -> environment_states

    reaction(steer_in, velocity_in) -> m.forward, m.turn, env.distance_from_start, env.v {=
        print("----------------------------------------------------------", flush=True)
        if velocity_in.is_present:
            self.velocity_kmh = float(velocity_in.value)
            print(f"[SIMULATION] Received velocity: {velocity_in.value}", flush=True)
        if steer_in.is_present:
            self.steer_value = steer_in.value
            print(f"[SIMULATION] Received steer: {steer_in.value}", flush=True)
        current_logical_ns = lf.time.logical_elapsed()
        if not self.has_previous_logical_time:
            dt_seconds = 0.0
        else:
            dt_seconds = max(0.0, (current_logical_ns - self.previous_logical_ns) / 1e9)
        self.has_previous_logical_time = True
        self.previous_logical_ns = current_logical_ns
        self.distance_from_start_m += (self.velocity_kmh / 3.6) * dt_seconds

        # MuJoCoCarAutoHardware displays forward * 3.6 as km/h.
        forward_cmd = self.velocity_kmh / 3.6
 
        if self.steer_value == 2:
            turn_cmd = -0.05
        elif self.steer_value == 0:
            turn_cmd = 0.05
        else:
            turn_cmd = 0.0

        m.forward.set(forward_cmd)
        m.turn.set(turn_cmd)
        env.distance_from_start.set(self.distance_from_start_m)
        env.v.set(self.velocity_kmh)
        print(f"[SIMULATION] Distance from start: {self.distance_from_start_m:.2f} m", flush=True)

        current_sim = lf.time.logical_elapsed()/1e6
        physical_sim = lf.time.physical_elapsed()/1e6
        lag = physical_sim - current_sim
        current_tag = lf.tag()

        print(f"[SIMULATION] Logical time: {current_sim:.2f} ms", flush=True)
        print(f"[SIMULATION] Physical time: {physical_sim:.2f} ms", flush=True)
        print(f"[SIMULATION] LAG: {lag:.2f} ms", flush=True)
        print(f"[SIMULATION] Tag time: {current_tag.time} ns", flush=True)
        print(f"[SIMULATION] Microstep: {current_tag.microstep}", flush=True)
        print("----------------------------------------------------------", flush=True)
    =}tardy

    m.front_car_present -> env.front_car_visible after 0 msec
    m.right_car_present -> env.right_car_visible after 0 msec
    m.cross_left_car_present -> env.cross_left_car_visible after 0 msec
    m.cross_right_car_present -> env.cross_right_car_visible after 0 msec

    reaction(m.key) -> m.cam_toggle {=
        if m.key.value.act == glfw.PRESS:
            if m.key.value.key == glfw.KEY_F:
                m.cam_toggle.set(True)
    =}
    // en = new EnvironmentSimullation()
}