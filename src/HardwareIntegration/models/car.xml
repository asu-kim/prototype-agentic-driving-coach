<mujoco>
  <compiler autolimits="true"/>
  
  <!-- Setting to adjust camera/mouse sensitivity to match the car's scale. 
       Prevents the massive camera jump on mouse scroll since the initial track was huge. -->
  <statistic extent="3.0" center="0 0 0"/>

  <asset> 
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/> 
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/> 
    
    <!-- Sign textures (paths relative to this XML file directory) -->
    <texture name="exit_sign_tex" type="2d" file="exitsign.png"/>
    <material name="exit_sign_mat" texture="exit_sign_tex" texrepeat="1 1" texuniform="true" emission="0.35"/>
    <texture name="lane_change_sign_tex" type="2d" file="lanechange.png"/>
    <material name="lane_change_sign_mat" texture="lane_change_sign_tex" texrepeat="1 1" texuniform="true" emission="0.35"/>
    <texture name="speed_limit_sign_tex" type="2d" file="speed_limit.png"/>
    <material name="speed_limit_sign_mat" texture="speed_limit_sign_tex" texrepeat="1 1" texuniform="true" emission="0.35"/>
    <texture name="stop_sign_tex" type="2d" file="stopsign.png"/>
    <material name="stop_sign_mat" texture="stop_sign_tex" texrepeat="1 1" texuniform="true" emission="0.35"/>
  </asset>


  <default>
    <joint damping=".03" />
    <default class="wheel">
      <geom type="cylinder" size=".03 .01" rgba=".5 .5 1 1"/>
    </default>
    <!-- Steer knuckle joint: larger force range so position actuator can hold angle -->
    <default class="steer">
      <joint type="hinge" axis="0 0 1" range="-0.6 0.6" damping="0.1" actuatorfrcrange="-5 5"/>
    </default>
  </default>

  <worldbody>
    <!-- Wide grassy background for the extended 6 km highway segment. -->
    <geom name="grass" type="plane" pos="30 0 -0.01" size="45 20 .01" rgba="0.15 0.4 0.15 1"/>
    
    <!-- Straight 6 km, 3-lane road. Scale: 1 MuJoCo meter = 100 real meters; lane centers are y=0.25, y=0.0, y=-0.25. -->
    <geom name="road_asphalt" type="plane" pos="30 0 0" size="30 0.375 .01" rgba="0.2 0.2 0.2 1"/>
    
