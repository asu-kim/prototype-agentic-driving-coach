        <!-- Outer rim: 12 capsule arc segments (30° each, R=0.018m)
             Midpoint of segment k is at angle (15+30k)°.
             pos = R*(cos θ, sin θ, 0),  zaxis = (-sin θ, cos θ, 0)
             Arc chord half-length = R*sin(15°) ≈ 0.0047 -->
        <geom name="sw_r0"  type="capsule" pos=" 0.01739  0.00466 0" size="0.0018 0.0047" zaxis="-0.259  0.966 0" rgba=".15 .15 .15 1" contype="0" conaffinity="0"/>
