             Symmetric 120° spacing with bottom spoke exactly vertical on screen -->
        <geom name="sw_sp0" type="capsule" pos="-0.00900  0.00000 0" size="0.0020 0.0090" zaxis="-1.000  0.000 0" rgba=".25 .25 .25 1" contype="0" conaffinity="0"/>
        <geom name="sw_sp1" type="capsule" pos=" 0.00450 -0.00779 0" size="0.0020 0.0090" zaxis=" 0.500 -0.866 0" rgba=".25 .25 .25 1" contype="0" conaffinity="0"/>
        <geom name="sw_sp2" type="capsule" pos=" 0.00450  0.00779 0" size="0.0020 0.0090" zaxis=" 0.500  0.866 0" rgba=".25 .25 .25 1" contype="0" conaffinity="0"/>
      </body>
      <!-- Driver first-person camera: looking forward ~20° downward to see steering wheel -->
      <!-- xyaxes: cam_x=(0,-1,0)=car_right, cam_y=(0.342,0,0.940)=up-tilted-fwd → looks in +X and -Z -->
      <camera name="driver_cam" pos="0.005 0 0.092" xyaxes="0 -1 0 0.342 0 0.940" fovy="75"/>
      <!-- Front-left: outer body = steer (yaw), inner body = roll (spin) -->
