<mujoco>
  <compiler autolimits="true"/>
  
  <!-- Setting to adjust camera/mouse sensitivity to match the car's scale. 
       Prevents the massive camera jump on mouse scroll since the initial track was huge. -->
  <statistic extent="3.0" center="0 0 0"/>

  <asset>
    <texture name="grid" type="2d" builtin="checker" width="512" height="512" rgb1=".1 .2 .3" rgb2=".2 .3 .4"/>
    <material name="grid" texture="grid" texrepeat="1 1" texuniform="true" reflectance=".2"/>
    <!-- Speed limit sign texture (path relative to this XML file's directory) -->
    <!-- <texture name="speed_limit_tex" type="2d" file="speed_limit.png"/> -->
    <texture name="speed_limit_tex" type="2d" file="stopsign.png"/>
    <material name="speed_limit_mat" texture="speed_limit_tex" texrepeat="1 1" texuniform="false"/>
  </asset>

  <default>
    <joint damping=".03" />
    <default class="wheel">
      <geom type="cylinder" size=".03 .01" rgba=".5 .5 1 1"/>
    </default>
    <default class="decor">
      <site type="box" rgba=".5 1 .5 1"/>
    </default>
    <!-- Steer knuckle joint: larger force range so position actuator can hold angle -->
    <default class="steer">
      <joint type="hinge" axis="0 0 1" range="-0.6 0.6" damping="0.1" actuatorfrcrange="-5 5"/>
    </default>
  </default>

  <worldbody>
    <!-- Wide grassy background -->
    <geom name="grass" type="plane" pos="15 0 -0.01" size="30 20 .01" rgba="0.15 0.4 0.15 1"/>
    
    <!-- 3-lane asphalt road (based on 15cm car width, 25cm lane width. Total width 75cm -> half-width 0.375) -->
    <geom name="road_asphalt" type="plane" pos="15 0 0" size="20 0.375 .01" rgba="0.2 0.2 0.2 1"/>
    
