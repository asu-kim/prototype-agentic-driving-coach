      <geom type="cylinder" pos="-0.080 -0.064 0.000" size="0.023 0.010" zaxis="0 1 0" rgba="0.02 0.02 0.025 1" contype="0" conaffinity="0"/>
    </body>

    <!-- One car on the right side of the cross road -->
    <body name="cross_car_right" pos="43.5 -12.12 0.023" euler="0 0 180">
      <!-- Full detailed model, colored yellow -->
      <geom type="box" pos="0 0 0.015" size="0.145 0.060 0.028" rgba="0.8 0.8 0.2 1"/>
      <geom type="box" pos="0.105 0 0.033" size="0.045 0.052 0.018" rgba="0.9 0.9 0.2 1" contype="0" conaffinity="0"/>
      <geom type="box" pos="-0.015 0 0.060" size="0.060 0.047 0.028" rgba="0.5 0.5 0.1 1" contype="0" conaffinity="0"/>
      <geom type="box" pos="0.030 0 0.082" size="0.020 0.040 0.003" rgba="0.08 0.11 0.14 1" contype="0" conaffinity="0"/>
      <geom type="box" pos="-0.055 0 0.082" size="0.018 0.038 0.003" rgba="0.08 0.11 0.14 1" contype="0" conaffinity="0"/>
      <geom type="box" pos="0.152 0.034 0.031" size="0.006 0.010 0.006" rgba="1.0 0.90 0.45 1" contype="0" conaffinity="0"/>
      <geom type="box" pos="0.152 -0.034 0.031" size="0.006 0.010 0.006" rgba="1.0 0.90 0.45 1" contype="0" conaffinity="0"/>
      <geom type="cylinder" pos="0.075 0.064 0.000" size="0.023 0.010" zaxis="0 1 0" rgba="0.02 0.02 0.025 1" contype="0" conaffinity="0"/>
      <geom type="cylinder" pos="0.075 -0.064 0.000" size="0.023 0.010" zaxis="0 1 0" rgba="0.02 0.02 0.025 1" contype="0" conaffinity="0"/>
      <geom type="cylinder" pos="-0.080 0.064 0.000" size="0.023 0.010" zaxis="0 1 0" rgba="0.02 0.02 0.025 1" contype="0" conaffinity="0"/>
      <geom type="cylinder" pos="-0.080 -0.064 0.000" size="0.023 0.010" zaxis="0 1 0" rgba="0.02 0.02 0.025 1" contype="0" conaffinity="0"/>
    </body>

    <body name="car" pos="0 0 .03">
      <freejoint name="ego_free"/>
      <light name="top light" pos="0 0 2" mode="trackcom" diffuse=".4 .4 .4"/>
      <!-- Box chassis: main body slab (taller floor) -->
      <geom name="chassis_body" type="box" pos="0.005 0 0.012" size="0.077 0.040 0.020" rgba=".45 .45 .5 1"/>
      <!-- Rear cabin block kept behind the driver camera so first-person view is not occluded while steering. -->
      <geom name="chassis_cabin" type="box" pos="-0.035 0 0.065" size="0.024 0.033 0.030" rgba=".38 .38 .43 1"/>
      <!-- Front axle strut (non-collideable visual) -->
      <geom name="axle_front" type="box" pos="0.08 0 0" size="0.010 0.058 0.007" rgba=".3 .3 .35 1" contype="0" conaffinity="0"/>
      <!-- Rear axle strut (non-collideable visual) -->
      <geom name="axle_rear" type="box" pos="-0.07 0 0" size="0.010 0.058 0.007" rgba=".3 .3 .35 1" contype="0" conaffinity="0"/>
      <!-- Steering column (fixed to chassis, does not rotate) -->
      <geom name="steering_column" type="cylinder" pos="0.046 0 0.040"
            size="0.003 0.016" zaxis="-0.70 0 0.70"
            rgba=".18 .18 .18 1" contype="0" conaffinity="0"/>
      <!-- Steering wheel body: rotates around column axis when turning.
           zaxis="-0.707 0 0.707" → body local-Z aligns with the column direction.
           All child geoms are in the local XY-plane (a circle of radius 0.018). -->
      <body name="steer_wheel_body" pos="0.028 0 0.058" zaxis="-0.707 0 0.707">
        <inertial pos="0 0 0" mass="0.005" diaginertia="1e-6 1e-6 1e-6"/>
        <!-- Joint: hinge around local Z = steering-column axis; driven by equality constraint -->
        <joint name="steer_visual" type="hinge" axis="0 0 1" damping="0.01"/>
        <!-- Hub -->
        <geom name="sw_hub" type="sphere" pos="0 0 0"
              size="0.006" rgba=".25 .25 .25 1" contype="0" conaffinity="0"/>
        <!-- Outer rim: 12 capsule arc segments (30° each, R=0.018m)
             Midpoint of segment k is at angle (15+30k)°.
             pos = R*(cos θ, sin θ, 0),  zaxis = (-sin θ, cos θ, 0)
             Arc chord half-length = R*sin(15°) ≈ 0.0047 -->
        <geom name="sw_r0"  type="capsule" pos=" 0.01739  0.00466 0" size="0.0018 0.0047" zaxis="-0.259  0.966 0" rgba=".15 .15 .15 1" contype="0" conaffinity="0"/>
        <geom name="sw_r1"  type="capsule" pos=" 0.01273  0.01273 0" size="0.0018 0.0047" zaxis="-0.707  0.707 0" rgba=".15 .15 .15 1" contype="0" conaffinity="0"/>
        <geom name="sw_r2"  type="capsule" pos=" 0.00466  0.01739 0" size="0.0018 0.0047" zaxis="-0.966  0.259 0" rgba=".15 .15 .15 1" contype="0" conaffinity="0"/>
        <geom name="sw_r3"  type="capsule" pos="-0.00466  0.01739 0" size="0.0018 0.0047" zaxis="-0.966 -0.259 0" rgba=".15 .15 .15 1" contype="0" conaffinity="0"/>
        <geom name="sw_r4"  type="capsule" pos="-0.01273  0.01273 0" size="0.0018 0.0047" zaxis="-0.707 -0.707 0" rgba=".15 .15 .15 1" contype="0" conaffinity="0"/>
        <geom name="sw_r5"  type="capsule" pos="-0.01739  0.00466 0" size="0.0018 0.0047" zaxis="-0.259 -0.966 0" rgba=".15 .15 .15 1" contype="0" conaffinity="0"/>
        <geom name="sw_r6"  type="capsule" pos="-0.01739 -0.00466 0" size="0.0018 0.0047" zaxis=" 0.259 -0.966 0" rgba=".15 .15 .15 1" contype="0" conaffinity="0"/>
        <geom name="sw_r7"  type="capsule" pos="-0.01273 -0.01273 0" size="0.0018 0.0047" zaxis=" 0.707 -0.707 0" rgba=".15 .15 .15 1" contype="0" conaffinity="0"/>
        <geom name="sw_r8"  type="capsule" pos="-0.00466 -0.01739 0" size="0.0018 0.0047" zaxis=" 0.966 -0.259 0" rgba=".15 .15 .15 1" contype="0" conaffinity="0"/>
        <geom name="sw_r9"  type="capsule" pos=" 0.00466 -0.01739 0" size="0.0018 0.0047" zaxis=" 0.966  0.259 0" rgba=".15 .15 .15 1" contype="0" conaffinity="0"/>
        <geom name="sw_r10" type="capsule" pos=" 0.01273 -0.01273 0" size="0.0018 0.0047" zaxis=" 0.707  0.707 0" rgba=".15 .15 .15 1" contype="0" conaffinity="0"/>
        <geom name="sw_r11" type="capsule" pos=" 0.01739 -0.00466 0" size="0.0018 0.0047" zaxis=" 0.259  0.966 0" rgba=".15 .15 .15 1" contype="0" conaffinity="0"/>
        <!-- 3 spokes: screen-vertical bottom (local -X = 180°), upper-right (60°), upper-left (300°)
             In camera view: local +X → screen up, local +Y → screen left
             Symmetric 120° spacing with bottom spoke exactly vertical on screen -->
        <geom name="sw_sp0" type="capsule" pos="-0.00900  0.00000 0" size="0.0020 0.0090" zaxis="-1.000  0.000 0" rgba=".25 .25 .25 1" contype="0" conaffinity="0"/>
        <geom name="sw_sp1" type="capsule" pos=" 0.00450 -0.00779 0" size="0.0020 0.0090" zaxis=" 0.500 -0.866 0" rgba=".25 .25 .25 1" contype="0" conaffinity="0"/>
        <geom name="sw_sp2" type="capsule" pos=" 0.00450  0.00779 0" size="0.0020 0.0090" zaxis=" 0.500  0.866 0" rgba=".25 .25 .25 1" contype="0" conaffinity="0"/>
      </body>
      <!-- Driver camera just above the cockpit, tilted slightly down to see the road ahead. -->
      <camera name="driver_cam" pos="0.005 0 0.105" xyaxes="0 -1 0 0.174 0 0.985" fovy="75"/>

      <!-- Front-left: outer body = steer (yaw), inner body = roll (spin) -->
      <body name="front_left_steer" pos=".08 .06 0">
        <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
        <joint name="steer_left" class="steer"/>
        <body name="front_left_wheel" zaxis="0 1 0">
          <joint name="roll_front_left" type="hinge" axis="0 0 1" damping="0.002"/>
          <geom class="wheel" priority="1"/>
        </body>
      </body>
      <!-- Front-right: outer body = steer (yaw), inner body = roll (spin) -->
      <body name="front_right_steer" pos=".08 -.06 0">
        <inertial pos="0 0 0" mass="0.001" diaginertia="1e-6 1e-6 1e-6"/>
        <joint name="steer_right" class="steer"/>
        <body name="front_right_wheel" zaxis="0 1 0">
          <joint name="roll_front_right" type="hinge" axis="0 0 1" damping="0.002"/>
          <geom class="wheel" priority="1"/>
        </body>
      </body>
      <light name="front light" pos=".1 0 .02" dir="2 0 -1" diffuse="1 1 1"/>
      <body name="left wheel" pos="-.07 .06 0" zaxis="0 1 0">
        <joint name="left"/>
        <geom class="wheel"/>
      </body>
      <body name="right wheel" pos="-.07 -.06 0" zaxis="0 1 0">
        <joint name="right"/>
        <geom class="wheel"/>
      </body>
    </body>
  </worldbody>

  <equality>
    <!-- Make the steering wheel visually rotate 4x the angle of the front wheels -->
    <joint joint1="steer_visual" joint2="steer_left" polycoef="0 4 0 0 0"/>
  </equality>

  <tendon>
    <!-- Rear wheel drive: both rear wheels spin together -->
    <fixed name="forward">
      <joint joint="left" coef=".5"/>
      <joint joint="right" coef=".5"/>
    </fixed>
    <!-- Front steering: turn knuckle controls both front wheels -->
    <fixed name="turn">
      <joint joint="steer_left" coef=".5"/>
      <joint joint="steer_right" coef=".5"/>
    </fixed>
  </tendon>

  <actuator>
    <motor name="forward" tendon="forward" ctrlrange="-1 1"/>
    <!-- position actuator: ctrl sets target angle (rad) for front wheel steering -->
    <position name="turn" tendon="turn" kp="10" ctrlrange="-0.5 0.5"/>
  </actuator>

  <sensor>
    <jointactuatorfrc name="right" joint="right"/>
    <jointactuatorfrc name="left" joint="left"/>
  </sensor>
</mujoco>
