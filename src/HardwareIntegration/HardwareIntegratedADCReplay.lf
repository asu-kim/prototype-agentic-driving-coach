target Python {keepalive: true, 
    coordination: decentralized,
    DNET: false,
    tracing:true
}

import DriverControl from "DriverReplayInput.lf"
import DriverMonitor from "DriverReplayInput.lf"
import Car from "CarReplay.lf"
import InputForCoach from "InputForCoachReplay.lf"
import AgenticCoach from "AgenticCoachReplay.lf"
import ActionPlanner from "ActionPlannerReplay.lf"
import Environment from "EnvironmentReplay.lf"

federated reactor at 10.218.100.78 {
    // Select a replay situation with REPLAY_TRACE_DIR or REPLAY_TRACE_NAME.
    // REPLAY_TRACE_NAME is resolved under src/HardwareIntegration/evaluation.
    d_control = new DriverControl()
    d_monitor = new DriverMonitor()
    @maxwait(10 msec)
    c = new Car()
    @maxwait(111 msec)
    adc = new InputForCoach()
    @maxwait(111 msec)
    llm = new AgenticCoach() 
    @maxwait(170 msec)
    planner = new ActionPlanner() 
    @maxwait(14 msec)
    sim = new Environment() 


    d_control.steer -> c.steer_in
    d_control.accelerator -> c.accel_in
    d_control.brake -> c.brake_in

    d_monitor.head -> adc.h
    d_monitor.eye -> adc.e

    c.velocity -> adc.v
    c.steer -> adc.st

    c.velocity -> sim.velocity_in
    c.steer -> sim.steer_in

    sim.displacement -> adc.s 
    sim.environment_states -> adc.en_states 
    adc.displacement -> llm.s
    adc.velocity -> llm.v
    adc.steer -> llm.st
    adc.head_pos -> llm.h
    adc.eye_pos -> llm.e
    adc.environment_states -> llm.en_states
    adc.velocity -> planner.v
    adc.displacement -> planner.s
    adc.environment_states -> planner.en_states

    llm.control -> planner.ctrl
    llm.instruction -> planner.instr

    planner.act -> c.actuate_in after 200 ms
}