target Python {keepalive: true, 
    // logging: DEBUG,
    coordination: decentralized,
    DNET: false,
    tracing:true
    }
import DriverControl from "DriverControl.lf"
import DriverMonitor from "DriverMonitor.lf"
import Car from "Car.lf"
// import Environment from "Environment.lf" // Old CSV-driven environment
import InputForCoach from "InputForCoach.lf"
import AgenticCoach from "AgenticCoach.lf"
import ActionPlanner from "ActionPlanner.lf"
import Environment from "Simulation.lf"

federated reactor at 100.116.19.18 {
    d_control = new DriverControl()
    d_monitor = new DriverMonitor()
    @maxwait(20 msec)
    c = new Car()
    // en_csv = new Environment()  // Old CSV-driven environment replay
    @maxwait(120 msec)
    adc = new InputForCoach()
    llm = new AgenticCoach() 
    @maxwait(400 msec)
    planner = new ActionPlanner() 
    @maxwait(20 msec)
    sim = new Environment() 
    d_control.steer -> c.steer_in
    d_control.accelerator -> c.accel_in
    d_control.brake -> c.brake_in
   
    d_monitor.head -> adc.h
    d_monitor.eye -> adc.e
  

    c.velocity -> adc.v
    c.steer -> adc.st

     
    c.velocity -> sim.velocity_in
    c.steer -> sim.steer_in

    sim.displacement -> adc.s 
    sim.environment_states -> adc.en_states 
    adc.displacement -> llm.s
    adc.velocity -> llm.v
    adc.steer -> llm.st
    adc.head_pos -> llm.h
    adc.eye_pos ->llm.e
    adc.environment_states -> llm.en_states
    adc.velocity -> planner.v
    adc.displacement -> planner.s
    adc.environment_states -> planner.en_states
    // adc.coach_input -> llm.coach_inp


    llm.control -> planner.ctrl
    llm.instruction -> planner.instr
   
   
    planner.act -> c.actuate_in after 200 ms
    // planner.lane_act -> c.lane_actuate_in after 200 ms

    

}