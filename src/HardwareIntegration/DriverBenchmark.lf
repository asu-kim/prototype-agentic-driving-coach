target Python {
    timeout: 104 sec
}

import SensorInputs from "SensorInputs.lf"

reactor BenchmarkDriverControl {
    input steer_msg
    input accel_msg
    input brake_msg

    state steer_val = 1
    state accel_val = 0.0
    state brake_val = 0.0

    state input_count = 0
    state input_total_ns = 0
    state input_max_ns = 0
    state output_count = 0
    state output_total_ns = 0
    state output_max_ns = 0

    output steer
    output accelerator
    output brake

    timer sensorclock(4 sec, 100 msec)
    reaction(steer_msg, accel_msg, brake_msg) {=
        start_ns = lf.time.physical_elapsed()

        if steer_msg.is_present:
            self.steer_val = steer_msg.value
        if accel_msg.is_present:
            self.accel_val = accel_msg.value
        if brake_msg.is_present:
            self.brake_val = brake_msg.value

        execution_ns = lf.time.physical_elapsed() - start_ns
        self.input_count += 1
        self.input_total_ns += execution_ns
        self.input_max_ns = max(self.input_max_ns, execution_ns)
    =}

    reaction(sensorclock) -> steer, accelerator, brake {=
        start_ns = lf.time.physical_elapsed()

        steer.set(self.steer_val)
        accelerator.set(self.accel_val)
        brake.set(self.brake_val)

        execution_ns = lf.time.physical_elapsed() - start_ns
        self.output_count += 1
        self.output_total_ns += execution_ns
        self.output_max_ns = max(self.output_max_ns, execution_ns)
    =}

    reaction(shutdown) {=
        input_average_ns = self.input_total_ns / self.input_count if self.input_count else 0
        output_average_ns = self.output_total_ns / self.output_count if self.output_count else 0
        print("[DRIVER CONTROL: STEER, ACCELERATOR, BRAKE]", flush=True)
        print(f"Input reaction samples: {self.input_count}", flush=True)
        print(f"Input reaction average execution time: {input_average_ns / 1e6:.6f} ms", flush=True)
        print(f"Input reaction observed WCET: {self.input_max_ns / 1e6:.6f} ms", flush=True)
        print(f"Output reaction samples: {self.output_count}", flush=True)
        print(f"Output reaction average execution time: {output_average_ns / 1e6:.6f} ms", flush=True)
        print(f"Output reaction observed WCET: {self.output_max_ns / 1e6:.6f} ms", flush=True)
    =}
}

reactor BenchmarkDriverMonitor {
    input head_msg
    input eye_msg

    state head_val = 1
    state eye_val = 1

    state input_count = 0
    state input_total_ns = 0
    state input_max_ns = 0
    state output_count = 0
    state output_total_ns = 0
    state output_max_ns = 0

    output head
    output eye

    timer sensorclock(4 sec, 100 msec)
    reaction(head_msg, eye_msg) {=
        start_ns = lf.time.physical_elapsed()

        if head_msg.is_present:
            self.head_val = head_msg.value
        if eye_msg.is_present:
            self.eye_val = eye_msg.value

        execution_ns = lf.time.physical_elapsed() - start_ns
        self.input_count += 1
        self.input_total_ns += execution_ns
        self.input_max_ns = max(self.input_max_ns, execution_ns)
    =}

    reaction(sensorclock) -> head, eye {=
        start_ns = lf.time.physical_elapsed()

        head.set(self.head_val)
        eye.set(self.eye_val)

        execution_ns = lf.time.physical_elapsed() - start_ns
        self.output_count += 1
        self.output_total_ns += execution_ns
        self.output_max_ns = max(self.output_max_ns, execution_ns)
    =}

    reaction(shutdown) {=
        input_average_ns = self.input_total_ns / self.input_count if self.input_count else 0
        output_average_ns = self.output_total_ns / self.output_count if self.output_count else 0
        print("[DRIVER MONITOR: HEAD, EYE]", flush=True)
        print(f"Input reaction samples: {self.input_count}", flush=True)
        print(f"Input reaction average execution time: {input_average_ns / 1e6:.6f} ms", flush=True)
        print(f"Input reaction observed WCET: {self.input_max_ns / 1e6:.6f} ms", flush=True)
        print(f"Output reaction samples: {self.output_count}", flush=True)
        print(f"Output reaction average execution time: {output_average_ns / 1e6:.6f} ms", flush=True)
        print(f"Output reaction observed WCET: {self.output_max_ns / 1e6:.6f} ms", flush=True)
    =}
}

main reactor DriverBenchmark {
    inputs = new SensorInputs()
    control = new BenchmarkDriverControl()
    monitor = new BenchmarkDriverMonitor()

    inputs.steer_msg -> control.steer_msg
    inputs.accel_msg -> control.accel_msg
    inputs.brake_msg -> control.brake_msg
    inputs.head_msg -> monitor.head_msg
    inputs.eye_msg -> monitor.eye_msg

    reaction(startup) {=
        print("[DRIVER BENCHMARK] Started: measuring physical execution time inside each reaction using real sensor inputs.", flush=True)
    =}

    reaction(shutdown) {=
        print("[DRIVER BENCHMARK] Finished: the 104-second benchmark timeout was reached.", flush=True)
    =}
}
