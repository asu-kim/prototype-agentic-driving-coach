target Python {
    timeout: 60 sec
}

import AgenticCoach from "AgenticCoach.lf"

reactor CoachBenchmarkInputs {
    timer sample(4 sec, 500 msec)

    output s
    output v
    output st
    output h
    output e
    output en_states

    reaction(sample) -> s, v, st, h, e, en_states {=
        s.set(1600.0)
        v.set(88.0)
        st.set(1)
        h.set(["CENTER", "CENTER", "RIGHT", "CENTER"])
        e.set(["CENTER", "CENTER", "RIGHT", "CENTER"])
        en_states.set([
            "LANE_CHANGE",
            False,
            100.0,
            88.0,
            False,
            "NONE",
            100.0,
            88.0,
            False,
            False
        ])
    =}
}

main reactor AgenticCoachBenchmark {
    inputs = new CoachBenchmarkInputs()
    coach = new AgenticCoach()

    state sample_count = 0
    state total_output_latency_ns = 0
    state max_output_latency_ns = 0

    inputs.s -> coach.s
    inputs.v -> coach.v
    inputs.st -> coach.st
    inputs.h -> coach.h
    inputs.e -> coach.e
    inputs.en_states -> coach.en_states

    reaction(startup) {=
        print(
            "[AGENTIC COACH BENCHMARK] Started: approximately 1000 LLM samples "
            "at a 10-second period.",
            flush=True
        )
    =}

    reaction(coach.control, coach.instruction) {=
        output_latency_ns = (
            lf.time.physical_elapsed() - lf.time.logical_elapsed()
        )
        self.sample_count += 1
        self.total_output_latency_ns += output_latency_ns
        self.max_output_latency_ns = max(
            self.max_output_latency_ns,
            output_latency_ns
        )
    =}

    reaction(shutdown) {=
        average_output_latency_ns = (
            self.total_output_latency_ns / self.sample_count
            if self.sample_count
            else 0
        )
        print("----------------------------------------------------------", flush=True)
        print("[AGENTIC COACH BENCHMARK SUMMARY]", flush=True)
        print(f"Samples: {self.sample_count}", flush=True)
        print(
            f"Average observable output latency: "
            f"{average_output_latency_ns / 1e6:.6f} ms",
            flush=True
        )
        print(
            f"Maximum observable output latency: "
            f"{self.max_output_latency_ns / 1e6:.6f} ms",
            flush=True
        )
        print(
            "[AGENTIC COACH BENCHMARK] Finished.",
            flush=True
        )
        print("----------------------------------------------------------", flush=True)
    =}
}
