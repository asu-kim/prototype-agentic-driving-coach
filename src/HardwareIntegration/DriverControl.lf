target Python

import SensorInputs from "SensorInputs.lf"

preamble {=
    import csv
    import os
    import sys

    _DRIVER_CONTROL_LOG_PATH = os.getenv(
        "DRIVER_CONTROL_LOG_PATH",
        "logs-trace/driver_control_inputs.csv",
    )
    _FEDERATE_EXECUTION_LOG_PATH = os.getenv(
        "FEDERATE_EXECUTION_LOG_PATH",
        "logs-trace/federate_execution_times.csv",
    )

    def _open_execution_log():
        log_dir = os.path.dirname(_FEDERATE_EXECUTION_LOG_PATH)
        if log_dir:
            os.makedirs(log_dir, exist_ok=True)
        needs_header = (
            not os.path.exists(_FEDERATE_EXECUTION_LOG_PATH)
            or os.path.getsize(_FEDERATE_EXECUTION_LOG_PATH) == 0
        )
        log_file = open(_FEDERATE_EXECUTION_LOG_PATH, "a", newline="", encoding="utf-8")
        log_writer = csv.writer(log_file)
        if needs_header:
            log_writer.writerow([
                "federate",
                "reactor",
                "reaction",
                "logical_time_ns",
                "logical_time_ms",
                "tag_time_ns",
                "microstep",
                "lag_ms",
                "start_physical_time_ms",
                "stop_physical_time_ms",
                "execution_time_ms",
            ])
            log_file.flush()
        return log_file, log_writer

    def _log_execution_time(self, federate, reactor, reaction, start_physical_time_ms, stop_physical_time_ms):
        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        self.execution_log_writer.writerow([
            federate,
            reactor,
            reaction,
            logical_time_ns,
            logical_time_ns / 1e6,
            (lf.tag().time - lf.time.start()),
            current_tag.microstep,
            start_physical_time_ms - (logical_time_ns / 1e6),
            start_physical_time_ms,
            stop_physical_time_ms,
            stop_physical_time_ms - start_physical_time_ms,
        ])
        self.execution_log_file.flush()
   
=}

reactor DriverControl {
    state steer_val = 1
    state accel_val = 0.0
    state brake_val = 0.0

    output steer
    output accelerator
    output brake

    timer sensorclock(7 sec, 100 msec)

    sensors = new SensorInputs()


    reaction(startup) {=
        os.makedirs(os.path.dirname(_DRIVER_CONTROL_LOG_PATH), exist_ok=True)
        self.driver_control_log_file = open(_DRIVER_CONTROL_LOG_PATH, "w", newline="", encoding="utf-8")
        self.driver_control_log_writer = csv.writer(self.driver_control_log_file)
        self.driver_control_log_writer.writerow([
            "event",
            "logical_time_ns",
            "logical_time_ms",
            "physical_time_ms",
            "tag_time_ns",
            "microstep",
            "steer_present",
            "accelerator_present",
            "brake_present",
            "steer",
            "accelerator",
            "brake",
        ])
        self.driver_control_log_file.flush()
        self.execution_log_file, self.execution_log_writer = _open_execution_log()
        print(f"[DRIVER CONTROL LOG] Writing inputs to {_DRIVER_CONTROL_LOG_PATH}", flush=True)
        print(f"[EXECUTION LOG] Appending timings to {_FEDERATE_EXECUTION_LOG_PATH}", flush=True)
    =}

    reaction(sensors.steer_msg, sensors.accel_msg, sensors.brake_msg) {=
        start_physical_time = lf.time.physical_elapsed()/1e6
        if sensors.steer_msg.is_present:
            self.steer_val = sensors.steer_msg.value
        if sensors.accel_msg.is_present:
            self.accel_val = sensors.accel_msg.value
        if sensors.brake_msg.is_present:
            self.brake_val = sensors.brake_msg.value

        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        self.driver_control_log_writer.writerow([
            "sensor_arrival",
            logical_time_ns,
            logical_time_ns / 1e6,
            lf.time.physical_elapsed() / 1e6,
            (lf.tag().time - lf.time.start()),
            current_tag.microstep,
            int(sensors.steer_msg.is_present),
            int(sensors.accel_msg.is_present),
            int(sensors.brake_msg.is_present),
            self.steer_val,
            self.accel_val,
            self.brake_val,
        ])
        self.driver_control_log_file.flush()
        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "d_control", "DriverControl", "sensor_arrival", start_physical_time, stop_physical_time)
    =}

    reaction(sensorclock) -> steer, accelerator, brake {=
        start_physical_time = lf.time.physical_elapsed()/1e6
        steer.set(self.steer_val)
        accelerator.set(self.accel_val)
        brake.set(self.brake_val)

        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        self.driver_control_log_writer.writerow([
            "output_tick",
            logical_time_ns,
            logical_time_ns / 1e6,
            lf.time.physical_elapsed() / 1e6,
            (lf.tag().time - lf.time.start()),
            current_tag.microstep,
            1,
            1,
            1,
            self.steer_val,
            self.accel_val,
            self.brake_val,
        ])
        self.driver_control_log_file.flush()
        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "d_control", "DriverControl", "output_tick", start_physical_time, stop_physical_time)
    
    =}

    reaction(shutdown) {=
        if hasattr(self, "driver_control_log_file") and not self.driver_control_log_file.closed:
            self.driver_control_log_file.flush()
            self.driver_control_log_file.close()
        if hasattr(self, "execution_log_file") and not self.execution_log_file.closed:
            self.execution_log_file.flush()
            self.execution_log_file.close()
    =}

}
