target Python

preamble {=
    import csv
    import os

    _DRIVER_REPLAY_LOG_DIR = os.getenv(
        "DRIVER_REPLAY_LOG_DIR",
        "/home/asurite.ad.asu.edu/dprahlad/deterministic-prototyping-agenticCPS/src/HardwareIntegration/llm-inference-code-log/logs-trace",
    )
=}

reactor Driver{

    state steer_val = 1
    state accel_val = 0.0
    state brake_val = 0.0
    state head_val = 1
    state eye_val = 1
    state sensor_ready = False
    state replay_idx = 0

    output steer
    output accelerator
    output brake
    output head
    output eye

    timer sensorclock(4 sec, 100 msec)

    preamble {=
        def _to_int(self, value, default):
            try:
                if value is None or value == "":
                    return default
                return int(float(value))
            except Exception:
                return default

        def _to_float(self, value, default):
            try:
                if value is None or value == "":
                    return default
                return float(value)
            except Exception:
                return default

        def _load_replay_samples(self):
            car_path = os.path.join(_DRIVER_REPLAY_LOG_DIR, "car_inputs.csv")
            llm_path = os.path.join(_DRIVER_REPLAY_LOG_DIR, "llm_inputs.csv")
            head_eye_by_time = {}

            if os.path.exists(llm_path):
                with open(llm_path, "r", newline="", encoding="utf-8") as f:
                    for row in csv.DictReader(f):
                        if row.get("event") != "input_arrival":
                            continue
                        logical_ns = row.get("logical_time_ns")
                        if not logical_ns:
                            continue
                        head_eye_by_time[logical_ns] = {
                            "head": self._to_int(row.get("head"), self.head_val),
                            "eye": self._to_int(row.get("eye"), self.eye_val),
                        }

            samples = []
            if os.path.exists(car_path):
                with open(car_path, "r", newline="", encoding="utf-8") as f:
                    for row in csv.DictReader(f):
                        logical_ns = row.get("logical_time_ns")
                        head_eye = head_eye_by_time.get(logical_ns, {})
                        samples.append({
                            "logical_time_ns": self._to_int(logical_ns, 0),
                            "steer": self._to_int(row.get("steer_in"), self.steer_val),
                            "accel": self._to_float(row.get("accel_in"), self.accel_val),
                            "brake": self._to_float(row.get("brake_in"), self.brake_val),
                            "head": head_eye.get("head", self.head_val),
                            "eye": head_eye.get("eye", self.eye_val),
                        })

            samples.sort(key=lambda sample: sample["logical_time_ns"])
            return samples
    =}

    reaction(startup) {=
        self.replay_samples = self._load_replay_samples()
        self.sensor_ready = len(self.replay_samples) > 0
        print(
            f"[DRIVER REPLAY] Loaded {len(self.replay_samples)} samples from {_DRIVER_REPLAY_LOG_DIR}",
            flush=True,
        )
        if not self.sensor_ready:
            print("[DRIVER REPLAY] No samples found; using default driver values.", flush=True)
    =}

    reaction(sensorclock) -> head, eye, accelerator, brake, steer {=
        if self.sensor_ready:
            if self.replay_idx < len(self.replay_samples):
                sample = self.replay_samples[self.replay_idx]
                self.replay_idx += 1
            else:
                sample = self.replay_samples[-1]

            self.steer_val = sample["steer"]
            self.accel_val = sample["accel"]
            self.brake_val = sample["brake"]
            self.head_val = sample["head"]
            self.eye_val = sample["eye"]

        steer.set(self.steer_val)
        accelerator.set(self.accel_val)
        brake.set(self.brake_val)
        head.set(self.head_val)
        eye.set(self.eye_val)

        current_dri = lf.time.logical_elapsed()/1e6
        physical_dri = lf.time.physical_elapsed()/1e6
        lag = physical_dri - current_dri
        current_tag = lf.tag()

        print("----------------------------------------------------------")
        print(
            f"[DRIVER SEND] "
            f"sample={self.replay_idx}/{len(self.replay_samples) if self.sensor_ready else 0}, "
            f"accel={self.accel_val}, "
            f"brake={self.brake_val}, "
            f"steer={self.steer_val}, "
            f"head={self.head_val}, "
            f"eye={self.eye_val}",
            flush=True
        )

        print(f"[DRIVER] Logical time: {current_dri:.2f} ms", flush=True)
        print(f"[DRIVER] Physical time: {physical_dri:.2f} ms", flush=True)
        print(f"[DRIVER] LAG: {lag:.2f} ms", flush=True)
        print(f"[DRIVER] Tag time: {current_tag.time} ns", flush=True)
        print(f"[DRIVER] Microstep: {current_tag.microstep}", flush=True)
        print("----------------------------------------------------------")

    =}
}
