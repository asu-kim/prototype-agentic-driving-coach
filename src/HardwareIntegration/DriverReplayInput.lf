target Python

preamble {=
    import csv
    import os
    import time

    _DRIVER_REPLAY_LOG_DIR = os.getenv(
        "DRIVER_REPLAY_LOG_DIR",
        "/home/raspdeeksha/deterministic-prototyping-agenticCPS/src/HardwareIntegration/data-collection/logs-trace-2",
    )
    _FEDERATE_EXECUTION_LOG_PATH = os.getenv(
        "FEDERATE_EXECUTION_LOG_PATH",
        "logs-trace/federate_execution_times.csv",
    )
    _REPLAY_STOP_GRACE_NS = int(float(os.getenv("REPLAY_STOP_GRACE_MS", "0")) * 1e6)

    def _open_execution_log():
        log_dir = os.path.dirname(_FEDERATE_EXECUTION_LOG_PATH)
        if log_dir:
            os.makedirs(log_dir, exist_ok=True)
        needs_header = (
            not os.path.exists(_FEDERATE_EXECUTION_LOG_PATH)
            or os.path.getsize(_FEDERATE_EXECUTION_LOG_PATH) == 0
        )
        log_file = open(_FEDERATE_EXECUTION_LOG_PATH, "a", newline="", encoding="utf-8")
        log_writer = csv.writer(log_file)
        if needs_header:
            log_writer.writerow([
                "federate",
                "reactor",
                "reaction",
                "logical_time_ns",
                "logical_time_ms",
                "tag_time_ns",
                "microstep",
                "lag_ms",
                "start_physical_time_ms",
                "stop_physical_time_ms",
                "execution_time_ms",
            ])
            log_file.flush()
        return log_file, log_writer

    def _log_execution_time(self, federate, reactor, reaction, start_physical_time_ms, stop_physical_time_ms):
        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        self.execution_log_writer.writerow([
            federate,
            reactor,
            reaction,
            logical_time_ns,
            logical_time_ns / 1e6,
            lf.tag().time,
            current_tag.microstep,
            start_physical_time_ms - (logical_time_ns / 1e6),
            start_physical_time_ms,
            stop_physical_time_ms,
            stop_physical_time_ms - start_physical_time_ms,
        ])
        self.execution_log_file.flush()
=}

reactor DriverControl {
    state steer_val = 1
    state accel_val = 0.0
    state brake_val = 0.0
    state sensor_ready = False
    state replay_idx = 0
    state replay_stop_requested = False
    state replay_stop_ns = 0

    output steer
    output accelerator
    output brake

    timer sensorclock(7 sec, 100 msec)

    preamble {=
        def _to_int(self, value, default):
            try:
                if value is None or value == "":
                    return default
                return int(float(value))
            except Exception:
                return default

        def _to_float(self, value, default):
            try:
                if value is None or value == "":
                    return default
                return float(value)
            except Exception:
                return default

        def _last_logical_time_ns(self, csv_path):
            last_ns = 0
            if not os.path.exists(csv_path):
                print(f"[DRIVER CONTROL REPLAY] Missing file for stop time: {csv_path}", flush=True)
                return last_ns
            with open(csv_path, "r", newline="", encoding="utf-8") as f:
                for row in csv.DictReader(f):
                    last_ns = max(last_ns, self._to_int(row.get("logical_time_ns"), 0))
            return last_ns

        def _load_replay_stop_ns(self):
            control_path = os.path.join(_DRIVER_REPLAY_LOG_DIR, "driver_control_replay_values.csv")
            monitor_path = os.path.join(_DRIVER_REPLAY_LOG_DIR, "driver_monitor_replay_values.csv")
            return max(
                self._last_logical_time_ns(control_path),
                self._last_logical_time_ns(monitor_path),
            ) + _REPLAY_STOP_GRACE_NS

        def _load_control_samples(self):
            control_path = os.path.join(_DRIVER_REPLAY_LOG_DIR, "driver_control_replay_values.csv")
            samples = []

            print(f"[DRIVER CONTROL REPLAY] Reading {control_path}", flush=True)

            if os.path.exists(control_path):
                with open(control_path, "r", newline="", encoding="utf-8") as f:
                    for row in csv.DictReader(f):
                        samples.append({
                            "logical_time_ns": self._to_int(row.get("logical_time_ns"), 0),
                            "steer_present": self._to_int(row.get("steer_present"), 0),
                            "accel_present": self._to_int(row.get("accelerator_present"), 0),
                            "brake_present": self._to_int(row.get("brake_present"), 0),
                            "steer": self._to_int(row.get("steer"), self.steer_val),
                            "accel": self._to_float(row.get("accelerator"), self.accel_val),
                            "brake": self._to_float(row.get("brake"), self.brake_val),
                        })
            else:
                print(f"[DRIVER CONTROL REPLAY] Missing file: {control_path}", flush=True)

            samples.sort(key=lambda sample: sample["logical_time_ns"])
            return samples
    =}

    reaction(startup) {=
        self.replay_samples = self._load_control_samples()
        self.sensor_ready = len(self.replay_samples) > 0
        self.replay_stop_ns = self._load_replay_stop_ns()
        self.execution_log_file, self.execution_log_writer = _open_execution_log()

        print(f"[DRIVER CONTROL REPLAY] Loaded {len(self.replay_samples)} samples", flush=True)
        print(f"[DRIVER CONTROL REPLAY] Stop time: {self.replay_stop_ns / 1e9:.3f} sec", flush=True)
        print(f"[EXECUTION LOG] Appending timings to {_FEDERATE_EXECUTION_LOG_PATH}", flush=True)
    =}

    reaction(sensorclock) -> steer, accelerator, brake {=
        start_physical_time = lf.time.physical_elapsed()/1e6
        exec_t0 = time.perf_counter()

        if self.replay_stop_ns <= 0:
            print("[DRIVER CONTROL REPLAY] No replay inputs found; requesting stop.", flush=True)
            self.replay_stop_requested = True
            lf.request_stop()
            return

        if lf.time.logical_elapsed() > self.replay_stop_ns:
            if not self.replay_stop_requested:
                print(
                    f"[DRIVER CONTROL REPLAY] Reached end of replay inputs at {lf.time.logical_elapsed() / 1e9:.3f} sec; requesting stop.",
                    flush=True,
                )
                self.replay_stop_requested = True
                lf.request_stop()
            return

        sample = None

        if self.sensor_ready and self.replay_idx < len(self.replay_samples):
            sample = self.replay_samples[self.replay_idx]
            self.replay_idx += 1

        if sample is not None:
            if sample["steer_present"]:
                self.steer_val = sample["steer"]

            if sample["accel_present"]:
                self.accel_val = sample["accel"]

            if sample["brake_present"]:
                self.brake_val = sample["brake"]

        steer.set(self.steer_val)
        accelerator.set(self.accel_val)
        brake.set(self.brake_val)

        exec_ms = (time.perf_counter() - exec_t0) * 1000.0

        current_dri = lf.time.logical_elapsed()/1e6
        physical_dri = lf.time.physical_elapsed()/1e6
        lag = physical_dri - current_dri
        current_tag = lf.tag()

        print("----------------------------------------------------------")
        print(
            f"[DRIVER CONTROL REPLAY SEND] "
            f"sample={self.replay_idx}/{len(self.replay_samples) if self.sensor_ready else 0}, "
            f"steer_present={sample['steer_present'] if sample is not None else 0}, "
            f"accel_present={sample['accel_present'] if sample is not None else 0}, "
            f"brake_present={sample['brake_present'] if sample is not None else 0}, "
            f"accel={self.accel_val}, brake={self.brake_val}, steer={self.steer_val}",
            flush=True
        )
        print(f"[DRIVER CONTROL REPLAY EXEC TIME] {exec_ms:.3f} ms", flush=True)
        print(f"[DRIVER CONTROL REPLAY] Logical time: {current_dri:.2f} ms", flush=True)
        print(f"[DRIVER CONTROL REPLAY] Physical time: {physical_dri:.2f} ms", flush=True)
        print(f"[DRIVER CONTROL REPLAY] LAG: {lag:.2f} ms", flush=True)
        print(f"[DRIVER CONTROL REPLAY] Tag time: {lf.tag().time} ns", flush=True)
        print(f"[DRIVER CONTROL REPLAY] Microstep: {current_tag.microstep}", flush=True)
        print("----------------------------------------------------------")

        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "d_control", "DriverControlReplay", "output_tick", start_physical_time, stop_physical_time)
    =}

    reaction(shutdown) {=
        if hasattr(self, "execution_log_file") and not self.execution_log_file.closed:
            self.execution_log_file.flush()
            self.execution_log_file.close()
    =}
}


reactor DriverMonitor {
    state head_val = 1
    state eye_val = 1
    state sensor_ready = False
    state replay_idx = 0

    output head
    output eye

    timer sensorclock(7 sec, 100 msec)

    preamble {=
        def _to_int(self, value, default):
            try:
                if value is None or value == "":
                    return default
                return int(float(value))
            except Exception:
                return default

        def _load_monitor_samples(self):
            monitor_path = os.path.join(_DRIVER_REPLAY_LOG_DIR, "driver_monitor_replay_values.csv")
            samples = []

            print(f"[DRIVER MONITOR REPLAY] Reading {monitor_path}", flush=True)

            if os.path.exists(monitor_path):
                with open(monitor_path, "r", newline="", encoding="utf-8") as f:
                    for row in csv.DictReader(f):
                        samples.append({
                            "logical_time_ns": self._to_int(row.get("logical_time_ns"), 0),
                            "head_present": self._to_int(row.get("head_present"), 0),
                            "eye_present": self._to_int(row.get("eye_present"), 0),
                            "head": self._to_int(row.get("head"), self.head_val),
                            "eye": self._to_int(row.get("eye"), self.eye_val),
                        })
            else:
                print(f"[DRIVER MONITOR REPLAY] Missing file: {monitor_path}", flush=True)

            samples.sort(key=lambda sample: sample["logical_time_ns"])
            return samples
    =}

    reaction(startup) {=
        self.replay_samples = self._load_monitor_samples()
        self.sensor_ready = len(self.replay_samples) > 0
        self.execution_log_file, self.execution_log_writer = _open_execution_log()

        print(f"[DRIVER MONITOR REPLAY] Loaded {len(self.replay_samples)} samples", flush=True)
        print(f"[EXECUTION LOG] Appending timings to {_FEDERATE_EXECUTION_LOG_PATH}", flush=True)
    =}

    reaction(sensorclock) -> head, eye {=
        start_physical_time = lf.time.physical_elapsed()/1e6
        exec_t0 = time.perf_counter()

        sample = None

        if self.sensor_ready and self.replay_idx < len(self.replay_samples):
            sample = self.replay_samples[self.replay_idx]
            self.replay_idx += 1

        if sample is not None:
            if sample["head_present"]:
                self.head_val = sample["head"]
                head.set(self.head_val)

            if sample["eye_present"]:
                self.eye_val = sample["eye"]
                eye.set(self.eye_val)

        exec_ms = (time.perf_counter() - exec_t0) * 1000.0

        current_dri = lf.time.logical_elapsed()/1e6
        physical_dri = lf.time.physical_elapsed()/1e6
        lag = physical_dri - current_dri
        current_tag = lf.tag()

        print("----------------------------------------------------------")
        print(
            f"[DRIVER MONITOR REPLAY SEND] "
            f"sample={self.replay_idx}/{len(self.replay_samples) if self.sensor_ready else 0}, "
            f"head_present={sample['head_present'] if sample is not None else 0}, "
            f"eye_present={sample['eye_present'] if sample is not None else 0}, "
            f"head={self.head_val}, eye={self.eye_val}",
            flush=True
        )
        print(f"[DRIVER MONITOR REPLAY EXEC TIME] {exec_ms:.3f} ms", flush=True)
        print(f"[DRIVER MONITOR REPLAY] Logical time: {current_dri:.2f} ms", flush=True)
        print(f"[DRIVER MONITOR REPLAY] Physical time: {physical_dri:.2f} ms", flush=True)
        print(f"[DRIVER MONITOR REPLAY] LAG: {lag:.2f} ms", flush=True)
        print(f"[DRIVER MONITOR REPLAY] Tag time: {lf.tag().time} ns", flush=True)
        print(f"[DRIVER MONITOR REPLAY] Microstep: {current_tag.microstep}", flush=True)
        print("----------------------------------------------------------")

        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "d_monitor", "DriverMonitorReplay", "output_tick", start_physical_time, stop_physical_time)
    =}

    reaction(shutdown) {=
        if hasattr(self, "execution_log_file") and not self.execution_log_file.closed:
            self.execution_log_file.flush()
            self.execution_log_file.close()
    =}
}