target Python

preamble {=
    import csv
    import json
    import os

    _LLM_INPUT_LOG_PATH = os.getenv(
        "ADC_INPUT_LOG_PATH",
        os.getenv("LLM_INPUT_LOG_PATH", "logs-trace/adc_inputs.csv"),
    )
    _FEDERATE_EXECUTION_LOG_PATH = os.getenv(
        "FEDERATE_EXECUTION_LOG_PATH",
        "logs-trace/federate_execution_times.csv",
    )

    def _open_execution_log():
        log_dir = os.path.dirname(_FEDERATE_EXECUTION_LOG_PATH)
        if log_dir:
            os.makedirs(log_dir, exist_ok=True)
        needs_header = (
            not os.path.exists(_FEDERATE_EXECUTION_LOG_PATH)
            or os.path.getsize(_FEDERATE_EXECUTION_LOG_PATH) == 0
        )
        log_file = open(_FEDERATE_EXECUTION_LOG_PATH, "a", newline="", encoding="utf-8")
        log_writer = csv.writer(log_file)
        if needs_header:
            log_writer.writerow([
                "federate",
                "reactor",
                "reaction",
                "logical_time_ns",
                "logical_time_ms",
                "tag_time_ns",
                "microstep",
                "lag_ms",
                "start_physical_time_ms",
                "stop_physical_time_ms",
                "execution_time_ms",
            ])
            log_file.flush()
        return log_file, log_writer

    def _log_execution_time(self, federate, reactor, reaction, start_physical_time_ms, stop_physical_time_ms):
        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        self.execution_log_writer.writerow([
            federate,
            reactor,
            reaction,
            logical_time_ns,
            logical_time_ns / 1e6,
            lf.tag().time,
            current_tag.microstep,
            start_physical_time_ms - (logical_time_ns / 1e6),
            start_physical_time_ms,
            stop_physical_time_ms,
            stop_physical_time_ms - start_physical_time_ms,
        ])
        self.execution_log_file.flush()
=}

reactor InputForCoach{
    input s
    input v
    input st
    input h
    input e
    input en_states

    // Local LLM inference is synchronous, so leave enough time between requests
    // for one inference to finish before the next logical tick.
    timer llmclock(7 sec, 400 msec)

    state s_val = 0.0
    state v_val = 0.0
    state st_val = 2
    state h_val = 5
    state e_val = 5
    state en_states_val = []

    output displacement
    output velocity
    output steer
    output head_pos
    output eye_pos
    output environment_states
 


    reaction(startup){=
        self.head_history = []
        self.eye_history = []
        self.max_history = 4
        os.makedirs(os.path.dirname(_LLM_INPUT_LOG_PATH), exist_ok=True)
        self.llm_input_log_file = open(_LLM_INPUT_LOG_PATH, "w", newline="", encoding="utf-8")
        self.llm_input_log_writer = csv.writer(self.llm_input_log_file)
        self.llm_input_log_writer.writerow([
            "event",
            "logical_time_ns",
            "logical_time_ms",
            "physical_time_ms",
            "tag_time_ns",
            "microstep",
            "displacement_present",
            "velocity_present",
            "car_steer_present",
            "head_present",
            "eye_present",
            "environment_states_present",
            "environment_distance",
            "car_velocity",
            "car_steer",
            "head",
            "eye",
            "head_history_json",
            "eye_history_json",
            "environment_states_json",
        ])
        self.llm_input_log_file.flush()
        self.execution_log_file, self.execution_log_writer = _open_execution_log()
        print(f"[ADC INPUT LOG] Writing inputs to {_LLM_INPUT_LOG_PATH}", flush=True)
        print(f"[EXECUTION LOG] Appending timings to {_FEDERATE_EXECUTION_LOG_PATH}", flush=True)
    =}
    reaction(s, v, st, h, e, en_states){=
        start_physical_time = lf.time.physical_elapsed()/1e6
        if s.is_present:
            self.s_val = s.value
        if v.is_present:
            self.v_val = v.value
        if st.is_present:
            self.st_val = st.value
        if h.is_present:
            self.h_val = h.value
            #  print(f"Head value every 100ms: {self.h_val}")
            if self.h_val == 0:
                self.head_history.append("LEFT")
            elif self.h_val == 1:
                self.head_history.append("CENTER")
            elif self.h_val == 2:
                self.head_history.append("RIGHT")
            else:
                self.head_history.append("CENTER")
        if e.is_present:
            self.e_val = e.value
            #  print(f"EYE value every 100ms: {self.e_val}")
            if self.e_val == 0:
                self.eye_history.append("LEFT")
            elif self.e_val == 1:
                self.eye_history.append("CENTER")
            elif self.e_val == 2:
                self.eye_history.append("RIGHT")
            else:
                self.eye_history.append("CENTER")
        if en_states.is_present:
            self.en_states_val = en_states.value
        self.head_history = self.head_history[-self.max_history:]
        self.eye_history = self.eye_history[-self.max_history:]

        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        self.llm_input_log_writer.writerow([
            "input_arrival",
            logical_time_ns,
            logical_time_ns / 1e6,
            lf.time.physical_elapsed() / 1e6,
            lf.tag().time,
            current_tag.microstep,
            int(s.is_present),
            int(v.is_present),
            int(st.is_present),
            int(h.is_present),
            int(e.is_present),
            int(en_states.is_present),
            self.s_val,
            self.v_val,
            self.st_val,
            self.h_val,
            self.e_val,
            json.dumps(self.head_history),
            json.dumps(self.eye_history),
            json.dumps(self.en_states_val),
        ])
        self.llm_input_log_file.flush()
        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "adc", "InputForCoach", "input_arrival", start_physical_time, stop_physical_time)
    =} tardy


    reaction(llmclock)->displacement, velocity, steer, head_pos, eye_pos, environment_states{=
        start_physical_time = lf.time.physical_elapsed()/1e6
        #reaction(llmclock)->coach_input{=
        displacement.set(self.s_val)
        velocity.set(self.v_val)
        steer.set(self.st_val)
        head_pos.set(self.head_history)
        eye_pos.set(self.eye_history)
        environment_states.set(self.en_states_val)

        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        self.llm_input_log_writer.writerow([
            "llm_output_tick",
            logical_time_ns,
            logical_time_ns / 1e6,
            lf.time.physical_elapsed() / 1e6,
            lf.tag().time,
            current_tag.microstep,
            1,
            1,
            1,
            1,
            1,
            1,
            self.s_val,
            self.v_val,
            self.st_val,
            self.h_val,
            self.e_val,
            json.dumps(self.head_history),
            json.dumps(self.eye_history),
            json.dumps(self.en_states_val),
        ])
        self.llm_input_log_file.flush()
        # coach_input.set({
        #     "distance": self.s_val,
        #     "velocity": self.v_val,
        #     "steering": self.st_val,
        #     "head_history": list(self.head_history),
        #     "eye_history": list(self.eye_history),
        #     "environment": self.en_states_val,
        # })

        current_dri = lf.time.logical_elapsed()/1e6
        physical_dri = lf.time.physical_elapsed()/1e6
        lag = physical_dri - current_dri
        current_tag = lf.tag()


        print("----------------------------------------------------------")
        print(f"[InputForCoach] Logical time: {current_dri:.2f} ms", flush=True)
        print(f"[InputForCoach] Physical time: {physical_dri:.2f} ms", flush=True)
        print(f"[InputForCoach] LAG: {lag:.2f} ms", flush=True)
        print(f"[InputForCoach] Tag time: {lf.tag().time} ns", flush=True)
        print(f"[InputForCoach] Microstep: {current_tag.microstep}", flush=True)
        print("----------------------------------------------------------")
        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "adc", "InputForCoach", "llm_output_tick", start_physical_time, stop_physical_time)

    =}


    reaction(shutdown) {=
        if hasattr(self, "llm_input_log_file") and not self.llm_input_log_file.closed:
            self.llm_input_log_file.flush()
            self.llm_input_log_file.close()
        if hasattr(self, "execution_log_file") and not self.execution_log_file.closed:
            self.execution_log_file.flush()
            self.execution_log_file.close()
    =}

}
