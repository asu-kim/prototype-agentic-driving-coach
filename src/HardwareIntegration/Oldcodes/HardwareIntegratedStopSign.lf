target Python {keepalive: true, files: "rag.py"}

import SensorInputs from "SensorInputs.lf"
preamble{=
    import time
    import subprocess
=}

reactor Driver{
    // input start_signal
    // state started = False
    state steer_val = 1
    state accel_val = 0.0
    state brake_val = 0.0
    state head_val = 1
    state eye_val = 1

    output steer
    output accelerator
    output brake
    output head
    output eye
    timer sensorclock(0, 100 msec)

    sen = new SensorInputs()

    // reaction(start_signal) {=
    //     self.started = True
    // =}

    
    reaction(sen.eye_msg, sen.head_msg, sen.accel_msg, sen.brake_msg, sen.steer_msg) {=
        # if not self.started:
        #     return

        if sen.head_msg.is_present:
            self.head_val = sen.head_msg.value
        if sen.eye_msg.is_present:
            self.eye_val = sen.eye_msg.value

        if sen.steer_msg.is_present:
            self.steer_val = sen.steer_msg.value

        if sen.accel_msg.is_present:
            self.accel_val = sen.accel_msg.value

        if sen.brake_msg.is_present:
            self.brake_val = sen.brake_msg.value
    =}
    reaction(sensorclock) -> head, eye, accelerator, brake, steer {=
        # if not self.started:
        #     return
        current_dri = lf.time.logical_elapsed()/1e6
        steer.set(self.steer_val)
        accelerator.set(self.accel_val)
        brake.set(self.brake_val)
        head.set(self.head_val)
        eye.set(self.eye_val)
        if self.head_val == 0:
            head_str = "LEFT"
        elif self.head_val == 1:
            head_str = "CENTER"
        else:
            head_str = "RIGHT"

        if self.eye_val == 0:
            eye_str = "LEFT"
        elif self.eye_val == 1:
            eye_str = "CENTER"
        else:
            eye_str = "RIGHT"

        if self.steer_val == 0:
            steer_str = "LEFT"
        elif self.steer_val == 1:
            steer_str = "CENTER"
        else:
            steer_str = "RIGHT"

        print("----- sensor clock-----")
        print(f"[DRIVER] logical time: {current_dri:.2f} ", flush=True)
        print(f"Head: {self.head_val} ({head_str})", flush=True)
        print(f"Eye: {self.eye_val} ({eye_str})", flush=True)
        print(f"Accelerator: {self.accel_val}", flush=True)
        print(f"Brake: {self.brake_val}", flush=True)
        print(f"Steer: {self.steer_val} ({steer_str})", flush=True)
    =}
}

reactor Car{
    input start_signal
    state started = False

    // input steer_in
    // input accel_in
    // input brake_in
    input actuate_in 
    // input head_pos_in  
    // input eye_pos_in

    state acceleration_net
    state velocity_init = 30
    state dist_init = 0.0
  
    state accel_val = 0.0
    state brake_val = 0.0
    state act_val 

    output velocity
    output steer
    output head_pos
    output eye_pos
    
    d = new Driver()

    reaction(start_signal) {=
        self.started = True
    =}
    reaction(d.accelerator, d.brake, d.eye, d.head, d.steer, actuate_in)-> velocity, steer, head_pos, eye_pos {=
        if not self.started:
            return
        if d.accelerator.is_present:
            self.accel_val = float(d.accelerator.value)

        if d.brake.is_present:
            self.brake_val = float(d.brake.value)


        if actuate_in.is_present:
            self.act_val = actuate_in.value

        current_dri = lf.time.logical_elapsed()/1e6
        amsg = self.accel_val
        bmsg = self.brake_val
        act  = self.act_val

        def acel_cal(p):
            p = max(0.0, min(1.0, p))
            if p < 0.1:
                return p
            elif p < 0.6:
                return 2.4 * p
            else:
                return 4.0 * (p**2)

        def brake_cal(p):
            p = max(0.0, min(1.0, p))
            if p < 0.1:
                return -p
            elif p < 0.6:
                return -(5.4 * p)
            else:
                return -(9.0 * (p**2))

        vel_prev = self.velocity_init

        #ACTUATE
        if act == 11:
            target_speed = 0.0

            error = target_speed - vel_prev

            Kp = 1.2
            acc_net = Kp * error

            acc_net = max(-9.0, min(4.0, acc_net))


      
        else:
            acc_net = 0.0


            if amsg > 0.0:
                acc_net += acel_cal(amsg)

            if bmsg > 0.0:
                acc_net += brake_cal(bmsg)


        
        vel = vel_prev + acc_net * 0.1
        vel = max(0.0, vel)
        dist = max(0.0, self.dist_init - vel * 0.1)
        self.velocity_init = vel
        self.dist_init = dist

        print(f"---------------------------------------------------------", flush=True)
        print(f"[CAR CLOCK] logical time: {current_dri:.2f}", flush=True)
        print(f"velocity={vel:.2f} acceleration={acc_net:.2f}", flush=True)
        print(f"acceleration={acc_net:.2f}", flush=True)

        velocity.set(vel)
        steer.set(d.steer.value)
        head_pos.set(d.head.value)
        eye_pos.set(d.eye.value)


    =}

}

reactor Environment{
    input start_signal
    state started = False

    input v
    state pos_stop_sign = 200.0
    state passed = False
    output displacement
    state v_val = 0.0

    reaction(start_signal) {=
        self.started = True
    =}
    reaction(v) -> displacement{=
        if not self.started:
            return
        if v.is_present:
            self.v_val = float(v.value)
        current_dri = lf.time.logical_elapsed()/1e6
        

        step = self.v_val * 0.1

        if not self.passed:
            self.pos_stop_sign -= step

            if self.pos_stop_sign <= 0.0:
                self.pos_stop_sign = 0.0
                self.passed = True

            displacement.set(self.pos_stop_sign)
        else:
            displacement.set(0.0)

        print(f"[ENV CLOCK] logical time: {current_dri:.2f} disp={self.pos_stop_sign}", flush=True)
    =}

}



reactor LLMInference {
    input s
    input v
    input st 
    input h
    input e

    output ready
    output control
    output instruction

    state last_dl_tok = ""
    state last_dl_msg = ""
    state is_ready = False
    state s_val = 0.0
    state v_val = 0.0
    state st_val = 1
    state h_val = 1
    state e_val = 1

    timer llmclock(0, 100 msec)

    preamble{=
        from rag_stop import generate_response
        def fallback_policy(self, rd_val, v_val):
            if rd_val <= 0.0:
                return "NONE", ""

            if rd_val <= 25.0 and v_val > 2.5:
                return "ACTUATE", "Brake now."

            if 50.0 < rd_val <= 60.0 and (v_val > 10.0 or v_val < 8.0):
                return "WARNING", "Adjust speed and prepare to stop."

            if rd_val >= 99.0 and (v_val > 12.0 or v_val < 8.0):
                return "WARNING", "Stop sign ahead."

            return "NONE", ""
    =}

    reaction(startup) -> ready {=
        import time
        import ollama
        print("\n=== STARTUP ===", flush=True)
        print(f"[TIME] logical={lf.time.logical_elapsed()/1e6:.2f}", flush=True)
        print(f"[TIME] physical={lf.time.physical_elapsed()/1e6:.2f}", flush=True)
        try:
                r = ollama.chat(
                    model="llama3:8b",
                    messages=[
                        {
                            "role": "system",
                            "content": (
                                        " You are a real-time driving coach.\n"
                                    )
                        },
                        {
                            "role": "user",
                            "content": f"provide a greeting message"
                        }
                    ],
                    options={"temperature": 0.0, "num_predict": 10},
                )
        except Exception as e:
                print(">>> LLM ERROR:", e, flush=True)
                return "NONE", "", 0.0
        self.is_ready = True
        ready.set(True)

        print("[STATUS] LLM READY", flush=True)
    =}

    reaction(s, v, st, h, e){=
        
        if s.is_present:
            self.s_val = s.value
        if v.is_present:
            self.v_val = v.value
        if st.is_present:
            self.st_val = st.value
        if h.is_present:
            self.h_val = h.value
        if e.is_present:
            self.e_val = e.value


    =}

    reaction(llmclock) -> control, instruction {=

        current_logical = lf.time.logical_elapsed()/1e6
        current_physical = lf.time.physical_elapsed()/1e9
        # print(f"PHYSICAL TIME: {current_physical:.2f} S ")

        if not self.is_ready:

            return

        rd_val = self.s_val
        v_val  = self.v_val
        h_val = self.h_val
        e_val = self.e_val
        st_val = self.st_val



        if rd_val <= 0.0:
            rd_val = 0.0


        tok_raw, msg_raw = self.generate_response(rd_val, v_val, st_val, h_val, e_val)

        self.check_deadline()

        tok = tok_raw or "NONE"
        msg = msg_raw or "There is a stop sign ahead"
        # print(f"[LLM RESULT] {tok} | {msg} ", flush=True)

        tok = tok.strip()
        msg = msg.strip()

        control.set(tok)
        instruction.set(msg)

    =} 
    deadline(100 sec) {=


        rd_val = self.s_val
        v_val  = self.v_val

        tok, msg = self.fallback_policy(rd_val, v_val)


        control.set(tok)
        instruction.set(msg)
    =}
}


reactor Planner {
  input ctrl
  input instr
  input s
  input v
  output act
  output planned_instr

  state last_warn_ns = -10000000000000
  state last_act_ns = -1000000000000
  state speech_proc 
  state reached = False

  preamble{=
    import subprocess

    def speak(self, msg):
        try:
            if self.speech_proc is not None:
                self.speech_proc.kill()
        except:
            pass

        self.speech_proc = subprocess.Popen(
            ["espeak", "-s", "120", msg],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL
        )
  =}

  initial mode monitoring {
    
    reaction(ctrl, instr, s, v) -> warning, actuate, planned_instr {=
      
      kw  = (ctrl.value or "NONE").strip()
      instruction = (instr.value or "").strip()
      rd  = s.value if s.value is not None else 0.0
      v_val = v.value if v.value is not None else 0.0
      now_ns = lf.time.logical_elapsed()

      print(f"[DATA] v={v_val:.2f} | s={rd:.2f}", flush=True)

      if rd <= 2 and v_val <= 0.5:
        self.reached = True
        return

      if rd <= 2:
        if kw == "ACTUATE" or self.reached:
            self.reached = True
            actuate.set()

        if (now_ns - self.last_act_ns) >= 3000000000:
            if instruction:
                print(f"[LLM STOP] {instruction}", flush=True)
                planned_instr.set(instruction)
                self.speak(instruction)
            self.last_act_ns = now_ns

        return

      if kw == "ACTUATE" or self.reached:
        self.reached = True
        actuate.set()

        if (now_ns - self.last_act_ns) >= 3000000000:
          if instruction:
            print(f"[LLM] ACTUATE | {instruction}", flush=True)
            planned_instr.set(instruction)
            self.speak(instruction)

          self.last_act_ns = now_ns
        return

      if kw == "WARNING":
        if (now_ns - self.last_warn_ns) >= 3000000000:
          if instruction:
            print(f"[LLM] WARNING | {instruction}", flush=True)
            planned_instr.set(instruction)
            self.speak(instruction)

          self.last_warn_ns = now_ns

        warning.set()
        return
    =}
  }

  mode warning {
    reaction(ctrl, instr, s, v) -> monitoring, actuate, planned_instr {=
      kw  = (ctrl.value or "NONE").strip()
      instruction = (instr.value or "").strip()
      rd  = s.value if s.value is not None else 0.0
      v_val = v.value if v.value is not None else 0.0
      now_ns = lf.time.logical_elapsed()  

      print(f"[DATA] v={v_val:.2f} | s={rd:.2f}", flush=True)

      if rd <= 2 and v_val <= 0.5:
        self.reached = True
        return

      if rd <= 2:
        if kw == "ACTUATE" or self.reached:
            self.reached = True
            actuate.set()

        if (now_ns - self.last_act_ns) >= 3000000000:
            if instruction:
                print(f"[LLM STOP] {instruction}", flush=True)
                planned_instr.set(instruction)
                self.speak(instruction)
            self.last_act_ns = now_ns
        return

      if kw == "ACTUATE" or self.reached:
        self.reached = True
        actuate.set()
        return

      if kw == "NONE":
        monitoring.set()
        return
    =}
  }

  mode actuate {
    reaction(ctrl, instr, s, v) -> act, monitoring, planned_instr {=
        instruction = (instr.value or "").strip()
        rd = s.value if s.value is not None else 0.0
        v_val = v.value if v.value is not None else 0.0
        now_ns = lf.time.logical_elapsed()

        print(f"[DATA] v={v_val:.2f} | s={rd:.2f}", flush=True)

        if rd <= 2 and v_val <= 0.5:
            self.reached = True
            return

        if rd > 99 and (11 <= v_val <= 12):
            return

        if 50 <= rd <= 60 and (8 <= v_val <= 10):
            return

        if rd > 25 and v_val <= 2.5:
            return

        if rd <= 25 and v_val > 2.5:
            act.set(11)

        elif 50 <= rd <= 60 and not (8 <= v_val <= 10):
            act.set(11)

        elif rd > 99 and not (8 <= v_val <= 12):
            act.set(11)

        else:
            monitoring.set()
            return

        if (now_ns - self.last_act_ns) >= 3000000000:
            if instruction:
                print(f"[SYSTEM ACTION] {instruction}", flush=True)
                planned_instr.set(instruction)
                self.speak(instruction)
            self.last_act_ns = now_ns

        self.reached = True
        monitoring.set()
    =}
    }
}



reactor Coach{
    input s
    input v
    input st 
    input h
    input e

    

    output act
    output instr
    output ready

    llm = new LLMInference()
    a = new Planner()
    s -> llm.s
    v -> llm.v
    st -> llm.st
    h -> llm.h
    e -> llm.e
   
    llm.control -> a.ctrl
    llm.instruction -> a.instr
    s -> a.s
    v -> a.v
    a.act -> act
    a.planned_instr -> instr

    llm.ready -> ready

    
}

federated reactor at 10.218.100.78 {

    c = new Car()
    en = new Environment()
    adc = new Coach()


    adc.ready -> c.start_signal
    adc.ready -> en.start_signal



    c.velocity -> en.v
    c.velocity -> adc.v
    c.steer -> adc.st
    c.head_pos -> adc.h
    c.eye_pos -> adc.e

    en.displacement -> adc.s

    adc.act -> c.actuate_in after 100 ms
}