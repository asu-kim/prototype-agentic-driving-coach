target Python {
    timeout: 5 sec,
    logging: LOG,
    DNET: false,
    tracing: true
}

preamble {=
    import random
    TOKENS = ["NONE", "WARNING", "ACTUATE", "NONE", "WARNING"]
=}

reactor Producer {
    output ctrl
    output instr

    timer t(0, 500 msec)

    state produce_handle = 0
    state token_handle = 0



    reaction(startup) {=
        print("[Producer] startup", flush=True)

        self.i = 0
        self.produce_handle = self.register_user_trace_event("Producer generated planner token")
        self.token_handle = self.register_user_trace_event("Producer token id")

        print(f"[Producer] produce_handle={self.produce_handle}", flush=True)
        print(f"[Producer] token_handle={self.token_handle}", flush=True)
    =}

    reaction(t) -> ctrl, instr {=
        token = TOKENS[self.i % len(TOKENS)]
        self.i += 1

        if token == "NONE":
            msg = ""
            token_id = 0
        elif token == "WARNING":
            msg = "Prepare to change right for the exit."
            token_id = 1
        else:
            msg = "Brake now. Vehicle ahead."
            token_id = 2

        if self.produce_handle != 0:
            self.tracepoint_user_event(self.produce_handle)
        if self.token_handle != 0:
            self.tracepoint_user_value(self.token_handle, token_id)

        print(f"[Producer] token={token}, instr={msg}", flush=True)

        ctrl.set(token)
        instr.set(msg)
    =}
}

reactor ModalPlanner {
    input ctrl
    input instr

    output act
    output planned_instr

    state control_token = "NONE"
    state instruction_val = ""

    state monitor_handle = 0
    state warning_handle = 0
    state actuate_handle = 0
    state transition_handle = 0
    state act_handle = 0

    preamble {=
        def trace_transition(self, from_mode, to_mode, token):
            print(f"[MODE TRANSITION] {from_mode} -> {to_mode} because {token}", flush=True)
            if self.transition_handle != 0:
                self.tracepoint_user_event(self.transition_handle)

        def print_timing(self, label):
            current_ms = lf.time.logical_elapsed() / 1e6
            physical_ms = lf.time.physical_elapsed() / 1e6
            lag = physical_ms - current_ms
            tag = lf.tag()

            print("----------------------------------------------------------", flush=True)
            print(f"[{label}] Logical time: {current_ms:.2f} ms", flush=True)
            print(f"[{label}] Physical time: {physical_ms:.2f} ms", flush=True)
            print(f"[{label}] LAG: {lag:.2f} ms", flush=True)
            print(f"[{label}] Tag time: {tag.time} ns", flush=True)
            print(f"[{label}] Microstep: {tag.microstep}", flush=True)
            print("----------------------------------------------------------", flush=True)
    =}

    reaction(startup) {=
        print("[ModalPlanner] startup", flush=True)

        self.monitor_handle = self.register_user_trace_event("Planner monitoring reaction")
        self.warning_handle = self.register_user_trace_event("Planner warning reaction")
        self.actuate_handle = self.register_user_trace_event("Planner actuate reaction")
        self.transition_handle = self.register_user_trace_event("Planner mode transition")
        self.act_handle = self.register_user_trace_event("Planner actuation command id")

        print(f"[ModalPlanner] monitor_handle={self.monitor_handle}", flush=True)
        print(f"[ModalPlanner] warning_handle={self.warning_handle}", flush=True)
        print(f"[ModalPlanner] actuate_handle={self.actuate_handle}", flush=True)
        print(f"[ModalPlanner] transition_handle={self.transition_handle}", flush=True)
        print(f"[ModalPlanner] act_handle={self.act_handle}", flush=True)
    =}

    initial mode monitoring {
        reaction(ctrl, instr) -> reset(warning), reset(actuate), planned_instr {=
            if self.monitor_handle != 0:
                self.tracepoint_user_event(self.monitor_handle)

            if ctrl.is_present:
                self.control_token = (ctrl.value or "NONE").strip().upper()
            if instr.is_present:
                self.instruction_val = (instr.value or "").strip()

            token = self.control_token
            instruction = self.instruction_val

            print(f"[MONITORING] token={token}, instruction={instruction}", flush=True)

            if instruction:
                planned_instr.set(instruction)

            if token == "ACTUATE":
                self.trace_transition("MONITORING", "ACTUATE", token)
                actuate.set()
                self.print_timing("PLANNER MONITORING")
                return

            if token == "WARNING":
                self.trace_transition("MONITORING", "WARNING", token)
                warning.set()
                self.print_timing("PLANNER MONITORING")
                return

            self.print_timing("PLANNER MONITORING")
        =}
    }

    mode warning {
        reaction(ctrl, instr) -> reset(monitoring), reset(actuate), planned_instr {=
            if self.warning_handle != 0:
                self.tracepoint_user_event(self.warning_handle)

            if ctrl.is_present:
                self.control_token = (ctrl.value or "NONE").strip().upper()
            if instr.is_present:
                self.instruction_val = (instr.value or "").strip()

            token = self.control_token
            instruction = self.instruction_val

            print(f"[WARNING MODE] token={token}, instruction={instruction}", flush=True)

            if instruction:
                planned_instr.set(instruction)

            if token == "ACTUATE":
                self.trace_transition("WARNING", "ACTUATE", token)
                actuate.set()
                self.print_timing("PLANNER WARNING")
                return

            if token != "WARNING":
                self.trace_transition("WARNING", "MONITORING", token)
                monitoring.set()
                self.print_timing("PLANNER WARNING")
                return

            self.print_timing("PLANNER WARNING")
        =}
    }

    mode actuate {
        reaction(ctrl, instr) -> reset(monitoring), planned_instr, act {=
            if self.actuate_handle != 0:
                self.tracepoint_user_event(self.actuate_handle)

            if ctrl.is_present:
                self.control_token = (ctrl.value or "NONE").strip().upper()
            if instr.is_present:
                self.instruction_val = (instr.value or "").strip()

            token = self.control_token
            instruction = self.instruction_val

            print(f"[ACTUATE MODE] token={token}, instruction={instruction}", flush=True)

            if instruction:
                planned_instr.set(instruction)

            if token == "ACTUATE":
                command = "BRAKE"
                act.set(command)

                if self.act_handle != 0:
                    self.tracepoint_user_value(self.act_handle, 1)

                print(f"[ACTUATE MODE] act={command}", flush=True)
                self.print_timing("PLANNER ACTUATE")
                return

            self.trace_transition("ACTUATE", "MONITORING", token)
            monitoring.set()
            self.print_timing("PLANNER ACTUATE")
        =}
    }
}

federated reactor {
    p = new Producer()
    planner = new ModalPlanner()

    p.ctrl -> planner.ctrl
    p.instr -> planner.instr
}