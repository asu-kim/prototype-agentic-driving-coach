target Python {keepalive: true, 
    // logging: DEBUG,
    coordination: decentralized,
    DNET: False,
    // tracing:True
    }
import DriverControl from "DriverControl.lf"


import Simulation from "Simulation.lf"

reactor VelocityDisplacement{
    input accel
    input brake
    output velocity
    output displacement

    state velocity_init = 25.0
    state dist_init = 0.0
    state accel_val = 0.0
    state brake_val = 0.0

    preamble{=
        def update_car(self, accel_input, brake_input):
            if accel_input is not None:
                self.accel_val = float(accel_input)
            if brake_input is not None:
                self.brake_val = float(brake_input)
          
            amsg = self.accel_val
            bmsg = self.brake_val

            amsg = max(0.0, min(1.0, amsg))
            bmsg = max(0.0, min(1.0, bmsg))

            MAX_BRAKE = -10.0
            MAX_ACCEL = 4.0
            A_DRAG_COEF = -0.002
            A_FRIC_COEFF = -0.022
            DT = 0.1
            MAX_VEL = 35.0

            accel_brake = bmsg * MAX_BRAKE
            accel_throt = (0.6 * amsg + 0.4 * amsg * amsg) * MAX_ACCEL
            accel_drag = A_DRAG_COEF * self.velocity_init ** 2
            accel_net = accel_brake + accel_throt + accel_drag + A_FRIC_COEFF

            vel = max(0.0, min(MAX_VEL, self.velocity_init + accel_net * DT))
            dist = self.dist_init + vel * DT
            self.velocity_init = vel
            self.dist_init = dist

            velocity_kmh = vel * 3.6
            print(f"The accel pedal position: {amsg:.2f}, The brake pedal: {bmsg:.2f}", flush=True)
            print(f"velocity={velocity_kmh:.2f} km/h acceleration={accel_net:.2f} m/s^2", flush=True)
            print(f"Distance travelled={dist:.2f} m", flush=True)
            return velocity_kmh, dist
    =}
    reaction(accel, brake)-> velocity, displacement{=
        
        vel, dist = self.update_car(
            accel.value if accel.is_present else None, 
            brake.value if brake.is_present else None
        )   
        velocity.set(vel)
        displacement.set(dist) 
        current_dri = lf.time.logical_elapsed()/1e6
        physical_dri = lf.time.physical_elapsed()/1e6
        lag = physical_dri - current_dri
        current_tag = lf.tag()


        
        print("----------------------------------------------------------")
       
        print(f"[VelocityDisplacement] Logical time: {current_dri:.2f} ms", flush=True)
        print(f"[VelocityDisplacement] Physical time: {physical_dri:.2f} ms", flush=True)
        print(f"[VelocityDisplacement] LAG: {lag:.2f} ms", flush=True)
        print(f"[VelocityDisplacement] Tag time: {current_tag.time} ns", flush=True)
        print(f"[VelocityDisplacement] Microstep: {current_tag.microstep}", flush=True)
        print("----------------------------------------------------------")

    =}tardy
}

federated reactor at  100.126.10.42{


    d_control = new DriverControl()
    @maxwait(100 msec)
    veldist = new VelocityDisplacement()

   
    @maxwait(100 msec)
    sim = new Simulation()
    d_control.steer -> sim.steer_in
    d_control.accelerator -> veldist.accel
    d_control.brake -> veldist.brake
    veldist.velocity -> sim.velocity_in
    veldist.displacement -> sim.rem_dist
    

   
    





    

}