target Python

preamble {=
    import csv
    import os
    import sys

    _CAR_LOG_PATH = os.getenv(
        "CAR_LOG_PATH",
        "logs-trace/car_inputs.csv",
    )
    _FEDERATE_EXECUTION_LOG_DIR = os.getenv(
        "FEDERATE_EXECUTION_LOG_DIR",
        "logs-trace",
    )
    _FEDERATE_EXECUTION_LOG_PATH = os.getenv(
        "CAR_EXECUTION_LOG_PATH",
        os.path.join(_FEDERATE_EXECUTION_LOG_DIR, "federate_execution_times_c.csv"),
    )

    def _open_execution_log():
        log_dir = os.path.dirname(_FEDERATE_EXECUTION_LOG_PATH)
        if log_dir:
            os.makedirs(log_dir, exist_ok=True)
        needs_header = (
            not os.path.exists(_FEDERATE_EXECUTION_LOG_PATH)
            or os.path.getsize(_FEDERATE_EXECUTION_LOG_PATH) == 0
        )
        log_file = open(_FEDERATE_EXECUTION_LOG_PATH, "a", newline="", encoding="utf-8")
        log_writer = csv.writer(log_file)
        if needs_header:
            log_writer.writerow([
                "federate",
                "reactor",
                "reaction",
                "logical_time_ns",
                "logical_time_ms",
                "tag_time_ns",
                "microstep",
                "lag_ms",
                "tardy_invocation_count",
                "start_physical_time_ms",
                "stop_physical_time_ms",
                "execution_time_ms",
            ])
            log_file.flush()
        return log_file, log_writer

    def _log_execution_time(self, federate, reactor, reaction, start_physical_time_ms, stop_physical_time_ms):
        current_tag = lf.tag()
        logical_time_ns = lf.time.logical_elapsed()
        if not hasattr(self, "tardy_invocation_count"):
            self.tardy_invocation_count = 0
        if "tardy" in reaction:
            self.tardy_invocation_count += 1
        self.execution_log_writer.writerow([
            federate,
            reactor,
            reaction,
            logical_time_ns,
            logical_time_ns / 1e6,
            (lf.tag().time - lf.time.start()),
            current_tag.microstep,
            start_physical_time_ms - (logical_time_ns / 1e6),
            self.tardy_invocation_count,
            start_physical_time_ms,
            stop_physical_time_ms,
            stop_physical_time_ms - start_physical_time_ms,
        ])
        self.execution_log_file.flush()
=}

reactor Car {
    input steer_in
    input accel_in
    input brake_in
    input actuate_in

    state velocity_init = 25
    state dist_init = 0.0
    state accel_val = 0.0
    state brake_val = 0.0
    state steer_val = 1

    output velocity
    output steer

    reaction(startup) {=
        self.tardy_invocation_count = 0
        os.makedirs(os.path.dirname(_CAR_LOG_PATH), exist_ok=True)
        self.car_log_file = open(_CAR_LOG_PATH, "w", newline="", encoding="utf-8")
        self.car_log_writer = csv.writer(self.car_log_file)
        self.car_log_writer.writerow([
            "event",
            "logical_time_ns",
            "logical_time_ms",
            "physical_time_ms",
            "tag_time_ns",
            "microstep",
            "lag_ms",
            "tardy_invocation_count",
            "steer_in_present",
            "accel_in_present",
            "brake_in_present",
            "actuate_in_present",
            "steer_in",
            "accel_in",
            "brake_in",
            "actuate_in",
            "car_velocity",
            "car_steer",
        ])
        self.car_log_file.flush()
        self.execution_log_file, self.execution_log_writer = _open_execution_log()
        print(f"[CAR LOG] Writing inputs to {_CAR_LOG_PATH}", flush=True)
        print(f"[EXECUTION LOG] Appending timings to {_FEDERATE_EXECUTION_LOG_PATH}", flush=True)
    =}

    preamble {=
        def actuate_logic(self, cmd):
            if cmd == "ACCEL":
                return 0.5, 0.0
            elif cmd == "BRAKE":
                return 0.0, 0.5
            elif cmd == "HOLD":
                return 0.15, 0.0
            elif cmd == "STOP":
                return 0.0, 1.0
            print("[CAR_ACTUATE]: ACTUATE CMD is invalid", flush=True)
            return 0.0, 0.0

        def update_car(self, accel_input, brake_input, steer_input, actuate_command):
            if accel_input is not None:
                self.accel_val = float(accel_input)
            if brake_input is not None:
                self.brake_val = float(brake_input)
            if steer_input is not None:
                self.steer_val = steer_input

            if actuate_command is not None:
                print(f"The actuation command: {actuate_command}", flush=True)
                amsg, bmsg = self.actuate_logic(actuate_command)
            else:
                amsg = self.accel_val
                bmsg = self.brake_val

            amsg = max(0.0, min(1.0, amsg))
            bmsg = max(0.0, min(1.0, bmsg))

            MAX_BRAKE = -10.0
            MAX_ACCEL = 4.0
            A_DRAG_COEF = -0.002
            A_FRIC_COEFF = -0.022
            DT = 0.1
            MAX_VEL = 35.0

            accel_brake = bmsg * MAX_BRAKE
            accel_throt = (0.6 * amsg + 0.4 * amsg * amsg) * MAX_ACCEL
            accel_drag = A_DRAG_COEF * self.velocity_init ** 2
            accel_net = accel_brake + accel_throt + accel_drag + A_FRIC_COEFF

            vel = max(0.0, min(MAX_VEL, self.velocity_init + accel_net * DT))
            dist = self.dist_init + vel * DT
            self.velocity_init = vel
            self.dist_init = dist

            velocity_kmh = vel * 3.6
            print(f"The accel pedal position: {amsg:.2f}, The brake pedal: {bmsg:.2f}", flush=True)
            print(f"velocity={velocity_kmh:.2f} km/h acceleration={accel_net:.2f} m/s^2", flush=True)
            print(f"Distance travelled={dist:.2f} m", flush=True)
            return velocity_kmh, self.steer_val
    =}

    reaction(steer_in, accel_in, brake_in, actuate_in) -> velocity, steer {=
        start_physical_time = lf.time.physical_elapsed()/1e6
        current_car = lf.time.logical_elapsed()/1e6
        physical_car = lf.time.physical_elapsed()/1e6
        lag = physical_car - current_car
        current_tag = lf.tag()

        print("----------------------------------------------------------")
        # print(f"[CAR] INPUT: accel: {accel_in.value} brake: {brake_in.value} steer_in: {steer_in.value} actuate: {actuate_in.value}")
        print(
            f"[CAR PRESENT] "
            f"accel={accel_in.is_present}, "
            f"brake={brake_in.is_present}, "
            f"steer={steer_in.is_present}, "
            f"actuate={actuate_in.is_present}",
            flush=True
        )
        print(f"[CAR] Logical time: {current_car:.2f} ms", flush=True)
        print(f"[CAR] Physical time: {physical_car:.2f} ms", flush=True)
        print(f"[CAR] LAG: {lag:.2f} ms", flush=True)
        print(f"[CAR] Tag time: {(lf.tag().time - lf.time.start())} ns", flush=True)
        print(f"[CAR] Microstep: {current_tag.microstep}", flush=True)
        print("----------------------------------------------------------")
        velocity_kmh, steer_value = self.update_car(
            accel_in.value if accel_in.is_present else None,
            brake_in.value if brake_in.is_present else None,
            steer_in.value if steer_in.is_present else None,
            actuate_in.value if actuate_in.is_present else None
        )
        velocity.set(velocity_kmh)
        steer.set(steer_value)
        self.car_log_writer.writerow([
            "reaction",
            lf.time.logical_elapsed(),
            lf.time.logical_elapsed() / 1e6,
            lf.time.physical_elapsed() / 1e6,
            (lf.tag().time - lf.time.start()),
            current_tag.microstep,
            lag,
            self.tardy_invocation_count,
            int(steer_in.is_present),
            int(accel_in.is_present),
            int(brake_in.is_present),
            int(actuate_in.is_present),
            steer_in.value if steer_in.is_present else "",
            accel_in.value if accel_in.is_present else "",
            brake_in.value if brake_in.is_present else "",
            actuate_in.value if actuate_in.is_present else "",
            velocity_kmh,
            steer_value,
        ])
        self.car_log_file.flush()
        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "c", "Car", "reaction", start_physical_time, stop_physical_time)
    =} tardy {=
        start_physical_time = lf.time.physical_elapsed()/1e6
        current_car = lf.time.logical_elapsed()/1e6
        physical_car = lf.time.physical_elapsed()/1e6
        lag = physical_car - current_car
        current_tag = lf.tag()

        
        velocity_kmh, steer_value = self.update_car(
            accel_in.value if accel_in.is_present else None,
            brake_in.value if brake_in.is_present else None,
            steer_in.value if steer_in.is_present else None,
            actuate_in.value if actuate_in.is_present else None
        )
        print("----------------------------------------------------------")
        # print(f"[CAR TARDY] INPUT: accel: {accel_in.value} brake: {brake_in.value} steer_in: {steer_in.value} actuate: {actuate_in.value}")
        print(
            f"[CAR PRESENT] "
            f"accel={accel_in.is_present}, "
            f"brake={brake_in.is_present}, "
            f"steer={steer_in.is_present}, "
            f"actuate={actuate_in.is_present}",
            flush=True
        )
        print(f"[CAR TARDY] Logical time: {current_car:.2f} ms", flush=True)
        print(f"[CAR TARDY] Physical time: {physical_car:.2f} ms", flush=True)
        print(f"[CAR TARDY] LAG: {lag:.2f} ms", flush=True)
        print(f"[CAR TARDY] Tag time: {(lf.tag().time - lf.time.start())} ns", flush=True)
        print(f"[CAR TARDY] Microstep: {current_tag.microstep}", flush=True)
        print("----------------------------------------------------------")
        velocity.set(velocity_kmh)
        steer.set(steer_value)
        self.car_log_writer.writerow([
            "tardy",
            lf.time.logical_elapsed(),
            lf.time.logical_elapsed() / 1e6,
            lf.time.physical_elapsed() / 1e6,
            (lf.tag().time - lf.time.start()),
            current_tag.microstep,
            lag,
            self.tardy_invocation_count + 1,
            int(steer_in.is_present),
            int(accel_in.is_present),
            int(brake_in.is_present),
            int(actuate_in.is_present),
            steer_in.value if steer_in.is_present else "",
            accel_in.value if accel_in.is_present else "",
            brake_in.value if brake_in.is_present else "",
            actuate_in.value if actuate_in.is_present else "",
            velocity_kmh,
            steer_value,
        ])
        self.car_log_file.flush()
        stop_physical_time = lf.time.physical_elapsed()/1e6
        _log_execution_time(self, "c", "Car", "tardy", start_physical_time, stop_physical_time)

    =}

    reaction(shutdown) {=
        if hasattr(self, "car_log_file") and not self.car_log_file.closed:
            self.car_log_file.flush()
            self.car_log_file.close()
        if hasattr(self, "execution_log_file") and not self.execution_log_file.closed:
            self.execution_log_file.flush()
            self.execution_log_file.close()
    =}
}
