target Python 

preamble{=
    import csv
    import json
    import os
    import sys
    import time
    import subprocess
    import threading

    _PLANNER_LOG_PATH = os.getenv(
        "PLANNER_LOG_PATH",
        "logs-trace/planner_events.csv",
    )

=}


reactor ActionPlanner {
    input ctrl
    input instr
    input s
    input v
    input en_states
    
    output act
    output planned_instr

    state last_speak_ns = -10000000000000
    state speech_proc
    state control_token = "NONE"
    state instruction_val = ""
    state distance_val = 0.0
    state velocity_val = 0.0
    state stop_completed = False

    preamble{=
        import subprocess
        import re
        import threading
        import os
        import json

        def log_planner_event(self, event, mode, from_mode="", to_mode="", reason="", act_command="", lane_command=""):
            current_tag = lf.tag()
            logical_time_ns = lf.time.logical_elapsed()
            environment_states = self.latest_environment_states if hasattr(self, "latest_environment_states") else None
            row = [
                event,
                logical_time_ns,
                logical_time_ns / 1e6,
                lf.time.physical_elapsed() / 1e6,
                current_tag.time,
                current_tag.microstep,
                mode,
                from_mode,
                to_mode,
                reason,
                self.control_token,
                self.instruction_val,
                self.distance_val,
                self.velocity_val,
                json.dumps(environment_states),
                act_command,
                lane_command,
                int(bool(act_command)),
            ]
            if hasattr(self, "planner_log_writer"):
                self.planner_log_writer.writerow(row)
                self.planner_log_file.flush()

        def log_mode_transition(self, from_mode, to_mode, reason):
            print(f"[PLANNER MODE] {from_mode} -> {to_mode} because {reason}", flush=True)
            self.log_planner_event(
                "mode_transition",
                from_mode,
                from_mode=from_mode,
                to_mode=to_mode,
                reason=reason,
            )
        

        def adaptive_cruise_control(
            self,
            road_phase,
            velocity_kmh,
            distance_to_target_m,
            front_car_present,
            right_car_present,
            right_car_position,
            cross_left_car_present,
            cross_right_car_present
        ):
            SPEED_TOLERANCE_KMH = 2.0
            lane_command = "KEEP_LANE" # default assuming there is no lane change

            if road_phase in ("HIGHWAY", "LANE_CHANGE"):
                target_speed_kmh = 90.0
            elif road_phase == "EXIT":
                target_speed_kmh = 45.0
            elif road_phase == "MOVE":
                target_speed_kmh = 25.0
            elif road_phase == "STOP_SIGN":
                target_speed_kmh = 45.0
            elif road_phase == "YIELD":
                target_speed_kmh = 25.0
            else:
                target_speed_kmh = velocity_kmh

            if road_phase not in ("STOP_SIGN", "YIELD"):
                self.stop_completed = False

            # Presence-only front-car rule for the simplified scenario.
            if front_car_present:
                return "BRAKE", lane_command

            #Right-lane safety decision
            if road_phase == "LANE_CHANGE":
                right_lane_safe = True # default for initial

                if right_car_present:
                    right_lane_safe = False

                if right_lane_safe:
                    lane_command = "CHANGE_RIGHT"

            #Hold the vehicle stopped during stop or yield phases
            if road_phase == "STOP_SIGN":
                velocity_mps = velocity_kmh / 3.6
                required_stop_distance_m = velocity_mps * 1.0 + (velocity_mps ** 2) / (2.0 * 3.0)
                if distance_to_target_m <= 1.0 and velocity_kmh <= 0.5:
                    self.stop_completed = True
                    return "STOP", "KEEP_LANE"
                if distance_to_target_m <= max(5.0, required_stop_distance_m):
                    return "BRAKE", "KEEP_LANE"
            if road_phase == "YIELD":
                cross_traffic_present = cross_left_car_present or cross_right_car_present
                if not self.stop_completed:
                    if velocity_kmh > 0.5:
                        return "BRAKE", "KEEP_LANE"
                    self.stop_completed = True
                if cross_traffic_present:
                    if velocity_kmh > 0.5:
                        return "BRAKE", "KEEP_LANE"
                    return "STOP", "KEEP_LANE"

            if velocity_kmh > target_speed_kmh + SPEED_TOLERANCE_KMH:
                speed_command = "BRAKE"
            elif velocity_kmh < target_speed_kmh - SPEED_TOLERANCE_KMH:
                speed_command = "ACCEL"
            else:
                speed_command = "HOLD"
            return speed_command, lane_command

        def speak_worker(self, msg):
            import re
            if not msg:
                return
            def convert_mps_to_kmph(match):
                val = float(match.group(1))
                kmph = int(round(val * 3.6))
                return f"{kmph} kilometers per hour"
            msg = re.sub(r"(\d+\.?\d*)\s*m/s", convert_mps_to_kmph, msg)
            msg = re.sub(r"(\d+\.?\d*)\s*mps", convert_mps_to_kmph, msg)
            msg = re.sub(r"(\d+\.?\d*)\s*meter per second", convert_mps_to_kmph, msg)
            msg = re.sub(r"\d+\.?\d*", lambda m: str(int(round(float(m.group(0))))), msg)
            msg = re.sub(
                r"(\d+\.?\d*)\s*(m/s|mps|meter per second|meters per second)",
                convert_mps_to_kmph,
                msg,
                flags=re.IGNORECASE
            )
            print(f"[DEBUG SPEAK] {msg}", flush=True)
            wav_path = "/tmp/piper_out.wav"
            proc = subprocess.Popen(
                f"echo \"{msg}\" | ~/piper/piper "
                f"--model ~/piper/en_US-lessac-medium.onnx "
                f"--length_scale 1.15 "
                f"--noise_scale 0.6 "
                f"--output_file {wav_path} && aplay {wav_path}",
                shell=True,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL
            )
            with self.speech_lock:
                self.speech_proc = proc
        def speak(self, msg):
            t = threading.Thread(target=self.speak_worker, args=(msg,))
            t.daemon = True
            t.start()
        def try_speak(self, now_ns, instruction):
            if not instruction:
                return
            if (now_ns - self.last_speak_ns) < 5000000000:
                return
            with self.speech_lock:
                if self.speech_proc and self.speech_proc.poll() is None:
                    self.speech_proc.kill()
            print(f"[LLM SPEAK] {instruction}", flush=True)
            self.speak(instruction)
            self.last_speak_ns = now_ns
    =}

    reaction(startup) {=
        
        self.speech_proc = None
        self.speech_lock = threading.Lock()
        self.latest_environment_states = None
        os.makedirs(os.path.dirname(_PLANNER_LOG_PATH), exist_ok=True)
        self.planner_log_file = open(_PLANNER_LOG_PATH, "w", newline="", encoding="utf-8")
        self.planner_log_writer = csv.writer(self.planner_log_file)
        self.planner_log_writer.writerow([
            "event",
            "logical_time_ns",
            "logical_time_ms",
            "physical_time_ms",
            "tag_time_ns",
            "microstep",
            "mode",
            "from_mode",
            "to_mode",
            "reason",
            "control_token",
            "instruction",
            "distance_to_target_m",
            "velocity_kmh",
            "environment_states_json",
            "act_command",
            "lane_command",
            "act_set",
        ])
        self.planner_log_file.flush()
        print(f"[PLANNER LOG] Writing events to {_PLANNER_LOG_PATH}", flush=True)

    =}


    initial mode monitoring {
            reaction(ctrl, instr) -> warning, actuate, planned_instr {=
                if ctrl.is_present:
                    self.control_token = (ctrl.value or "NONE").strip()
                if instr.is_present:
                    self.instruction_val = (instr.value or "").strip()
                token_keyword = self.control_token
                instruction = self.instruction_val
                now_ns = lf.time.physical_elapsed()
         

                if token_keyword == "ACTUATE":
                    if instruction:
                        print(f"[LLM] ACTUATE | {instruction}", flush=True)
                        planned_instr.set(instruction)
                        self.try_speak(now_ns, instruction)
                    current_dri = lf.time.logical_elapsed()/1e6
                    physical_dri = lf.time.physical_elapsed()/1e6
                    lag = physical_dri - current_dri
                    current_tag = lf.tag()
                    print("----------------------------------------------------------")
                    print(f"[PLANNER monitor] Logical time: {current_dri:.2f} ms", flush=True)
                    print(f"[PLANNER monitor] Physical time: {physical_dri:.2f} ms", flush=True)
                    print(f"[PLANNER monitor] LAG: {lag:.2f} ms", flush=True)
                    print(f"[PLANNER monitor] Tag time: {current_tag.time} ns", flush=True)
                    print(f"[PLANNER monitor] Microstep: {current_tag.microstep}", flush=True)
                    print("----------------------------------------------------------")
                    self.log_mode_transition("MONITORING", "ACTUATE", token_keyword)
                    actuate.set()
                    return

                if token_keyword == "WARNING":
                    if instruction:
                        print(f"[LLM] WARNING | {instruction}", flush=True)
                        planned_instr.set(instruction)
                        self.try_speak(now_ns, instruction)
                    current_dri = lf.time.logical_elapsed()/1e6
                    physical_dri = lf.time.physical_elapsed()/1e6
                    lag = physical_dri - current_dri
                    current_tag = lf.tag()
                    print("----------------------------------------------------------")
                    print(f"[PLANNER monitor] Logical time: {current_dri:.2f} ms", flush=True)
                    print(f"[PLANNER monitor] Physical time: {physical_dri:.2f} ms", flush=True)
                    print(f"[PLANNER monitor] LAG: {lag:.2f} ms", flush=True)
                    print(f"[PLANNER monitor] Tag time: {current_tag.time} ns", flush=True)
                    print(f"[PLANNER monitor] Microstep: {current_tag.microstep}", flush=True)
                    print("----------------------------------------------------------")
                    self.log_mode_transition("MONITORING", "WARNING", token_keyword)
                    warning.set()
                    return

                if token_keyword == "NONE":
                    if instruction:
                        print(f"[LLM] NONE | {instruction}", flush=True)
                        planned_instr.set(instruction)
                        self.try_speak(now_ns, instruction)

                current_dri = lf.time.logical_elapsed()/1e6
                physical_dri = lf.time.physical_elapsed()/1e6
                lag = physical_dri - current_dri
                current_tag = lf.tag()
                print("----------------------------------------------------------")
                print(f"[PLANNER monitor] Logical time: {current_dri:.2f} ms", flush=True)
                print(f"[PLANNER monitor] Physical time: {physical_dri:.2f} ms", flush=True)
                print(f"[PLANNER monitor] LAG: {lag:.2f} ms", flush=True)
                print(f"[PLANNER monitor] Tag time: {current_tag.time} ns", flush=True)
                print(f"[PLANNER monitor] Microstep: {current_tag.microstep}", flush=True)
                print("----------------------------------------------------------")
            =} tardy {=
                if ctrl.is_present:
                    self.control_token = (ctrl.value or "NONE").strip()
                if instr.is_present:
                    self.instruction_val = (instr.value or "").strip()

                token_keyword = self.control_token
                instruction = self.instruction_val
                print(f"[PLANNER MONITORING TARDY] Processing {token_keyword}", flush=True)
                if instruction:
                    planned_instr.set(instruction)
                    self.try_speak(lf.time.physical_elapsed(), instruction)
                if token_keyword == "ACTUATE":
                    self.log_mode_transition("MONITORING", "ACTUATE", f"tardy {token_keyword}")
                    actuate.set()
                elif token_keyword == "WARNING":
                    self.log_mode_transition("MONITORING", "WARNING", f"tardy {token_keyword}")
                    warning.set()
            =}
    }

    mode warning {
            reaction(ctrl, instr) -> monitoring, actuate, planned_instr {=
                if ctrl.is_present:
                    self.control_token = (ctrl.value or "NONE").strip()
                if instr.is_present:
                    self.instruction_val = (instr.value or "").strip()
                token_keyword = self.control_token
                instruction = self.instruction_val
                now_ns = lf.time.physical_elapsed()
   

                if token_keyword == "ACTUATE":
                    if instruction:
                        print(f"[LLM] ACTUATE | {instruction}", flush=True)
                        planned_instr.set(instruction)
                        self.try_speak(now_ns, instruction)
                    current_dri = lf.time.logical_elapsed()/1e6
                    physical_dri = lf.time.physical_elapsed()/1e6
                    lag = physical_dri - current_dri
                    current_tag = lf.tag()
                    print("----------------------------------------------------------")
                    print(f"[PLANNER WARNING ] Logical time: {current_dri:.2f} ms", flush=True)
                    print(f"[PLANNER WARNING] Physical time: {physical_dri:.2f} ms", flush=True)
                    print(f"[PLANNER WARNING] LAG: {lag:.2f} ms", flush=True)
                    print(f"[PLANNER WARNING] Tag time: {current_tag.time} ns", flush=True)
                    print(f"[PLANNER WARNING] Microstep: {current_tag.microstep}", flush=True)
                    print("----------------------------------------------------------")
                    self.log_mode_transition("WARNING", "ACTUATE", token_keyword)
                    actuate.set()
                    return

                if token_keyword != "WARNING":
                    current_dri = lf.time.logical_elapsed()/1e6
                    physical_dri = lf.time.physical_elapsed()/1e6
                    lag = physical_dri - current_dri
                    current_tag = lf.tag()
                    print("----------------------------------------------------------")
                    print(f"[PLANNER WARNING] Logical time: {current_dri:.2f} ms", flush=True)
                    print(f"[PLANNER WARNING] Physical time: {physical_dri:.2f} ms", flush=True)
                    print(f"[PLANNER WARNING] LAG: {lag:.2f} ms", flush=True)
                    print(f"[PLANNER WARNING] Tag time: {current_tag.time} ns", flush=True)
                    print(f"[PLANNER WARNING] Microstep: {current_tag.microstep}", flush=True)
                    print("----------------------------------------------------------")
                    self.log_mode_transition("WARNING", "MONITORING", token_keyword)
                    monitoring.set()
                    return
                if instruction:
                    self.try_speak(now_ns, instruction)

                current_dri = lf.time.logical_elapsed()/1e6
                physical_dri = lf.time.physical_elapsed()/1e6
                lag = physical_dri - current_dri
                current_tag = lf.tag()
                print("----------------------------------------------------------")
                print(f"[PLANNER WARNING] Logical time: {current_dri:.2f} ms", flush=True)
                print(f"[PLANNER WARNING] Physical time: {physical_dri:.2f} ms", flush=True)
                print(f"[PLANNER WARNING] LAG: {lag:.2f} ms", flush=True)
                print(f"[PLANNER WARNING] Tag time: {current_tag.time} ns", flush=True)
                print(f"[PLANNER WARNING] Microstep: {current_tag.microstep}", flush=True)
                print("----------------------------------------------------------")
            =} tardy {=

                if ctrl.is_present:
                    self.control_token = (ctrl.value or "NONE").strip()
                if instr.is_present:
                    self.instruction_val = (instr.value or "").strip()

                token_keyword = self.control_token
                instruction = self.instruction_val
                print(f"[PLANNER WARNING TARDY] Processing {token_keyword}", flush=True)
                if instruction:
                    planned_instr.set(instruction)
                    self.try_speak(lf.time.physical_elapsed(), instruction)
                if token_keyword == "ACTUATE":
                    self.log_mode_transition("WARNING", "ACTUATE", f"tardy {token_keyword}")
                    actuate.set()
                elif token_keyword != "WARNING":
                    self.log_mode_transition("WARNING", "MONITORING", f"tardy {token_keyword}")
                    monitoring.set()
            =}
    }

    mode actuate {
            reaction(ctrl, instr, s, v, en_states) -> act, monitoring, planned_instr {=
                if ctrl.is_present:
                    self.control_token = (ctrl.value or "NONE").strip()
                if instr.is_present:
                    self.instruction_val = (instr.value or "").strip()
                if s.is_present:
                    self.distance_val = s.value
                if v.is_present:
                    self.velocity_val = v.value
                if en_states.is_present:
                    self.latest_environment_states = en_states.value
                token_keyword = self.control_token
                instruction = self.instruction_val
                velocity_kmh = self.velocity_val
                rd = self.distance_val

                now_ns = lf.time.physical_elapsed()

                if token_keyword != "ACTUATE":
                    self.log_mode_transition("ACTUATE", "MONITORING", token_keyword)
                    monitoring.set()
                    current_dri = lf.time.logical_elapsed()/1e6
                    physical_dri = lf.time.physical_elapsed()/1e6
                    lag = physical_dri - current_dri
                    current_tag = lf.tag()
                    print("----------------------------------------------------------")
                    print(f"[PLANNER ACTUATE] Logical time: {current_dri:.2f} ms", flush=True)
                    print(f"[PLANNER ACTUATE] Physical time: {physical_dri:.2f} ms", flush=True)
                    print(f"[PLANNER ACTUATE] LAG: {lag:.2f} ms", flush=True)
                    print(f"[PLANNER ACTUATE] Tag time: {current_tag.time} ns", flush=True)
                    print(f"[PLANNER ACTUATE] Microstep: {current_tag.microstep}", flush=True)
                    print("----------------------------------------------------------")
                    return

                environment_states = self.latest_environment_states
                if environment_states is None or len(environment_states) != 6:
                    raise RuntimeError(f"Planner expected 6 environment state values, received: {environment_states}")
                road_phase, front_car_present, right_car_present, right_car_position, cross_left_car_present, cross_right_car_present = environment_states

                speed_command, lane_command = self.adaptive_cruise_control(road_phase, velocity_kmh, rd, front_car_present, right_car_present, right_car_position, cross_left_car_present, cross_right_car_present)
                act.set(speed_command)
                self.log_planner_event(
                    "act_command_set",
                    "ACTUATE",
                    reason=token_keyword,
                    act_command=speed_command,
                    lane_command=lane_command,
                )

                if instruction:
                    self.try_speak(now_ns, instruction)

                current_dri = lf.time.logical_elapsed()/1e6
                physical_dri = lf.time.physical_elapsed()/1e6
                lag = physical_dri - current_dri
                current_tag = lf.tag()
                print("----------------------------------------------------------")
                print(f"[PLANNER ACTUATE] Logical time: {current_dri:.2f} ms", flush=True)
                print(f"[PLANNER ACTUATE] Physical time: {physical_dri:.2f} ms", flush=True)
                print(f"[PLANNER ACTUATE] LAG: {lag:.2f} ms", flush=True)
                print(f"[PLANNER ACTUATE] Tag time: {current_tag.time} ns", flush=True)
                print(f"[PLANNER ACTUATE] Microstep: {current_tag.microstep}", flush=True)
                print("----------------------------------------------------------")
            =} tardy {=
                logical_ms = lf.time.logical_elapsed()/1e6
                physical_ms = lf.time.physical_elapsed()/1e6
                message_age_ms = physical_ms - logical_ms
                if message_age_ms > 400.0:
                    print(f"[PLANNER ACTUATE TARDY] Discarded: age={message_age_ms:.2f} ms", flush=True)
                    return
                if ctrl.is_present:
                    self.control_token = (ctrl.value or "NONE").strip()
                if instr.is_present:
                    self.instruction_val = (instr.value or "").strip()
                if s.is_present:
                    self.distance_val = s.value
                if v.is_present:
                    self.velocity_val = v.value
                if en_states.is_present:
                    self.latest_environment_states = en_states.value
                token_keyword = self.control_token
                print(f"[PLANNER ACTUATE TARDY] Processing {token_keyword}: age={message_age_ms:.2f} ms", flush=True)
                if token_keyword != "ACTUATE":
                    self.log_mode_transition("ACTUATE", "MONITORING", token_keyword)
                    monitoring.set()
                    return
                environment_states = self.latest_environment_states
                if environment_states is None or len(environment_states) != 6:
                    print(f"[PLANNER ACTUATE TARDY] Missing environment state; discarding: {environment_states}", flush=True)
                    return
                road_phase, front_car_present, right_car_present, right_car_position, cross_left_car_present, cross_right_car_present = environment_states
                speed_command, lane_command = self.adaptive_cruise_control(road_phase, self.velocity_val, self.distance_val, front_car_present, right_car_present, right_car_position, cross_left_car_present, cross_right_car_present)
                act.set(speed_command)
                self.log_planner_event(
                    "act_command_set_tardy",
                    "ACTUATE",
                    reason=f"tardy {token_keyword}",
                    act_command=speed_command,
                    lane_command=lane_command,
                )

            =}
    }

    reaction(shutdown) {=
        if hasattr(self, "planner_log_file") and not self.planner_log_file.closed:
            self.planner_log_file.flush()
            self.planner_log_file.close()
    =}
}
