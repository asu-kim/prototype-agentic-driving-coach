target Python 

preamble{=
    import os
    import rerun as rr
    import time
    import subprocess
    import threading
    import csv
    _ACTUATOR_IDS = {"STOP": 0.0, "BRAKE": 1.0, "HOLD": 2.0, "ACCEL": 3.0}
    _MODE_IDS = {"MONITORING": 0.0, "WARNING": 1.0, "ACTUATE": 2.0}
=}


reactor ActionPlanner {
    input ctrl
    input instr
    input s
    input v
    input en_states
    
    output act
    output planned_instr

    state last_speak_ns = -10000000000000
    state speech_proc
    state control_token = "NONE"
    state instruction_val = ""
    state distance_val = 0.0
    state velocity_val = 0.0

    preamble{=
        import subprocess
        import re
        import threading
        import os

        def log_mode_transition(self, from_mode, to_mode, reason):
            logical_ms = lf.time.logical_elapsed() / 1_000_000
            rr.set_time("logical_time_ms", sequence=int(logical_ms))
            rr.log("planner/mode", rr.TextLog(to_mode))
            rr.log("planner/mode_id", rr.Scalars(_MODE_IDS[to_mode]))
            rr.log("planner/mode_transitions", rr.TextLog(f"{from_mode} -> {to_mode}: {reason}"))
            print(f"[PLANNER MODE] {from_mode} -> {to_mode}: {reason}", flush=True)

        def adaptive_cruise_control(
            self,
            road_phase,
            velocity_kmh,
            distance_to_target_m,
            other_car_present, # this is for the car in front after changing lane 
            other_distance_m,
            other_velocity_kmh,
            right_car_present, # this is for the car in on right lane while changing lane 
            right_car_position,
            right_car_distance_m,
            right_car_velocity_kmh,
            cross_left_car_present,# this is for the cars on right cross and left cross for stop sign
            cross_right_car_present
        ):
            SPEED_TOLERANCE_KMH = 2.0
            MIN_FRONT_DISTANCE_M = 10.0
            MIN_LANE_CHANGE_DISTANCE_M = 20.0
            lane_command = "KEEP_LANE" # default assuming there is no lane change

            if road_phase in ("HIGHWAY", "LANE_CHANGE"):
                target_speed_kmh = 90.0
            elif road_phase == "EXIT":
                target_speed_kmh = 45.0
            elif road_phase == "MOVE":
                target_speed_kmh = 25.0
            elif road_phase == "STOP_SIGN":
                target_speed_kmh = 45.0
            elif road_phase == "YIELD":
                target_speed_kmh = 0.0
            else:
                target_speed_kmh = velocity_kmh

            safe_front_distance_m = max(MIN_FRONT_DISTANCE_M,(velocity_kmh / 3.6) * 2.0)

            # Current-lane lead vehicle ACC
            if other_car_present:
                if other_distance_m < safe_front_distance_m:
                    return "BRAKE", lane_command

                if other_distance_m < safe_front_distance_m * 2.0:
                    target_speed_kmh = min(target_speed_kmh,other_velocity_kmh)

            #Right-lane safety decision
            if road_phase == "LANE_CHANGE":
                right_lane_safe = True # default for initial

                if right_car_present:
                    if right_car_position == "RIGHT_SIDE":
                        right_lane_safe = False

                    elif right_car_position == "RIGHT_REAR":
                        rear_closing_speed_kmh = (right_car_velocity_kmh - velocity_kmh)
                        if (right_car_distance_m < MIN_LANE_CHANGE_DISTANCE_M or rear_closing_speed_kmh > 5.0):
                            right_lane_safe = False
                    elif right_car_position == "RIGHT_FRONT":
                        front_closing_speed_kmh = (velocity_kmh - right_car_velocity_kmh)

                        if (right_car_distance_m < MIN_LANE_CHANGE_DISTANCE_M or front_closing_speed_kmh > 5.0):
                            right_lane_safe = False

                if right_lane_safe:
                    lane_command = "CHANGE_RIGHT"

            #Hold the vehicle stopped during stop or yield phases
            if road_phase == "STOP_SIGN":
                velocity_mps = velocity_kmh / 3.6
                required_stop_distance_m = velocity_mps * 1.0 + (velocity_mps ** 2) / (2.0 * 3.0)
                if distance_to_target_m <= 1.0 and velocity_kmh <= 0.5:
                    return "STOP", "KEEP_LANE"
                if distance_to_target_m <= max(5.0, required_stop_distance_m):
                    return "BRAKE", "KEEP_LANE"
            if road_phase == "YIELD":
                if velocity_kmh > 0.5:
                    return "BRAKE", "KEEP_LANE"
                return "STOP", "KEEP_LANE"

            if velocity_kmh > target_speed_kmh + SPEED_TOLERANCE_KMH:
                speed_command = "BRAKE"
            elif velocity_kmh < target_speed_kmh - SPEED_TOLERANCE_KMH:
                speed_command = "ACCEL"
            else:
                speed_command = "HOLD"
            return speed_command, lane_command

        def speak_worker(self, msg):
            import re
            if not msg:
                return
            def convert_mps_to_kmph(match):
                val = float(match.group(1))
                kmph = int(round(val * 3.6))
                return f"{kmph} kilometers per hour"
            msg = re.sub(r"(\d+\.?\d*)\s*m/s", convert_mps_to_kmph, msg)
            msg = re.sub(r"(\d+\.?\d*)\s*mps", convert_mps_to_kmph, msg)
            msg = re.sub(r"(\d+\.?\d*)\s*meter per second", convert_mps_to_kmph, msg)
            msg = re.sub(r"\d+\.?\d*", lambda m: str(int(round(float(m.group(0))))), msg)
            msg = re.sub(
                r"(\d+\.?\d*)\s*(m/s|mps|meter per second|meters per second)",
                convert_mps_to_kmph,
                msg,
                flags=re.IGNORECASE
            )
            print(f"[DEBUG SPEAK] {msg}", flush=True)
            wav_path = "/tmp/piper_out.wav"
            proc = subprocess.Popen(
                f"echo \"{msg}\" | ~/piper/piper "
                f"--model ~/piper/en_US-lessac-medium.onnx "
                f"--length_scale 1.15 "
                f"--noise_scale 0.6 "
                f"--output_file {wav_path} && aplay {wav_path}",
                shell=True,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL
            )
            with self.speech_lock:
                self.speech_proc = proc
        def speak(self, msg):
            t = threading.Thread(target=self.speak_worker, args=(msg,))
            t.daemon = True
            t.start()
        def try_speak(self, now_ns, instruction):
            if not instruction:
                return
            if (now_ns - self.last_speak_ns) < 5000000000:
                return
            with self.speech_lock:
                if self.speech_proc and self.speech_proc.poll() is None:
                    self.speech_proc.kill()
            print(f"[LLM SPEAK] {instruction}", flush=True)
            self.speak(instruction)
            self.last_speak_ns = now_ns
    =}

    reaction(startup) {=
        rr.init(
            "hardware_integrated_adc",
            recording_id=os.getenv("RERUN_RECORDING_ID", "hardware_integrated_adc_run")
        )
        rr.connect_grpc(os.getenv("RERUN_GRPC_URL", "rerun+http://127.0.0.1:9876/proxy"))
        print("[RERUN] Planner viewer initialized.", flush=True)
        self.speech_proc = None
        self.speech_lock = threading.Lock()
        self.latest_environment_states = None
        rr.set_time("logical_time_ms", sequence=lf.time.logical_elapsed() // 1_000_000)
        rr.log("planner/mode", rr.TextLog("MONITORING"))
        rr.log("planner/mode_id", rr.Scalars(_MODE_IDS["MONITORING"]))
        print("[PLANNER MODE] Initial mode: MONITORING", flush=True)
    =}


    initial mode monitoring {
            reaction(ctrl, instr, s, v) -> warning, actuate, planned_instr {=
                if ctrl.is_present:
                    self.control_token = (ctrl.value or "NONE").strip()
                if instr.is_present:
                    self.instruction_val = (instr.value or "").strip()
                if s.is_present:
                    self.distance_val = s.value
                if v.is_present:
                    self.velocity_val = v.value
                token_keyword = self.control_token
                instruction = self.instruction_val
                rd = self.distance_val
                v_val = self.velocity_val
                now_ns = lf.time.physical_elapsed()
                print(f"[RD PLANNER]: {rd:.2f}")

                if token_keyword == "ACTUATE":
                    if instruction:
                        print(f"[LLM] ACTUATE | {instruction}", flush=True)
                        planned_instr.set(instruction)
                        self.try_speak(now_ns, instruction)
                    current_dri = lf.time.logical_elapsed()/1e6
                    physical_dri = lf.time.physical_elapsed()/1e6
                    lag = physical_dri - current_dri
                    print("----------------------------------------------------------")
                    print(f"[PLANNER monitor] Logical time: {current_dri:.2f} ms", flush=True)
                    print(f"[PLANNER monitor] Physical time: {physical_dri:.2f} ms", flush=True)
                    print(f"[PLANNER monitor] LAG: {lag:.2f} ms", flush=True)
                    print("----------------------------------------------------------")
                    self.log_mode_transition("MONITORING", "ACTUATE", token_keyword)
                    actuate.set()
                    return

                if token_keyword == "WARNING":
                    if instruction:
                        print(f"[LLM] WARNING | {instruction}", flush=True)
                        planned_instr.set(instruction)
                        self.try_speak(now_ns, instruction)
                    current_dri = lf.time.logical_elapsed()/1e6
                    physical_dri = lf.time.physical_elapsed()/1e6
                    lag = physical_dri - current_dri
                    print("----------------------------------------------------------")
                    print(f"[PLANNER monitor] Logical time: {current_dri:.2f} ms", flush=True)
                    print(f"[PLANNER monitor] Physical time: {physical_dri:.2f} ms", flush=True)
                    print(f"[PLANNER monitor] LAG: {lag:.2f} ms", flush=True)
                    print("----------------------------------------------------------")
                    self.log_mode_transition("MONITORING", "WARNING", token_keyword)
                    warning.set()
                    return

                if token_keyword == "NONE":
                    if instruction:
                        print(f"[LLM] NONE | {instruction}", flush=True)
                        planned_instr.set(instruction)
                        self.try_speak(now_ns, instruction)

                current_dri = lf.time.logical_elapsed()/1e6
                physical_dri = lf.time.physical_elapsed()/1e6
                lag = physical_dri - current_dri
                print("----------------------------------------------------------")
                print(f"[PLANNER monitor] Logical time: {current_dri:.2f} ms", flush=True)
                print(f"[PLANNER monitor] Physical time: {physical_dri:.2f} ms", flush=True)
                print(f"[PLANNER monitor] LAG: {lag:.2f} ms", flush=True)
                print("----------------------------------------------------------")
            =} tardy {=
                logical_ms = lf.time.logical_elapsed()/1e6
                physical_ms = lf.time.physical_elapsed()/1e6
                message_age_ms = physical_ms - logical_ms
                if message_age_ms > 400.0:
                    print(f"[PLANNER MONITORING TARDY] Discarded: age={message_age_ms:.2f} ms", flush=True)
                    return
                if ctrl.is_present:
                    self.control_token = (ctrl.value or "NONE").strip()
                if instr.is_present:
                    self.instruction_val = (instr.value or "").strip()
                if s.is_present:
                    self.distance_val = s.value
                if v.is_present:
                    self.velocity_val = v.value
                token_keyword = self.control_token
                instruction = self.instruction_val
                print(f"[PLANNER MONITORING TARDY] Processing {token_keyword}: age={message_age_ms:.2f} ms", flush=True)
                if instruction:
                    planned_instr.set(instruction)
                    self.try_speak(lf.time.physical_elapsed(), instruction)
                if token_keyword == "ACTUATE":
                    self.log_mode_transition("MONITORING", "ACTUATE", f"tardy {token_keyword}")
                    actuate.set()
                elif token_keyword == "WARNING":
                    self.log_mode_transition("MONITORING", "WARNING", f"tardy {token_keyword}")
                    warning.set()
            =}
    }

    mode warning {
            reaction(ctrl, instr, s, v) -> monitoring, actuate, planned_instr {=
                if ctrl.is_present:
                    self.control_token = (ctrl.value or "NONE").strip()
                if instr.is_present:
                    self.instruction_val = (instr.value or "").strip()
                if s.is_present:
                    self.distance_val = s.value
                if v.is_present:
                    self.velocity_val = v.value
                token_keyword = self.control_token
                instruction = self.instruction_val
                now_ns = lf.time.physical_elapsed()
                rd = self.distance_val
                print(f"[RD PLANNER]: {rd:.2f}")

                if token_keyword == "ACTUATE":
                    if instruction:
                        print(f"[LLM] ACTUATE | {instruction}", flush=True)
                        planned_instr.set(instruction)
                        self.try_speak(now_ns, instruction)
                    current_dri = lf.time.logical_elapsed()/1e6
                    physical_dri = lf.time.physical_elapsed()/1e6
                    lag = physical_dri - current_dri
                    print("----------------------------------------------------------")
                    print(f"[PLANNER WARNING ] Logical time: {current_dri:.2f} ms", flush=True)
                    print(f"[PLANNER WARNING] Physical time: {physical_dri:.2f} ms", flush=True)
                    print(f"[PLANNER WARNING] LAG: {lag:.2f} ms", flush=True)
                    print("----------------------------------------------------------")
                    self.log_mode_transition("WARNING", "ACTUATE", token_keyword)
                    actuate.set()
                    return

                if token_keyword != "WARNING":
                    current_dri = lf.time.logical_elapsed()/1e6
                    physical_dri = lf.time.physical_elapsed()/1e6
                    lag = physical_dri - current_dri
                    print("----------------------------------------------------------")
                    print(f"[PLANNER WARNING] Logical time: {current_dri:.2f} ms", flush=True)
                    print(f"[PLANNER WARNING] Physical time: {physical_dri:.2f} ms", flush=True)
                    print(f"[PLANNER WARNING] LAG: {lag:.2f} ms", flush=True)
                    print("----------------------------------------------------------")
                    self.log_mode_transition("WARNING", "MONITORING", token_keyword)
                    monitoring.set()
                    return
                if instruction:
                    self.try_speak(now_ns, instruction)

                current_dri = lf.time.logical_elapsed()/1e6
                physical_dri = lf.time.physical_elapsed()/1e6
                lag = physical_dri - current_dri
                print("----------------------------------------------------------")
                print(f"[PLANNER WARNING] Logical time: {current_dri:.2f} ms", flush=True)
                print(f"[PLANNER WARNING] Physical time: {physical_dri:.2f} ms", flush=True)
                print(f"[PLANNER WARNING] LAG: {lag:.2f} ms", flush=True)
                print("----------------------------------------------------------")
            =} tardy {=
                logical_ms = lf.time.logical_elapsed()/1e6
                physical_ms = lf.time.physical_elapsed()/1e6
                message_age_ms = physical_ms - logical_ms
                if message_age_ms > 400.0:
                    print(f"[PLANNER WARNING TARDY] Discarded: age={message_age_ms:.2f} ms", flush=True)
                    return
                if ctrl.is_present:
                    self.control_token = (ctrl.value or "NONE").strip()
                if instr.is_present:
                    self.instruction_val = (instr.value or "").strip()
                if s.is_present:
                    self.distance_val = s.value
                if v.is_present:
                    self.velocity_val = v.value
                token_keyword = self.control_token
                instruction = self.instruction_val
                print(f"[PLANNER WARNING TARDY] Processing {token_keyword}: age={message_age_ms:.2f} ms", flush=True)
                if instruction:
                    planned_instr.set(instruction)
                    self.try_speak(lf.time.physical_elapsed(), instruction)
                if token_keyword == "ACTUATE":
                    self.log_mode_transition("WARNING", "ACTUATE", f"tardy {token_keyword}")
                    actuate.set()
                elif token_keyword != "WARNING":
                    self.log_mode_transition("WARNING", "MONITORING", f"tardy {token_keyword}")
                    monitoring.set()
            =}
    }

    mode actuate {
            reaction(ctrl, instr, s, v, en_states) -> act,  monitoring, planned_instr {=
                if ctrl.is_present:
                    self.control_token = (ctrl.value or "NONE").strip()
                if instr.is_present:
                    self.instruction_val = (instr.value or "").strip()
                if s.is_present:
                    self.distance_val = s.value
                if v.is_present:
                    self.velocity_val = v.value
                if en_states.is_present:
                    self.latest_environment_states = en_states.value
                token_keyword = self.control_token
                instruction = self.instruction_val
                velocity_kmh = self.velocity_val
                rd = self.distance_val

                now_ns = lf.time.physical_elapsed()

                if token_keyword != "ACTUATE":
                    self.log_mode_transition("ACTUATE", "MONITORING", token_keyword)
                    monitoring.set()
                    current_dri = lf.time.logical_elapsed()/1e6
                    physical_dri = lf.time.physical_elapsed()/1e6
                    lag = physical_dri - current_dri
                    print("----------------------------------------------------------")
                    print(f"[PLANNER ACTUATE] Logical time: {current_dri:.2f} ms", flush=True)
                    print(f"[PLANNER ACTUATE] Physical time: {physical_dri:.2f} ms", flush=True)
                    print(f"[PLANNER ACTUATE] LAG: {lag:.2f} ms", flush=True)
                    print("----------------------------------------------------------")
                    return

                environment_states = self.latest_environment_states
                if environment_states is None or len(environment_states) != 10:
                    raise RuntimeError(f"Planner expected 10 environment state values, received: {environment_states}")
                road_phase, other_car_present, other_distance_m, other_velocity_kmh, right_car_present, right_car_position, right_car_distance_m, right_car_velocity_kmh, cross_left_car_present, cross_right_car_present = environment_states

                speed_command, lane_command = self.adaptive_cruise_control(road_phase, velocity_kmh, rd, other_car_present, other_distance_m, other_velocity_kmh, right_car_present, right_car_position, right_car_distance_m, right_car_velocity_kmh, cross_left_car_present, cross_right_car_present)
                act.set(speed_command)
                rr.set_time("logical_time_ms", sequence=lf.time.logical_elapsed() // 1_000_000)
                rr.log("planner/actuator_command_id", rr.Scalars(_ACTUATOR_IDS.get(speed_command, -1.0)))
                rr.log("planner/actuator_command", rr.TextLog(speed_command))

                if instruction:
                    self.try_speak(now_ns, instruction)

                current_dri = lf.time.logical_elapsed()/1e6
                physical_dri = lf.time.physical_elapsed()/1e6
                lag = physical_dri - current_dri
                print("----------------------------------------------------------")
                print(f"[PLANNER ACTUATE] Logical time: {current_dri:.2f} ms", flush=True)
                print(f"[PLANNER ACTUATE] Physical time: {physical_dri:.2f} ms", flush=True)
                print(f"[PLANNER ACTUATE] LAG: {lag:.2f} ms", flush=True)
                print("----------------------------------------------------------")
            =} tardy {=
                logical_ms = lf.time.logical_elapsed()/1e6
                physical_ms = lf.time.physical_elapsed()/1e6
                message_age_ms = physical_ms - logical_ms
                if message_age_ms > 400.0:
                    print(f"[PLANNER ACTUATE TARDY] Discarded: age={message_age_ms:.2f} ms", flush=True)
                    return
                if ctrl.is_present:
                    self.control_token = (ctrl.value or "NONE").strip()
                if instr.is_present:
                    self.instruction_val = (instr.value or "").strip()
                if s.is_present:
                    self.distance_val = s.value
                if v.is_present:
                    self.velocity_val = v.value
                if en_states.is_present:
                    self.latest_environment_states = en_states.value
                token_keyword = self.control_token
                print(f"[PLANNER ACTUATE TARDY] Processing {token_keyword}: age={message_age_ms:.2f} ms", flush=True)
                if token_keyword != "ACTUATE":
                    self.log_mode_transition("ACTUATE", "MONITORING", token_keyword)
                    monitoring.set()
                    return
                environment_states = self.latest_environment_states
                if environment_states is None or len(environment_states) != 10:
                    print(f"[PLANNER ACTUATE TARDY] Missing environment state; discarding: {environment_states}", flush=True)
                    return
                road_phase, other_car_present, other_distance_m, other_velocity_kmh, right_car_present, right_car_position, right_car_distance_m, right_car_velocity_kmh, cross_left_car_present, cross_right_car_present = environment_states
                speed_command, lane_command = self.adaptive_cruise_control(road_phase, self.velocity_val, self.distance_val, other_car_present, other_distance_m, other_velocity_kmh, right_car_present, right_car_position, right_car_distance_m, right_car_velocity_kmh, cross_left_car_present, cross_right_car_present)
                act.set(speed_command)
                rr.set_time("logical_time_ms", sequence=lf.time.logical_elapsed() // 1_000_000)
                rr.log("planner/actuator_command_id", rr.Scalars(_ACTUATOR_IDS.get(speed_command, -1.0)))
                rr.log("planner/actuator_command", rr.TextLog(speed_command))
            =}
    } 
}

