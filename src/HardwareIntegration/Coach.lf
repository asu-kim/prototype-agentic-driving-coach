target Python 

reactor Coach{
    input s
    input v
    input st 
    input h
    input e
    timer llmclock(4 sec, 400 msec)

    state s_val = 0.0
    state v_val = 0.0
    state st_val = 2
    state h_val = 5

    output displacement
    output velocity
    output steer 
    output head_pos
    output eye_pos

    
    reaction(startup){=
        self.head_history = []
        self.eye_history = []
        self.max_history = 4
    =}
    reaction(s, v, st, h,e){=
         if s.is_present:
             self.s_val = s.value
         if v.is_present:
             self.v_val = v.value
         if st.is_present:
             self.st_val = st.value
         if h.is_present:
             self.h_val = h.value
             print(f"Head value every 100ms: {self.h_val}")
             if self.h_val == 0:
                 self.head_history.append("LEFT")
             elif self.h_val == 1:
                 self.head_history.append("CENTER")
             elif self.h_val == 2:
                 self.head_history.append("RIGHT")
             else:
                 self.head_history.append("CENTER")
         if e.is_present:
             self.e_val = e.value
             print(f"EYE value every 100ms: {self.e_val}")
             if self.e_val == 0:
                 self.eye_history.append("LEFT")
             elif self.e_val == 1:
                 self.eye_history.append("CENTER")
             elif self.e_val == 2:
                 self.eye_history.append("RIGHT")
             else:
                 self.eye_history.append("CENTER")
         self.head_history = self.head_history[-self.max_history:]
         self.eye_history = self.eye_history[-self.max_history:]
     =}

    
    reaction(llmclock)->displacement, velocity, steer, head_pos, eye_pos{=
        displacement.set(self.s.value)
        velocity.set(self.v.value)
        steer.set(self.st.value)
        head_pos.set(self.head_history)
        eye_pos.set(self.eye_history)

    =}

   
    
}